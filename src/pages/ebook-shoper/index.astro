---
export const prerender = true;

import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="ROI 23 815% — 10 sklepów Shoper i ich wyniki z automatyzacji | edrone"
  description="Pobierz darmowy ebook: jak 10 sklepów na Shoper wygenerowało 4,9 mln zł z automatyzacji marketingowej w edrone. Dane, screeny, wnioski."
  lang="pl"
  ogUrl="https://roi.edrone.me/ebook-shoper/"
  googleFont="Inter:wght@400;500;600;700;800;900"
>

<style>
:root {
  --yellow: #FACC15;
  --yellow-soft: #FEF9C3;
  --yellow-bg: #FFFBEB;
  --black: #0f172a;
  --dark: #1e293b;
  --gray-900: #334155;
  --gray-600: #64748b;
  --gray-400: #94a3b8;
  --gray-200: #e2e8f0;
  --gray-100: #f1f5f9;
  --gray-50: #f8fafc;
  --white: #ffffff;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  color: var(--black);
  background: var(--white);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }

/* HEADER */
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--gray-200);
}
.header-inner {
  max-width: 1120px; margin: 0 auto; padding: 0 24px;
  display: flex; align-items: center; justify-content: space-between; height: 64px;
}
.header-logo svg { display: block; }

/* BUTTONS */
.btn-yellow {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--yellow); color: var(--black); font-weight: 700;
  font-size: 14px; padding: 10px 24px; border-radius: 10px;
  border: none; cursor: pointer; transition: background 0.2s, transform 0.15s;
  text-decoration: none;
}
.btn-yellow:hover { background: #eab308; transform: translateY(-1px); }
.btn-hero { font-size: 17px; padding: 16px 36px; border-radius: 12px; }

/* HERO */
.hero { padding: 120px 0 80px; }
.hero-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;
}
.hero-badge {
  display: inline-block; background: var(--yellow-soft); color: var(--dark);
  font-weight: 700; font-size: 13px; letter-spacing: 0.05em;
  padding: 6px 14px; border-radius: 100px; margin-bottom: 20px;
}
.hero h1 {
  font-size: 42px; font-weight: 900; line-height: 1.12;
  color: var(--black); margin-bottom: 16px;
}
.hero h1 .accent { color: #ca8a04; }
.hero-subtitle {
  font-size: 17px; color: var(--gray-600); line-height: 1.65;
  margin-bottom: 24px; max-width: 500px;
}
.stat-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 32px; }
.stat-pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--gray-100); padding: 8px 16px; border-radius: 100px;
  font-size: 13px; font-weight: 600; color: var(--gray-900);
}
.stat-pill .dot { width: 8px; height: 8px; background: var(--yellow); border-radius: 50%; }
.hero-micro { font-size: 13px; color: var(--gray-400); margin-top: 12px; }

/* EBOOK MOCKUP */
.ebook-mockup-wrapper {
  display: flex; justify-content: center; align-items: center; perspective: 900px;
}
.ebook-mockup {
  width: 320px; height: 440px;
  transform: rotateY(-18deg) rotateX(4deg);
  transform-style: preserve-3d;
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
}
.ebook-mockup:hover { transform: rotateY(-8deg) rotateX(2deg); }
.ebook-cover {
  width: 100%; height: 100%;
  background: #1B1B2F;
  border-radius: 8px 16px 16px 8px;
  padding: 40px 32px;
  position: relative; overflow: hidden;
  box-shadow: -20px 20px 60px rgba(15,23,42,0.25), -5px 5px 20px rgba(15,23,42,0.15), 20px 0 40px rgba(15,23,42,0.08);
}
.ebook-cover::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
  background: #FFE600;
}
.ebook-cover .spine {
  position: absolute; left: 0; top: 0; bottom: 0; width: 8px;
  background: linear-gradient(to right, #0f0f24, #1B1B2F);
}
.ebook-roi {
  font-size: 42px; font-weight: 900; color: #FFE600;
  line-height: 1; margin-top: 60px; margin-bottom: 12px;
}
.ebook-title {
  font-size: 15px; font-weight: 600; color: #ffffff; line-height: 1.4;
  margin-bottom: 24px;
}
.ebook-tag {
  font-size: 11px; color: #9999BB; border-top: 1px solid #2A2A45;
  padding-top: 12px; position: absolute; bottom: 40px; left: 32px; right: 32px;
}

/* STATS SECTION */
.stats-section { padding: 64px 0; background: var(--gray-50); }
.stats-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 32px;
}
.stats-card {
  background: var(--white); border-radius: 16px; padding: 32px 24px;
  text-align: center; border: 1px solid var(--gray-200);
  transition: transform 0.2s, box-shadow 0.2s;
}
.stats-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
.stats-card .num {
  font-size: 36px; font-weight: 900; color: var(--black); margin-bottom: 4px;
}
.stats-card .label { font-size: 14px; color: var(--gray-600); }

/* STORES PREVIEW */
.stores-section { padding: 80px 0; }
.stores-section h2 {
  font-size: 32px; font-weight: 800; text-align: center; margin-bottom: 12px;
}
.stores-section .sub {
  text-align: center; color: var(--gray-600); font-size: 17px; margin-bottom: 48px;
}
.stores-grid {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;
}
.store-card {
  display: flex; align-items: center; gap: 20px;
  background: var(--gray-50); border-radius: 16px; padding: 24px;
  border: 1px solid var(--gray-200); transition: transform 0.2s;
}
.store-card:hover { transform: translateY(-2px); }
.store-num {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--yellow); display: flex; align-items: center;
  justify-content: center; font-weight: 800; font-size: 16px; color: var(--black);
  flex-shrink: 0;
}
.store-info { flex: 1; }
.store-info .name { font-weight: 700; font-size: 16px; margin-bottom: 2px; }
.store-info .branch { font-size: 13px; color: var(--gray-600); }
.store-stats {
  display: flex; gap: 16px; text-align: right;
}
.store-stat .val { font-weight: 800; font-size: 16px; color: var(--black); }
.store-stat .lbl { font-size: 11px; color: var(--gray-400); }

/* TAKEAWAYS */
.takeaways-section { padding: 80px 0; background: var(--black); color: var(--white); }
.takeaways-section h2 { font-size: 32px; font-weight: 800; margin-bottom: 48px; text-align: center; }
.takeaways-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
}
.takeaway-card {
  background: #1e293b; border-radius: 16px; padding: 32px;
  border-top: 3px solid var(--yellow);
}
.takeaway-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
.takeaway-card p { font-size: 14px; color: var(--gray-400); line-height: 1.6; }

/* CTA SECTION */
.cta-section {
  padding: 80px 0; text-align: center;
  background: linear-gradient(135deg, var(--yellow-bg), var(--white));
}
.cta-section h2 { font-size: 36px; font-weight: 900; margin-bottom: 16px; }
.cta-section p { font-size: 18px; color: var(--gray-600); margin-bottom: 32px; max-width: 500px; margin-left: auto; margin-right: auto; }
.cta-form {
  display: flex; gap: 12px; justify-content: center; align-items: center;
  max-width: 480px; margin: 0 auto;
}
.cta-form input {
  flex: 1; padding: 16px 20px; border: 2px solid var(--gray-200);
  border-radius: 12px; font-size: 16px; font-family: inherit;
  transition: border-color 0.2s;
}
.cta-form input:focus { outline: none; border-color: var(--yellow); }
.cta-form button { padding: 16px 32px; font-size: 16px; white-space: nowrap; }
.cta-trust {
  display: flex; justify-content: center; gap: 24px;
  margin-top: 20px; font-size: 13px; color: var(--gray-400);
}
.cta-trust span { display: flex; align-items: center; gap: 6px; }

/* FOOTER */
.footer {
  padding: 32px 0; text-align: center;
  font-size: 13px; color: var(--gray-400);
  border-top: 1px solid var(--gray-200);
}

/* RESPONSIVE */
@media (max-width: 768px) {
  .hero-grid { grid-template-columns: 1fr; gap: 40px; }
  .hero h1 { font-size: 32px; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .stores-grid { grid-template-columns: 1fr; }
  .takeaways-grid { grid-template-columns: 1fr; }
  .ebook-mockup-wrapper { order: -1; }
  .cta-form { flex-direction: column; }
  .cta-form input, .cta-form button { width: 100%; }
}
</style>

