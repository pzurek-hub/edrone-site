---
export const prerender = true;

import LandingLayout from '../../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Revenue Check | edrone — ile pieniędzy zostawia Twój sklep?"
  description="Sprawdź ile przychodu traci Twój sklep e-commerce. Darmowa analiza marketing automation na podstawie danych z 1000+ sklepów."
  lang="pl"
  ogTitle="Revenue Check | edrone — ile pieniędzy zostawia Twój sklep?"
  ogDescription="Wklej adres sklepu i sprawdź ile przychodu tracisz. Analiza oparta na danych z 1000+ sklepów e-commerce."
  ogUrl="https://roi.edrone.me/revenue-check/pl/"
  googleFont="Roboto:wght@300;400;700;900"
>

<style>
    .outline-text {
      font-family: 'Sans Pro Outline', sans-serif;
      font-weight: 700;
      color: var(--dark);
    }
    .bold-text {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
    }

    /* ── HEADER ── */
    .header {
      position: sticky;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(46, 46, 41, 0.08);
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .header-logo svg { display: block; }
    .btn-nav {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--yellow);
      color: var(--dark);
      font-weight: 700;
      font-size: 14px;
      padding: 10px 24px;
      border-radius: 100px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
      min-height: 44px;
    }
    .btn-nav:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(255, 255, 140, 0.5);
    }
    .btn-nav:focus-visible,
    .btn-cta:focus-visible,
    input:focus-visible,
    select:focus-visible,
    button:focus-visible {
      outline: 3px solid var(--dark);
      outline-offset: 2px;
    }
    .btn-nav svg { width: 14px; height: 14px; }

    /* ── CTA BUTTON (black) ── */
    .btn-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--dark);
      color: var(--white);
      font-weight: 700;
      font-size: 17px;
      padding: 16px 36px;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
      min-height: 48px;
    }
    .btn-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(46, 46, 41, 0.2);
    }
    .btn-cta .arrow { font-size: 20px; transition: transform 0.2s; }
    .btn-cta:hover .arrow { transform: translateX(3px); }

    /* ── HERO ── */
    .hero-section {
      background: var(--white);
      position: relative;
      overflow: hidden;
      min-height: 100vh;
      display: flex;
      align-items: center;
    }
    .hero-section::after {
      content: '';
      position: absolute;
      bottom: -15%;
      left: -10%;
      width: 70%;
      height: 70%;
      background: radial-gradient(ellipse at 25% 95%, #FFFF8C 0%, #FFFF8C66 30%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 24px 88px;
      display: grid;
      grid-template-columns: 1fr 480px;
      gap: 64px;
      align-items: center;
      position: relative;
      z-index: 10;
      width: 100%;
    }
    @media (max-width: 960px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 40px;
        padding: 48px 20px 56px;
      }
      .hero-section { min-height: auto; }
    }

    .hero-copy { max-width: 560px; }
    .hero-copy .outline-text {
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.1;
      display: block;
      margin-bottom: 4px;
    }
    .hero h1 {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
      font-weight: 900;
      font-size: clamp(36px, 5vw, 56px);
      line-height: 1.08;
      color: var(--dark);
      margin-bottom: 20px;
    }
    .hero-sub {
      font-size: 18px;
      color: #555550;
      line-height: 1.65;
      max-width: 480px;
      margin-bottom: 36px;
      font-weight: 300;
    }

    .hero-proof {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .hero-proof-item {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--ghost);
      padding: 12px 18px;
      border-radius: 12px;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .hero-proof-item:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);
    }
    .hero-proof-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: var(--yellow);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .hero-proof-icon svg {
      width: 18px;
      height: 18px;
      color: var(--dark);
    }
    .hero-proof-text { display: flex; flex-direction: column; }
    .hero-proof-num {
      font-size: 20px;
      font-weight: 900;
      letter-spacing: -0.5px;
      color: var(--dark);
      font-variant-numeric: tabular-nums;
      line-height: 1.2;
    }
    .hero-proof-label {
      font-size: 12px;
      color: #666;
      font-weight: 400;
      line-height: 1.3;
    }

    /* ── INPUT CARD ── */
    .input-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 36px 32px 32px;
      box-shadow: var(--shadow-xl);
      position: relative;
      border: 1px solid rgba(46, 46, 41, 0.06);
    }
    .input-card-accent {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--yellow);
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .input-card-label {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #666;
      margin-bottom: 8px;
    }
    .input-card-trust {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: #888;
      margin-bottom: 24px;
    }
    .input-card-trust svg {
      width: 14px;
      height: 14px;
      color: var(--green);
      flex-shrink: 0;
    }

    .url-form {
      display: flex;
      gap: 12px;
    }
    .url-input-wrap {
      flex: 1;
      position: relative;
    }
    .url-input-wrap .icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #999;
      pointer-events: none;
    }
    .url-input {
      width: 100%;
      padding: 16px 16px 16px 44px;
      border: 2px solid rgba(46, 46, 41, 0.12);
      border-radius: 12px;
      font-size: 16px;
      font-family: 'Roboto', sans-serif;
      background: var(--white);
      color: var(--dark);
      transition: border-color 0.2s, box-shadow 0.2s;
      min-height: 56px;
    }
    .url-input:focus {
      outline: none;
      border-color: var(--dark);
      box-shadow: 0 0 0 3px rgba(255, 255, 140, 0.3);
    }
    .url-input::placeholder {
      color: #aaa;
    }
    .url-submit {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--dark);
      color: var(--white);
      font-weight: 700;
      font-size: 16px;
      padding: 16px 28px;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
      min-height: 56px;
      white-space: nowrap;
    }
    .url-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(46, 46, 41, 0.2);
    }
    .url-submit:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }
    .url-submit .arrow { font-size: 18px; transition: transform 0.2s; }
    .url-submit:hover .arrow { transform: translateX(3px); }

    .url-hint {
      margin-top: 12px;
      font-size: 13px;
      color: #999;
    }

    @media (max-width: 600px) {
      .url-form { flex-direction: column; }
      .url-submit { justify-content: center; }
      .input-card { padding: 28px 20px 24px; }
    }

    /* ── SCANNING STATE ── */
    .scan-section {
      display: none;
      max-width: 720px;
      margin: 0 auto;
      padding: 80px 24px;
      text-align: center;
    }
    .scan-section.active { display: block; }

    .scan-url {
      font-size: 14px;
      color: #888;
      margin-bottom: 32px;
      word-break: break-all;
    }
    .scan-url strong {
      color: var(--dark);
      font-weight: 700;
    }

    .scan-progress {
      width: 100%;
      height: 6px;
      background: var(--ghost);
      border-radius: 3px;
      margin-bottom: 40px;
      overflow: hidden;
    }
    .scan-progress-fill {
      height: 100%;
      width: 0%;
      background: var(--dark);
      border-radius: 3px;
      transition: width 0.4s ease-out;
    }

    .scan-items {
      list-style: none;
      text-align: left;
      max-width: 400px;
      margin: 0 auto;
    }
    .scan-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 0;
      font-size: 15px;
      color: #999;
      transition: color 0.3s;
      border-bottom: 1px solid var(--ghost);
    }
    .scan-item:last-child { border-bottom: none; }
    .scan-item.active { color: var(--dark); font-weight: 500; }
    .scan-item.done { color: var(--green); }
    .scan-item-icon {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .scan-item-icon .spinner {
      width: 18px;
      height: 18px;
      border: 2px solid var(--ghost);
      border-top-color: var(--dark);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      display: none;
    }
    .scan-item.active .spinner { display: block; }
    .scan-item-icon .check {
      display: none;
      color: var(--green);
    }
    .scan-item.done .check { display: block; }
    .scan-item.done .spinner { display: none; }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .scan-section.active,
    .refine-section.active,
    .results-section.active {
      animation: fadeIn 0.4s ease-out;
    }

    /* ── REFINEMENT STEP ── */
    .refine-section {
      display: none;
      max-width: 720px;
      margin: 0 auto;
      padding: 40px 24px 80px;
    }
    .refine-section.active { display: block; }

    .refine-title {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
      font-size: 24px;
      font-weight: 900;
      margin-bottom: 8px;
      text-align: center;
    }
    .refine-subtitle {
      font-size: 15px;
      color: #888;
      text-align: center;
      margin-bottom: 32px;
    }

    .refine-group {
      margin-bottom: 28px;
    }
    .refine-group-label {
      font-size: 14px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 12px;
    }

    .option-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 10px;
    }
    .option-card {
      padding: 14px 16px;
      border: 2px solid rgba(46, 46, 41, 0.10);
      border-radius: 12px;
      text-align: center;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s, transform 0.15s;
      user-select: none;
      background: var(--white);
    }
    .option-card:hover {
      border-color: rgba(46, 46, 41, 0.25);
      transform: translateY(-1px);
    }
    .option-card.selected {
      border-color: var(--dark);
      background: var(--yellow);
      font-weight: 700;
    }

    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 0;
      border-bottom: 1px solid var(--ghost);
    }
    .toggle-row:last-child { border-bottom: none; }
    .toggle-label {
      font-size: 15px;
      font-weight: 400;
      color: var(--dark);
    }
    .toggle-switch {
      position: relative;
      width: 48px;
      height: 28px;
      background: #ddd;
      border-radius: 14px;
      cursor: pointer;
      transition: background 0.2s;
      flex-shrink: 0;
      border: none;
      padding: 0;
    }
    .toggle-switch.on { background: var(--dark); }
    .toggle-switch::after {
      content: '';
      position: absolute;
      top: 3px;
      left: 3px;
      width: 22px;
      height: 22px;
      background: var(--white);
      border-radius: 50%;
      transition: transform 0.2s;
    }
    .toggle-switch.on::after { transform: translateX(20px); }

    .revenue-options {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .revenue-card {
      padding: 14px 20px;
      border: 2px solid rgba(46, 46, 41, 0.10);
      border-radius: 12px;
      font-size: 15px;
      font-weight: 500;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      user-select: none;
      background: var(--white);
    }
    .revenue-card:hover { border-color: rgba(46, 46, 41, 0.25); }
    .revenue-card.selected {
      border-color: var(--dark);
      background: var(--yellow);
      font-weight: 700;
    }

    .refine-submit {
      display: block;
      width: 100%;
      margin-top: 32px;
    }

    /* ── RESULTS ── */
    .results-section {
      display: none;
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 24px 80px;
    }
    .results-section.active { display: block; }

    .results-hero {
      text-align: center;
      margin-bottom: 48px;
    }
    .results-hero-label {
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #888;
      margin-bottom: 8px;
    }
    .results-hero-number {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
      font-size: clamp(40px, 8vw, 64px);
      font-weight: 900;
      color: var(--dark);
      line-height: 1.1;
      margin-bottom: 4px;
      font-variant-numeric: tabular-nums;
    }
    .results-hero-unit {
      font-size: 18px;
      color: #888;
      font-weight: 400;
    }
    .results-hero-yearly {
      font-size: 20px;
      font-weight: 700;
      color: var(--dark);
      margin-top: 8px;
    }

    .results-score {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: 24px;
      margin-bottom: 12px;
    }
    .score-bar-wrap {
      width: 200px;
      height: 8px;
      background: var(--ghost);
      border-radius: 4px;
      overflow: hidden;
    }
    .score-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 1s ease-out;
      width: 0%;
    }
    .score-bar-fill.low { background: var(--red); }
    .score-bar-fill.mid { background: var(--amber); }
    .score-bar-fill.high { background: var(--green); }
    .score-label {
      font-size: 16px;
      font-weight: 900;
      font-variant-numeric: tabular-nums;
    }
    .results-score-text {
      font-size: 14px;
      color: #888;
      text-align: center;
    }

    .channel-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 40px;
    }
    .channel-card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 16px;
      align-items: center;
      padding: 20px 24px;
      border-radius: 14px;
      background: var(--white);
      border: 1px solid rgba(46, 46, 41, 0.08);
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .channel-card:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }
    .channel-card.status-red { border-left: 4px solid var(--red); }
    .channel-card.status-yellow { border-left: 4px solid var(--amber); }
    .channel-card.status-green { border-left: 4px solid var(--green); }

    .channel-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }
    .status-red .channel-icon { background: #fef2f2; }
    .status-yellow .channel-icon { background: #fffbeb; }
    .status-green .channel-icon { background: #f0fdf4; }

    .channel-info { min-width: 0; }
    .channel-name {
      font-weight: 700;
      font-size: 15px;
      margin-bottom: 2px;
    }
    .channel-note {
      font-size: 13px;
      color: #888;
      line-height: 1.4;
    }
    .channel-gap {
      text-align: right;
      white-space: nowrap;
    }
    .channel-gap-amount {
      font-size: 18px;
      font-weight: 900;
      font-variant-numeric: tabular-nums;
    }
    .status-red .channel-gap-amount { color: var(--red); }
    .status-yellow .channel-gap-amount { color: #b45309; }
    .status-green .channel-gap-amount { color: var(--green); }
    .channel-gap-label {
      font-size: 12px;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .channel-status-tag {
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 6px;
      margin-top: 4px;
    }
    .status-red .channel-status-tag { background: #fef2f2; color: var(--red); }
    .status-yellow .channel-status-tag { background: #fffbeb; color: #b45309; }
    .status-green .channel-status-tag { background: #f0fdf4; color: #16a34a; }

    @media (max-width: 600px) {
      .channel-card {
        grid-template-columns: auto 1fr;
        gap: 12px;
        padding: 16px;
      }
      .channel-gap {
        grid-column: 1 / -1;
        text-align: left;
        padding-top: 8px;
        border-top: 1px solid var(--ghost);
      }
    }

    /* ── RESULTS CTA ── */
    .results-cta-section {
      margin-top: 48px;
      text-align: center;
      background: var(--dark);
      border-radius: var(--radius);
      padding: 40px 32px;
      color: var(--white);
      position: relative;
      overflow: hidden;
    }
    .results-cta-section::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 4px;
      background: var(--yellow);
    }
    .results-cta-title {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
      font-size: 24px;
      font-weight: 900;
      margin-bottom: 8px;
    }
    .results-cta-sub {
      font-size: 15px;
      color: rgba(255,255,255,0.7);
      margin-bottom: 24px;
    }
    .btn-cta-yellow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--yellow);
      color: var(--dark);
      font-weight: 700;
      font-size: 17px;
      padding: 16px 36px;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
      min-height: 48px;
    }
    .btn-cta-yellow:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(255, 255, 140, 0.3);
    }
    .btn-cta-yellow .arrow { font-size: 20px; transition: transform 0.2s; }
    .btn-cta-yellow:hover .arrow { transform: translateX(3px); }
    .results-cta-trust {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: 16px;
      font-size: 13px;
      color: rgba(255,255,255,0.5);
    }

    /* ── FOOTER ── */
    .footer {
      text-align: center;
      padding: 32px 24px;
      font-size: 13px;
      color: #aaa;
    }
    .footer a { color: #888; text-decoration: none; }
    .footer a:hover { color: var(--dark); }

    /* ── EMAIL GATE (blur overlay on channel grid) ── */
    .gated-wrap {
      position: relative;
    }
    .gated-wrap.locked .channel-grid {
      filter: blur(6px);
      pointer-events: none;
      user-select: none;
    }
    .gated-wrap.locked .results-proof,
    .gated-wrap.locked .results-cta-section {
      filter: blur(6px);
      pointer-events: none;
      user-select: none;
    }
    .gate-overlay {
      position: absolute;
      top: 60px;
      left: 50%;
      transform: translateX(-50%);
      width: 100%;
      max-width: 480px;
      background: var(--white);
      border-radius: var(--radius);
      padding: 36px 32px;
      box-shadow: var(--shadow-xl);
      border: 1px solid rgba(46, 46, 41, 0.06);
      z-index: 30;
      text-align: center;
    }
    .gate-overlay.hidden { display: none; }
    .gate-title {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
      font-size: 22px;
      font-weight: 900;
      margin-bottom: 8px;
    }
    .gate-sub {
