        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </button>
      <button class="share-btn" id="btnBoss">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Wy&#347;lij szefowi
      </button>
    </div>
  </div>

  <!-- EXIT INTENT POPUP -->
  <div class="exit-overlay" id="exitOverlay">
    <div class="exit-modal">
      <button class="exit-close" id="exitClose">&times;</button>
      <p style="font-size:32px;margin-bottom:12px;">&#128172;</p>
      <p class="gate-title">Nie tra&#263; tych danych!</p>
      <p class="gate-sub">Wy&#347;lemy Twoje wyniki na maila &#8212; wr&#243;cisz do nich w dowolnym momencie.</p>
      <div class="gate-form" id="exitForm">
        <input type="email" class="gate-email" id="exitEmail" placeholder="twoj@email.pl">
        <button type="button" class="gate-submit" id="exitSubmit">Wy&#347;lij raport</button>
      </div>
      <button type="button" class="gate-skip" id="exitSkipBtn">Nie, dzi&#281;kuj&#281;</button>
    </div>
  </div>

  <!-- TOAST -->
  <div class="toast" id="toast"></div>

  <!-- FOOTER -->
  <footer class="footer">
    <a href="https://www.edrone.me/pl" target="_blank" rel="noopener">edrone.me</a> &middot; CRM i marketing automation dla e-commerce
  </footer>

  <script is:inline>
    // BENCHMARK DATA
    const BENCHMARK_DATA = {
      channels: {
        abandoned_cart: {
          label: 'Ratowanie porzuconych koszyk\u00f3w',
          icon: '\uD83D\uDED2',
          revenueMultiplier: 0.058,
          topPerformerNote: 'Najlepsi odzyskuj\u0105 30% koszyk\u00f3w (51% open rate)',
          statusTagRed: 'Nie odzyskujesz koszyk\u00f3w',
          statusTagYellow: 'Mo\u017cna poprawi\u0107 skuteczno\u015b\u0107',
          statusTagGreen: 'Dobrze! Blisko benchmarku'
        },
        welcome: {
          label: 'Seria powitalna',
          icon: '\uD83D\uDC4B',
          revenueMultiplier: 0.02,
          topPerformerNote: 'Welcome serie generuj\u0105 4x wy\u017cszy RPM ni\u017c newslettery',
          statusTagRed: 'Brak welcome sequence',
          statusTagYellow: 'Jest potencja\u0142 optymalizacji',
          statusTagGreen: 'Welcome dzia\u0142a dobrze'
        },
        popup: {
          label: 'Pop-upy i formularze',
          icon: '\uD83D\uDCCB',
          revenueMultiplier: 0.015,
          topPerformerNote: 'Top sklepy zbieraj\u0105 5% bazy miesi\u0119cznie przez pop-upy',
          statusTagRed: 'Brak pop-up\u00f3w',
          statusTagYellow: 'Pop-upy do optymalizacji',
          statusTagGreen: 'Pop-upy dzia\u0142aj\u0105'
        },
        post_purchase: {
          label: 'Maile po zakupie',
          icon: '\uD83D\uDCE6',
          revenueMultiplier: 0.03,
          topPerformerNote: 'Cross-sell po zakupie podnosi LTV o 22%',
          statusTagRed: 'Brak automatyzacji post-purchase',
          statusTagYellow: 'Mo\u017cna zwi\u0119kszy\u0107 cross-sell',
          statusTagGreen: 'Post-purchase w normie'
        },
        recommendations: {
          label: 'Rekomendacje produktowe',
          icon: '\uD83C\uDFAF',
          revenueMultiplier: 0.04,
          topPerformerNote: 'Personalizacja podnosi konwersj\u0119 \u015brednio o 15%',
          statusTagRed: 'Brak rekomendacji',
          statusTagYellow: 'Rekomendacje do poprawy',
          statusTagGreen: 'Personalizacja dzia\u0142a'
        },
        sms: {
          label: 'SMS / WhatsApp',
          icon: '\uD83D\uDCAC',
          revenueMultiplier: 0.015,
          topPerformerNote: 'SMS open rate 35% vs email 22% \u2014 60% wy\u017cszy',
          statusTagRed: 'Nie korzystasz z SMS/WhatsApp',
          statusTagYellow: 'SMS do optymalizacji',
          statusTagGreen: 'SMS kana\u0142 aktywny'
        },
        push: {
          label: 'Powiadomienia push',
          icon: '\uD83D\uDD14',
          revenueMultiplier: 0.012,
          topPerformerNote: 'Push ma najni\u017cszy koszt dotarcia ze wszystkich kana\u0142\u00f3w',
          statusTagRed: 'Brak push notifications',
          statusTagYellow: 'Push do rozwoju',
          statusTagGreen: 'Push aktywny'
        }
      },
      industries: {
        fashion:     { label: 'Moda i akcesoria',   multiplier: 1.0 },
        beauty:      { label: 'Uroda i kosmetyki',   multiplier: 1.15 },
        electronics: { label: 'Elektronika',         multiplier: 0.85 },
        home:        { label: 'Dom i ogr\u00f3d',    multiplier: 0.95 },
        food:        { label: '\u017bywno\u015b\u0107 i napoje', multiplier: 1.2 },
        sport:       { label: 'Sport i outdoor',     multiplier: 0.9 },
        health:      { label: 'Zdrowie i wellness',  multiplier: 1.1 },
        other:       { label: 'Inna bran\u017ca',    multiplier: 1.0 }
      },
      revenueBrackets: [
        { label: 'Ponizej 10 000 zl', mid: 7000 },
        { label: '10 000 - 50 000 zl', mid: 30000 },
        { label: '50 000 - 200 000 zl', mid: 125000 },
        { label: '200 000 - 1 000 000 zl', mid: 500000 },
        { label: 'Powyzej 1 000 000 zl', mid: 1500000 }
      ]
    };

    function detectPlatform(url) {
      const u = url.toLowerCase();
      if (u.includes('.myshopify.com') || u.includes('shopify')) return 'Shopify';
      if (u.includes('shoper.pl') || u.includes('.shoper.')) return 'Shoper';
      if (u.includes('woocommerce') || u.includes('/wp-content/') || u.includes('wordpress')) return 'WooCommerce';
      if (u.includes('prestashop') || u.includes('/module/')) return 'PrestaShop';
      if (u.includes('idosell')) return 'IdoSell';
      if (u.includes('magento')) return 'Magento';
      return null;
    }

    const state = { url: '', platform: null, industry: null, revenueBracket: null, activeChannels: [] };
    const fmt = n => Math.round(n).toLocaleString('pl-PL');

    const heroSection = document.getElementById('heroSection');
    const scanSection = document.getElementById('scanSection');
    const refineSection = document.getElementById('refineSection');
    const resultsSection = document.getElementById('resultsSection');
    const urlInput = document.getElementById('urlInput');
    const scanUrlDisplay = document.getElementById('scanUrlDisplay');
    const scanProgressFill = document.getElementById('scanProgressFill');
    const scanItems = document.querySelectorAll('.scan-item');
    const industryGrid = document.getElementById('industryGrid');
    const revenueGrid = document.getElementById('revenueGrid');
    const refineSubmit = document.getElementById('refineSubmit');

    function handleUrlSubmit() {
      let url = urlInput.value.trim();
      if (!url) return;
      if (!url.match(/^https?:\/\//)) url = 'https://' + url;
      state.url = url;
      state.platform = detectPlatform(url);
      if (typeof gtag === 'function') {
        gtag('event', 'revenue_check_start', { store_url: url, detected_platform: state.platform || 'unknown' });
      }
      showScan();
    }

    document.getElementById('urlSubmit').addEventListener('click', handleUrlSubmit);
    urlInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); handleUrlSubmit(); }
    });

    function showScan() {
      heroSection.classList.add('hidden');
      scanSection.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      try { scanUrlDisplay.textContent = new URL(state.url).hostname; } catch(e) { scanUrlDisplay.textContent = state.url; }
      const items = Array.from(scanItems);
      const totalDuration = 4000;
      const stepDuration = totalDuration / items.length;
      items.forEach((item, i) => {
        setTimeout(() => {
          if (i > 0) items[i - 1].classList.remove('active');
          if (i > 0) items[i - 1].classList.add('done');
          item.classList.add('active');
          scanProgressFill.style.width = ((i + 1) / items.length * 100) + '%';
        }, i * stepDuration);
      });
      setTimeout(() => {
        items[items.length - 1].classList.remove('active');
        items[items.length - 1].classList.add('done');
        scanProgressFill.style.width = '100%';
      }, totalDuration);
      setTimeout(() => { showRefine(); }, totalDuration + 600);
    }

    function showRefine() {
      scanSection.classList.remove('active');
      refineSection.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    industryGrid.addEventListener('click', function(e) {
      const card = e.target.closest('.option-card');
      if (!card) return;
      industryGrid.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      state.industry = card.dataset.value;
      checkRefineReady();
    });

    revenueGrid.addEventListener('click', function(e) {
      const card = e.target.closest('.revenue-card');
      if (!card) return;
      revenueGrid.querySelectorAll('.revenue-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      state.revenueBracket = parseInt(card.dataset.value);
      checkRefineReady();
    });

    document.querySelectorAll('.toggle-switch').forEach(toggle => {
      toggle.addEventListener('click', function() {
        this.classList.toggle('on');
        this.setAttribute('aria-checked', this.classList.contains('on'));
        const channel = this.dataset.channel;
        if (this.classList.contains('on')) {
          if (!state.activeChannels.includes(channel)) state.activeChannels.push(channel);
        } else {
          state.activeChannels = state.activeChannels.filter(c => c !== channel);
        }
      });
    });

    function checkRefineReady() {
      refineSubmit.disabled = !(state.industry && state.revenueBracket !== null);
    }

    refineSubmit.addEventListener('click', function() {
      if (this.disabled) return;
      if (typeof gtag === 'function') {
        gtag('event', 'revenue_check_refine', { industry: state.industry, revenue_bracket: state.revenueBracket, channels_active: state.activeChannels.join(','), channels_count: state.activeChannels.length });
      }
      showResults();
    });

    function calculateResults() {
      const bracket = BENCHMARK_DATA.revenueBrackets[state.revenueBracket];
      const monthlyRevenue = bracket.mid;
      const industryData = BENCHMARK_DATA.industries[state.industry];
      const industryMultiplier = industryData.multiplier;
      const channelResults = [];
      let totalLeakMonthly = 0;
      for (const [key, channel] of Object.entries(BENCHMARK_DATA.channels)) {
        const isActive = state.activeChannels.includes(key);
        const captureRate = isActive ? 0.6 : 0;
        const benchmarkRevenue = monthlyRevenue * channel.revenueMultiplier * industryMultiplier;
        const currentRevenue = benchmarkRevenue * captureRate;
        const gap = benchmarkRevenue - currentRevenue;
        let status;
        if (!isActive) status = 'red';
        else if (gap > benchmarkRevenue * 0.2) status = 'yellow';
        else status = 'green';
        let statusTag;
        if (status === 'red') statusTag = channel.statusTagRed;
        else if (status === 'yellow') statusTag = channel.statusTagYellow;
        else statusTag = channel.statusTagGreen;
        channelResults.push({ key, label: channel.label, icon: channel.icon, status, monthlyGap: Math.round(gap), benchmarkNote: channel.topPerformerNote, statusTag, isActive });
        totalLeakMonthly += gap;
      }
      channelResults.sort((a, b) => { const order = { red: 0, yellow: 1, green: 2 }; return order[a.status] - order[b.status]; });
      const totalWeight = Object.values(BENCHMARK_DATA.channels).reduce((s, c) => s + c.revenueMultiplier, 0);
      const activeWeight = state.activeChannels.reduce((s, k) => s + (BENCHMARK_DATA.channels[k]?.revenueMultiplier || 0), 0);
      const score = Math.round((activeWeight / totalWeight) * 100);
      return { channelResults, totalLeakMonthly: Math.round(totalLeakMonthly), totalLeakYearly: Math.round(totalLeakMonthly * 12), score: Math.min(score, 100), monthlyRevenue };
    }

    function showResults() {
      refineSection.classList.remove('active');
      resultsSection.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      const results = calculateResults();
      animateNumber('heroNumber', results.totalLeakMonthly);
      document.getElementById('heroYearly').textContent = fmt(results.totalLeakYearly) + ' z\u0142';
      const scoreEl = document.getElementById('scoreValue');
      const scoreBar = document.getElementById('scoreBarFill');
      const scoreText = document.getElementById('scoreText');
      scoreEl.textContent = results.score + '/100';
      scoreBar.className = 'score-bar-fill';
      if (results.score < 30) { scoreBar.classList.add('low'); scoreText.textContent = 'Du\u017cy potencja\u0142 do optymalizacji'; }
      else if (results.score < 60) { scoreBar.classList.add('mid'); scoreText.textContent = 'Dobry pocz\u0105tek, ale sporo do poprawy'; }
      else { scoreBar.classList.add('high'); scoreText.textContent = 'Nie\u017ale! Sprawd\u017a co jeszcze mo\u017cna poprawi\u0107'; }
      setTimeout(() => { scoreBar.style.width = results.score + '%'; }, 100);
      const grid = document.getElementById('channelGrid');
      grid.innerHTML = '';
      results.channelResults.forEach((ch, idx) => {
        const card = document.createElement('div');
        card.className = 'channel-card status-' + ch.status;
        card.innerHTML = '<div class="channel-icon">' + ch.icon + '</div><div class="channel-info"><p class="channel-name">' + ch.label + '</p><p class="channel-note">' + ch.benchmarkNote + '</p><span class="channel-status-tag">' + ch.statusTag + '</span></div><div class="channel-gap"><p class="channel-gap-amount">' + (ch.status === 'green' ? '' : '-') + fmt(ch.monthlyGap) + ' z\u0142</p><p class="channel-gap-label">' + (ch.status === 'green' ? 'do odzyskania' : '/ miesi\u0105c') + '</p></div>';
        grid.appendChild(card);
        if (idx === 2) {
          const inlineCta = document.createElement('a');
          inlineCta.href = 'https://control.edrone.me/register';
          inlineCta.target = '_blank';
          inlineCta.rel = 'noopener';
          inlineCta.style.cssText = 'display:flex;align-items:center;justify-content:center;gap:8px;padding:16px 24px;background:var(--yellow);border-radius:12px;text-decoration:none;color:var(--dark);font-weight:700;font-size:15px;transition:transform 0.2s;';
          inlineCta.innerHTML = 'edrone zamyka te luki automatycznie. Zacznij za darmo <span style="font-size:18px">\u2192</span>';
          inlineCta.addEventListener('mouseenter', function(){ this.style.transform='translateY(-2px)'; });
          inlineCta.addEventListener('mouseleave', function(){ this.style.transform='none'; });
          grid.appendChild(inlineCta);
        }
      });
      document.getElementById('ctaTitle').textContent = 'Odzyskaj ' + fmt(results.totalLeakMonthly) + ' z\u0142/mies. z edrone';
      if (typeof gtag === 'function') {
        gtag('event', 'revenue_check_complete', { store_url: state.url, platform: state.platform || 'unknown', industry: state.industry, revenue_bracket: state.revenueBracket, channels_active: state.activeChannels.join(','), channels_missing: Object.keys(BENCHMARK_DATA.channels).filter(k => !state.activeChannels.includes(k)).join(','), total_leak_monthly: results.totalLeakMonthly, score: results.score });
      }
    }

    let animFrame;
    function animateNumber(elId, target) {
      const el = document.getElementById(elId);
      const start = parseInt(el.textContent.replace(/\s/g, '').replace(/[^0-9]/g, '')) || 0;
      const duration = 900;
      el.textContent = fmt(Math.round(target));
      if (animFrame) cancelAnimationFrame(animFrame);
      const startTime = performance.now();
      function tick(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = fmt(Math.round(start + (target - start) * eased));
        if (progress < 1) animFrame = requestAnimationFrame(tick);
      }
      animFrame = requestAnimationFrame(tick);
    }

    (function() {
      const params = new URLSearchParams(window.location.search);
      const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
      const utmParams = new URLSearchParams();
      utmKeys.forEach(k => { if (params.get(k)) utmParams.set(k, params.get(k)); });
      if (utmParams.toString()) {
        document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(a => {
          const url = new URL(a.href);
          utmParams.forEach((v, k) => url.searchParams.set(k, v));
          a.href = url.toString();
        });
      }
    })();

    document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', { link_url: btn.href, link_text: btn.textContent.trim(), page_location: window.location.pathname });
        }
      });
    });

    let emailCaptured = false;
    function unlockResults() {
      document.getElementById('gatedWrap').classList.remove('locked');
      document.getElementById('gateOverlay').classList.add('hidden');
      emailCaptured = true;
    }
    document.getElementById('gateSubmit').addEventListener('click', function() {
      const email = document.getElementById('gateEmail').value.trim();
      if (!email || !email.includes('@')) { document.getElementById('gateEmail').style.borderColor = 'var(--red)'; return; }
      captureEmail(email, 'gate');
      unlockResults();
      showToast('Raport odblokowany! Wyniki wys\u0142ane na ' + email);
    });
    document.getElementById('gateEmail').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); document.getElementById('gateSubmit').click(); }
      this.style.borderColor = '';
    });
    document.getElementById('gateSkip').addEventListener('click', function() {
      unlockResults();
      if (typeof gtag === 'function') gtag('event', 'gate_skipped');
    });

    let exitShown = false;
    document.addEventListener('mouseleave', function(e) {
      if (e.clientY > 10) return;
      if (exitShown || emailCaptured) return;
      if (!resultsSection.classList.contains('active')) return;
      exitShown = true;
      document.getElementById('exitOverlay').classList.add('active');
      if (typeof gtag === 'function') gtag('event', 'exit_intent_shown');
    });
    document.getElementById('exitClose').addEventListener('click', function() { document.getElementById('exitOverlay').classList.remove('active'); });
    document.getElementById('exitSkipBtn').addEventListener('click', function() { document.getElementById('exitOverlay').classList.remove('active'); });
    document.getElementById('exitOverlay').addEventListener('click', function(e) { if (e.target === this) this.classList.remove('active'); });
    document.getElementById('exitSubmit').addEventListener('click', function() {
      const email = document.getElementById('exitEmail').value.trim();
      if (!email || !email.includes('@')) { document.getElementById('exitEmail').style.borderColor = 'var(--red)'; return; }
      captureEmail(email, 'exit_intent');
      document.getElementById('exitOverlay').classList.remove('active');
      unlockResults();
      showToast('Wyniki wys\u0142ane na ' + email);
    });

    function captureEmail(email, source) {
      if (typeof gtag === 'function') {
        gtag('event', 'email_captured', { email_source: source, store_url: state.url, platform: state.platform || 'unknown', industry: state.industry, revenue_bracket: state.revenueBracket, total_leak_monthly: document.getElementById('heroNumber').textContent, score: document.getElementById('scoreValue').textContent });
      }
      try { const saved = JSON.parse(localStorage.getItem('revenueCheck') || '{}'); saved.email = email; localStorage.setItem('revenueCheck', JSON.stringify(saved)); } catch(e) {}
    }

    function getShareUrl() {
      const p = new URLSearchParams();
      p.set('url', state.url || '');
      p.set('i', state.industry || '');
      p.set('r', state.revenueBracket ?? '');
      p.set('ch', state.activeChannels.join(','));
      return window.location.origin + window.location.pathname + '?' + p.toString();
    }
    function getShareText() {
      const hero = document.getElementById('heroNumber').textContent;
      const score = document.getElementById('scoreValue').textContent;
      return 'M\u00f3j sklep zostawia ~' + hero + ' z\u0142/mies. na stole (wynik: ' + score + '). Sprawd\u017a sw\u00f3j: ';
    }
    document.getElementById('btnShare').addEventListener('click', function() {
      const url = getShareUrl();
      if (navigator.clipboard) { navigator.clipboard.writeText(url).then(() => showToast('Link skopiowany do schowka!')); } else { showToast(url); }
      if (typeof gtag === 'function') gtag('event', 'results_shared', { method: 'copy_link' });
    });
    document.getElementById('btnLinkedIn').addEventListener('click', function() {
      const url = getShareUrl();
      window.open('https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(url), '_blank');
      if (typeof gtag === 'function') gtag('event', 'results_shared', { method: 'linkedin' });
    });
    document.getElementById('btnBoss').addEventListener('click', function() {
      const hero = document.getElementById('heroNumber').textContent;
      const yearly = document.getElementById('heroYearly').textContent;
      const score = document.getElementById('scoreValue').textContent;
      const shareUrl = getShareUrl();
      const subject = encodeURIComponent('Nasz sklep traci ~' + hero + ' z\u0142 miesi\u0119cznie \u2014 raport Revenue Check');
      const body = encodeURIComponent('Cze\u015b\u0107,\n\nZrobi\u0142em/am analiz\u0119 naszego marketing automation narz\u0119dziem Revenue Check od edrone.\n\nWyniki:\n\u2022 Tracimy: ~' + hero + ' z\u0142 miesi\u0119cznie (' + yearly + ' rocznie)\n\u2022 Wynik: ' + score + '\n\nPe\u0142ny raport: ' + shareUrl + '\n\nedrone mo\u017ce to naprawi\u0107 \u2014 wdro\u017cenie trwa 5 minut:\nhttps://control.edrone.me/register\n\nCo my\u015blisz?');
      window.location.href = 'mailto:?subject=' + subject + '&body=' + body;
      if (typeof gtag === 'function') gtag('event', 'send_to_boss');
    });

    function saveToLocalStorage() {
      try { localStorage.setItem('revenueCheck', JSON.stringify({ url: state.url, platform: state.platform, industry: state.industry, revenueBracket: state.revenueBracket, activeChannels: state.activeChannels, timestamp: Date.now() })); } catch(e) {}
    }
    function loadFromLocalStorage() {
      try {
        const data = JSON.parse(localStorage.getItem('revenueCheck'));
        if (!data || !data.url || !data.industry) return false;
        if (Date.now() - data.timestamp > 7 * 24 * 60 * 60 * 1000) { localStorage.removeItem('revenueCheck'); return false; }
        return data;
      } catch(e) { return false; }
    }

    const origShowResults = showResults;
    showResults = function() { origShowResults(); saveToLocalStorage(); };

    (function() {
      const params = new URLSearchParams(window.location.search);
      if (params.has('i') && params.has('r')) {
        state.url = params.get('url') || '';
        state.industry = params.get('i');
        state.revenueBracket = parseInt(params.get('r'));
        state.activeChannels = (params.get('ch') || '').split(',').filter(Boolean);
        state.platform = detectPlatform(state.url);
        heroSection.classList.add('hidden');
        showResults();
        return;
      }
      const saved = loadFromLocalStorage();
      if (saved) {
        state.url = saved.url;
        state.platform = saved.platform;
        state.industry = saved.industry;
        state.revenueBracket = saved.revenueBracket;
        state.activeChannels = saved.activeChannels || [];
        heroSection.classList.add('hidden');
        if (saved.email) emailCaptured = true;
        showResults();
        showToast('Twoja ostatnia analiza \u2014 wci\u0105\u017c aktualna');
      }
    })();

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3500);
    }
  </script>

</LandingLayout>
