    function showScan(){heroSection.classList.add('hidden');scanSection.classList.add('active');window.scrollTo({top:0,behavior:'smooth'});try{scanUrlDisplay.textContent=new URL(state.url).hostname;}catch(e){scanUrlDisplay.textContent=state.url;}const items=Array.from(scanItems);const totalDuration=4000;const stepDuration=totalDuration/items.length;items.forEach((item,i)=>{setTimeout(()=>{if(i>0)items[i-1].classList.remove('active');if(i>0)items[i-1].classList.add('done');item.classList.add('active');scanProgressFill.style.width=((i+1)/items.length*100)+'%';},i*stepDuration);});setTimeout(()=>{items[items.length-1].classList.remove('active');items[items.length-1].classList.add('done');scanProgressFill.style.width='100%';},totalDuration);setTimeout(()=>{showRefine();},totalDuration+600);}

    function showRefine(){scanSection.classList.remove('active');refineSection.classList.add('active');window.scrollTo({top:0,behavior:'smooth'});}
    industryGrid.addEventListener('click',function(e){const card=e.target.closest('.option-card');if(!card)return;industryGrid.querySelectorAll('.option-card').forEach(c=>c.classList.remove('selected'));card.classList.add('selected');state.industry=card.dataset.value;checkRefineReady();});
    revenueGrid.addEventListener('click',function(e){const card=e.target.closest('.revenue-card');if(!card)return;revenueGrid.querySelectorAll('.revenue-card').forEach(c=>c.classList.remove('selected'));card.classList.add('selected');state.revenueBracket=parseInt(card.dataset.value);checkRefineReady();});
    document.querySelectorAll('.toggle-switch').forEach(toggle=>{toggle.addEventListener('click',function(){this.classList.toggle('on');this.setAttribute('aria-checked',this.classList.contains('on'));const channel=this.dataset.channel;if(this.classList.contains('on')){if(!state.activeChannels.includes(channel))state.activeChannels.push(channel);}else{state.activeChannels=state.activeChannels.filter(c=>c!==channel);}});});
    function checkRefineReady(){refineSubmit.disabled=!(state.industry&&state.revenueBracket!==null);}
    refineSubmit.addEventListener('click',function(){if(this.disabled)return;if(typeof gtag==='function')gtag('event','revenue_check_refine',{industry:state.industry,revenue_bracket:state.revenueBracket,channels_active:state.activeChannels.join(','),channels_count:state.activeChannels.length,market:'mx'});showResults();});

    function calculateResults(){const bracket=BENCHMARK_DATA.revenueBrackets[state.revenueBracket];const monthlyRevenue=bracket.mid;const industryMultiplier=BENCHMARK_DATA.industries[state.industry].multiplier;const channelResults=[];let totalLeakMonthly=0;for(const[key,channel]of Object.entries(BENCHMARK_DATA.channels)){const isActive=state.activeChannels.includes(key);const captureRate=isActive?0.6:0;const benchmarkRevenue=monthlyRevenue*channel.revenueMultiplier*industryMultiplier;const currentRevenue=benchmarkRevenue*captureRate;const gap=benchmarkRevenue-currentRevenue;let status;if(!isActive)status='red';else if(gap>benchmarkRevenue*0.2)status='yellow';else status='green';let statusTag;if(status==='red')statusTag=channel.statusTagRed;else if(status==='yellow')statusTag=channel.statusTagYellow;else statusTag=channel.statusTagGreen;channelResults.push({key,label:channel.label,icon:channel.icon,status,monthlyGap:Math.round(gap),benchmarkNote:channel.topPerformerNote,statusTag,isActive});totalLeakMonthly+=gap;}channelResults.sort((a,b)=>{const order={red:0,yellow:1,green:2};return order[a.status]-order[b.status];});const totalWeight=Object.values(BENCHMARK_DATA.channels).reduce((s,c)=>s+c.revenueMultiplier,0);const activeWeight=state.activeChannels.reduce((s,k)=>s+(BENCHMARK_DATA.channels[k]?.revenueMultiplier||0),0);const score=Math.round((activeWeight/totalWeight)*100);return{channelResults,totalLeakMonthly:Math.round(totalLeakMonthly),totalLeakYearly:Math.round(totalLeakMonthly*12),score:Math.min(score,100),monthlyRevenue};}

    function showResults(){refineSection.classList.remove('active');resultsSection.classList.add('active');window.scrollTo({top:0,behavior:'smooth'});const results=calculateResults();animateNumber('heroNumber',results.totalLeakMonthly);document.getElementById('heroYearly').textContent=fmt(results.totalLeakYearly)+' MXN';const scoreEl=document.getElementById('scoreValue');const scoreBar=document.getElementById('scoreBarFill');const scoreText=document.getElementById('scoreText');scoreEl.textContent=results.score+'/100';scoreBar.className='score-bar-fill';if(results.score<30){scoreBar.classList.add('low');scoreText.textContent='Gran potencial de optimización';}else if(results.score<60){scoreBar.classList.add('mid');scoreText.textContent='Buen inicio, pero mucho por mejorar';}else{scoreBar.classList.add('high');scoreText.textContent='¡Bien! Revisa qué más puedes mejorar';}setTimeout(()=>{scoreBar.style.width=results.score+'%';},100);const grid=document.getElementById('channelGrid');grid.innerHTML='';results.channelResults.forEach((ch,idx)=>{const card=document.createElement('div');card.className='channel-card status-'+ch.status;card.innerHTML='<div class="channel-icon">'+ch.icon+'</div><div class="channel-info"><p class="channel-name">'+ch.label+'</p><p class="channel-note">'+ch.benchmarkNote+'</p><span class="channel-status-tag">'+ch.statusTag+'</span></div><div class="channel-gap"><p class="channel-gap-amount">'+(ch.status==='green'?'':'-')+fmt(ch.monthlyGap)+' MXN</p><p class="channel-gap-label">'+(ch.status==='green'?'por recuperar':'/ mes')+'</p></div>';grid.appendChild(card);if(idx===2){const inlineCta=document.createElement('a');inlineCta.href='https://control.edrone.me/register';inlineCta.target='_blank';inlineCta.rel='noopener';inlineCta.style.cssText='display:flex;align-items:center;justify-content:center;gap:8px;padding:16px 24px;background:var(--yellow);border-radius:12px;text-decoration:none;color:var(--dark);font-weight:700;font-size:15px;transition:transform 0.2s;';inlineCta.innerHTML='edrone cierra estas brechas automáticamente. Empieza gratis <span style="font-size:18px">\u2192</span>';inlineCta.addEventListener('mouseenter',function(){this.style.transform='translateY(-2px)';});inlineCta.addEventListener('mouseleave',function(){this.style.transform='none';});grid.appendChild(inlineCta);}});document.getElementById('ctaTitle').textContent='Recupera '+fmt(results.totalLeakMonthly)+' MXN/mes con edrone';if(typeof gtag==='function')gtag('event','revenue_check_complete',{store_url:state.url,platform:state.platform||'unknown',industry:state.industry,revenue_bracket:state.revenueBracket,channels_active:state.activeChannels.join(','),channels_missing:Object.keys(BENCHMARK_DATA.channels).filter(k=>!state.activeChannels.includes(k)).join(','),total_leak_monthly:results.totalLeakMonthly,score:results.score,market:'mx'});}

    let animFrame;function animateNumber(elId,target){const el=document.getElementById(elId);const start=parseInt(el.textContent.replace(/\s/g,'').replace(/[^0-9]/g,''))||0;const duration=900;el.textContent=fmt(Math.round(target)).replace('$','');if(animFrame)cancelAnimationFrame(animFrame);const startTime=performance.now();function tick(now){const progress=Math.min((now-startTime)/duration,1);const eased=1-Math.pow(1-progress,3);el.textContent=fmt(Math.round(start+(target-start)*eased)).replace('$','');if(progress<1)animFrame=requestAnimationFrame(tick);}animFrame=requestAnimationFrame(tick);}

    (function(){const params=new URLSearchParams(window.location.search);const utmKeys=['utm_source','utm_medium','utm_campaign','utm_term','utm_content'];const utmParams=new URLSearchParams();utmKeys.forEach(k=>{if(params.get(k))utmParams.set(k,params.get(k));});if(utmParams.toString()){document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(a=>{const url=new URL(a.href);utmParams.forEach((v,k)=>url.searchParams.set(k,v));a.href=url.toString();});}})();
    document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(btn=>{btn.addEventListener('click',()=>{if(typeof gtag==='function')gtag('event','cta_click',{link_url:btn.href,link_text:btn.textContent.trim(),page_location:window.location.pathname});});});

    let emailCaptured=false;
    function unlockResults(){document.getElementById('gatedWrap').classList.remove('locked');document.getElementById('gateOverlay').classList.add('hidden');emailCaptured=true;}
    document.getElementById('gateSubmit').addEventListener('click',function(){const email=document.getElementById('gateEmail').value.trim();if(!email||!email.includes('@')){document.getElementById('gateEmail').style.borderColor='var(--red)';return;}captureEmail(email,'gate');unlockResults();showToast('¡Reporte desbloqueado! Resultados enviados a '+email);});
    document.getElementById('gateEmail').addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();document.getElementById('gateSubmit').click();}this.style.borderColor='';});
    document.getElementById('gateSkip').addEventListener('click',function(){unlockResults();if(typeof gtag==='function')gtag('event','gate_skipped',{market:'mx'});});

    let exitShown=false;
    document.addEventListener('mouseleave',function(e){if(e.clientY>10)return;if(exitShown||emailCaptured)return;if(!resultsSection.classList.contains('active'))return;exitShown=true;document.getElementById('exitOverlay').classList.add('active');if(typeof gtag==='function')gtag('event','exit_intent_shown',{market:'mx'});});
    document.getElementById('exitClose').addEventListener('click',function(){document.getElementById('exitOverlay').classList.remove('active');});
    document.getElementById('exitSkipBtn').addEventListener('click',function(){document.getElementById('exitOverlay').classList.remove('active');});
    document.getElementById('exitOverlay').addEventListener('click',function(e){if(e.target===this)this.classList.remove('active');});
    document.getElementById('exitSubmit').addEventListener('click',function(){const email=document.getElementById('exitEmail').value.trim();if(!email||!email.includes('@')){document.getElementById('exitEmail').style.borderColor='var(--red)';return;}captureEmail(email,'exit_intent');document.getElementById('exitOverlay').classList.remove('active');unlockResults();showToast('Resultados enviados a '+email);});

    function captureEmail(email,source){if(typeof gtag==='function')gtag('event','email_captured',{email_source:source,store_url:state.url,platform:state.platform||'unknown',industry:state.industry,revenue_bracket:state.revenueBracket,total_leak_monthly:document.getElementById('heroNumber').textContent,score:document.getElementById('scoreValue').textContent,market:'mx'});try{const saved=JSON.parse(localStorage.getItem('revenueCheckMX')||'{}');saved.email=email;localStorage.setItem('revenueCheckMX',JSON.stringify(saved));}catch(e){}}

    function getShareUrl(){const p=new URLSearchParams();p.set('url',state.url||'');p.set('i',state.industry||'');p.set('r',state.revenueBracket??'');p.set('ch',state.activeChannels.join(','));return window.location.origin+window.location.pathname+'?'+p.toString();}
    function getShareText(){const hero=document.getElementById('heroNumber').textContent;const score=document.getElementById('scoreValue').textContent;return'Mi tienda deja ~$'+hero+' MXN/mes en la mesa (score: '+score+'). Revisa la tuya: ';}
    document.getElementById('btnShare').addEventListener('click',function(){const url=getShareUrl();if(navigator.clipboard){navigator.clipboard.writeText(url).then(()=>showToast('¡Link copiado al portapapeles!'));}else{showToast(url);}if(typeof gtag==='function')gtag('event','results_shared',{method:'copy_link',market:'mx'});});
    document.getElementById('btnLinkedIn').addEventListener('click',function(){const url=getShareUrl();window.open('https://www.linkedin.com/sharing/share-offsite/?url='+encodeURIComponent(url),'_blank');if(typeof gtag==='function')gtag('event','results_shared',{method:'linkedin',market:'mx'});});
    document.getElementById('btnBoss').addEventListener('click',function(){const hero=document.getElementById('heroNumber').textContent;const yearly=document.getElementById('heroYearly').textContent;const score=document.getElementById('scoreValue').textContent;const shareUrl=getShareUrl();const subject=encodeURIComponent('Nuestra tienda pierde ~$'+hero+' MXN mensuales \u2014 reporte Revenue Check');const body=encodeURIComponent('Hola,\n\nHice un análisis de nuestro marketing automation con Revenue Check de edrone.\n\nResultados:\n\u2022 Perdemos: ~$'+hero+' MXN mensuales ('+yearly+' al año)\n\u2022 Score: '+score+'\n\nReporte completo: '+shareUrl+'\n\nedrone puede solucionarlo \u2014 la implementación toma 5 minutos:\nhttps://control.edrone.me/register\n\n¿Qué opinas?');window.location.href='mailto:?subject='+subject+'&body='+body;if(typeof gtag==='function')gtag('event','send_to_boss',{market:'mx'});});

    function saveToLocalStorage(){try{localStorage.setItem('revenueCheckMX',JSON.stringify({url:state.url,platform:state.platform,industry:state.industry,revenueBracket:state.revenueBracket,activeChannels:state.activeChannels,timestamp:Date.now()}));}catch(e){}}
    function loadFromLocalStorage(){try{const data=JSON.parse(localStorage.getItem('revenueCheckMX'));if(!data||!data.url||!data.industry)return false;if(Date.now()-data.timestamp>7*24*60*60*1000){localStorage.removeItem('revenueCheckMX');return false;}return data;}catch(e){return false;}}
    const origShowResults=showResults;showResults=function(){origShowResults();saveToLocalStorage();};

    (function(){const params=new URLSearchParams(window.location.search);if(params.has('i')&&params.has('r')){state.url=params.get('url')||'';state.industry=params.get('i');state.revenueBracket=parseInt(params.get('r'));state.activeChannels=(params.get('ch')||'').split(',').filter(Boolean);state.platform=detectPlatform(state.url);heroSection.classList.add('hidden');showResults();return;}const saved=loadFromLocalStorage();if(saved){state.url=saved.url;state.platform=saved.platform;state.industry=saved.industry;state.revenueBracket=saved.revenueBracket;state.activeChannels=saved.activeChannels||[];heroSection.classList.add('hidden');if(saved.email)emailCaptured=true;showResults();showToast('Tu último análisis — aún vigente');}})();

    function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3500);}
  </script>

</LandingLayout>
