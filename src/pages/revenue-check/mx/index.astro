    function detectPlatform(url){const u=url.toLowerCase();if(u.includes('.myshopify.com')||u.includes('shopify'))return'Shopify';if(u.includes('tiendanube')||u.includes('nuvemshop'))return'Tiendanube';if(u.includes('woocommerce')||u.includes('/wp-content/')||u.includes('wordpress'))return'WooCommerce';if(u.includes('prestashop')||u.includes('/module/'))return'PrestaShop';if(u.includes('magento'))return'Magento';if(u.includes('vtex'))return'VTEX';return null;}

    const state={url:'',platform:null,industry:null,revenueBracket:null,activeChannels:[]};
    const fmt=n=>'$'+Math.round(n).toLocaleString('es-MX');
    const heroSection=document.getElementById('heroSection'),scanSection=document.getElementById('scanSection'),refineSection=document.getElementById('refineSection'),resultsSection=document.getElementById('resultsSection'),urlInput=document.getElementById('urlInput'),scanUrlDisplay=document.getElementById('scanUrlDisplay'),scanProgressFill=document.getElementById('scanProgressFill'),scanItems=document.querySelectorAll('.scan-item'),industryGrid=document.getElementById('industryGrid'),revenueGrid=document.getElementById('revenueGrid'),refineSubmit=document.getElementById('refineSubmit');

    function handleUrlSubmit(){let url=urlInput.value.trim();if(!url)return;if(!url.match(/^https?:\/\//))url='https://'+url;state.url=url;state.platform=detectPlatform(url);if(typeof gtag==='function')gtag('event','revenue_check_start',{store_url:url,detected_platform:state.platform||'unknown',market:'mx'});showScan();}
    document.getElementById('urlSubmit').addEventListener('click',handleUrlSubmit);
