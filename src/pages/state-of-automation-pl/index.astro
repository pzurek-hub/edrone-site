}

.cta-trust svg {
  width: 14px;
  height: 14px;
  opacity: 0.6;
}

/* NEXT STEPS */
.next-steps {
  padding: 64px 0;
  background: var(--ink-soft);
}

.next-steps h3 {
  text-align: center;
  font-size: 20px;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 36px;
  letter-spacing: -0.01em;
}

.steps-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  max-width: 840px;
  margin: 0 auto;
}

.step-link {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 18px 22px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 14px;
  text-decoration: none;
  transition: background 0.4s var(--spring), transform 0.4s var(--spring), border-color 0.4s var(--spring);
}

.step-link:hover {
  background: rgba(255, 255, 255, 0.08);
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.1);
}

.step-link:active {
  transform: scale(0.98);
}

.step-icon {
  width: 36px;
  height: 36px;
  background: rgba(250, 204, 21, 0.08);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-icon svg {
  width: 16px;
  height: 16px;
  color: var(--yellow);
  stroke-width: 2;
}

.step-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--white);
  line-height: 1.35;
}

.step-arrow {
  margin-left: auto;
  flex-shrink: 0;
  color: var(--gray-mid);
  transition: transform 0.4s var(--spring);
}

.step-link:hover .step-arrow {
  transform: translateX(3px);
}

.step-arrow svg {
  width: 14px;
  height: 14px;
}

/* FOOTER */
.footer {
  padding: 28px 0;
  background: var(--ink);
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.footer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.footer-copy {
  font-size: 13px;
  color: var(--gray-mid);
}

.footer-copy a {
  color: var(--gray-mid);
  text-decoration: none;
  transition: color 0.3s var(--spring);
}

.footer-copy a:hover {
  color: var(--white);
}

/* STICKY BAR */
.sticky-bar {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(120px);
  z-index: 99;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 10px 10px 24px;
  background: rgba(10, 10, 15, 0.82);
  backdrop-filter: blur(24px) saturate(1.6);
  -webkit-backdrop-filter: blur(24px) saturate(1.6);
  border-radius: var(--radius-pill);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 8px 32px rgba(10, 10, 15, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
  transition: transform 0.6s var(--spring), opacity 0.6s var(--spring);
  opacity: 0;
  white-space: nowrap;
}

.sticky-bar.visible {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

.sticky-label {
  font-size: 14px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
}

.sticky-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--yellow);
  color: var(--ink);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 13px;
  padding: 10px 14px 10px 18px;
  border-radius: var(--radius-pill);
  border: none;
  cursor: pointer;
  transition: transform 0.4s var(--spring), box-shadow 0.4s var(--spring);
}

.sticky-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(250, 204, 21, 0.3);
}

.sticky-btn:active {
  transform: scale(0.97);
}

.sticky-btn .btn-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  background: rgba(10, 10, 15, 0.08);
  border-radius: 50%;
  transition: transform 0.4s var(--spring);
}

.sticky-btn:hover .btn-icon {
  transform: translateX(2px);
}

.sticky-btn .btn-icon svg {
  width: 11px;
  height: 11px;
}

/* SCROLL ANIMATIONS */
.reveal {
  opacity: 0;
  transform: translateY(32px);
  filter: blur(4px);
  transition:
    opacity 0.8s var(--spring),
    transform 0.8s var(--spring),
    filter 0.8s var(--spring);
}

.reveal.in {
  opacity: 1;
  transform: translateY(0);
  filter: blur(0);
}

.reveal[style*="--d:1"] { transition-delay: 80ms; }
.reveal[style*="--d:2"] { transition-delay: 160ms; }
.reveal[style*="--d:3"] { transition-delay: 240ms; }
.reveal[style*="--d:4"] { transition-delay: 320ms; }
.reveal[style*="--d:5"] { transition-delay: 400ms; }
.reveal[style*="--d:6"] { transition-delay: 480ms; }
.reveal[style*="--d:7"] { transition-delay: 560ms; }
.reveal[style*="--d:8"] { transition-delay: 640ms; }

/* PREFERS REDUCED MOTION */
@media (prefers-reduced-motion: reduce) {
  .reveal { opacity: 1; transform: none; filter: none; transition: none; }
  .ebook-3d { animation: none; transition: none; }
  .stat-shell, .action-card-shell, .ch-img-shell, .step-link { transition: none; }
  .btn-primary, .nav-btn, .sticky-btn, .nav { transition: none; }
  .btn-primary .btn-icon, .action-arrow, .step-arrow { transition: none; }
  .sticky-bar { transition: none; }
}

