<script is:inline>
// Fake download
function fakeDownload(btn) {
  var orig = btn.textContent || btn.innerText;
  btn.style.opacity = '0.7';
  btn.style.pointerEvents = 'none';
  btn.innerHTML = 'Pobieranie\u2026';
  setTimeout(function() {
    btn.innerHTML = 'Gotowe \u2714';
    btn.style.opacity = '1';
  }, 1500);
  return false;
}

(function() {
  // Scroll reveal with IntersectionObserver
  var els = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px 0px 0px' });
    els.forEach(function(el) { io.observe(el); });
  } else {
    els.forEach(function(el) { el.classList.add('in'); });
  }

  // Sticky bar: show when hero exits viewport
  var hero = document.getElementById('hero');
  var bar = document.getElementById('stickyBar');
  if (hero && bar && 'IntersectionObserver' in window) {
    var sio = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        bar.classList.toggle('visible', !e.isIntersecting);
      });
    }, { threshold: 0 });
    sio.observe(hero);
  }

  // Spotlight border tracking — mouse position for stat cards
  document.querySelectorAll('.stat-shell').forEach(function(card) {
    card.addEventListener('mousemove', function(e) {
      var r = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', ((e.clientX - r.left) / r.width * 100) + '%');
      card.style.setProperty('--mouse-y', ((e.clientY - r.top) / r.height * 100) + '%');
    });
  });
})();
</script>

