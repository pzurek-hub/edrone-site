---
export const prerender = true;

import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Marketing Automation w polskim e-commerce — Raport 2026 | edrone"
  description="Ile przychodu zostawiasz na stole? Dane z 1 400+ sklepów e-commerce w Polsce — automatyzacje, ROI i przychody. Raport ekskluzywnie dla klientów edrone."
  lang="pl"
  ogTitle="Marketing Automation w polskim e-commerce — Raport 2026"
  ogDescription="Dane z 1 400+ sklepów e-commerce w Polsce. Sprawdź, które automatyzacje dają najlepszy zwrot."
  googleFont="Outfit:wght@300;400;500;600;700;800;900"
>

<style>
/* Page-specific variables */
:root {
  --yellow: #FACC15;
  --yellow-dim: #d4a90e;
  --yellow-glow: rgba(250, 204, 21, 0.12);
  --yellow-tint: #fef9e7;
  --ink: #0a0a0f;
  --ink-soft: #16161d;
  --ink-muted: #1e1e28;
  --slate: #2a2a38;
  --gray-warm: #6b6b7b;
  --gray-mid: #9898a8;
  --gray-light: #c8c8d4;
  --gray-wash: #ebebf0;
  --gray-faint: #f5f5f8;
  --surface: #fafafa;
  --white: #ffffff;
  --spring: cubic-bezier(0.16, 1, 0.3, 1);
  --spring-heavy: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
  --radius-xl: 24px;
  --radius-2xl: 32px;
  --radius-pill: 100px;
}

html {
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
  color: var(--ink);
  background: var(--white);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

/* NOISE OVERLAY */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 9999;
  pointer-events: none;
  opacity: 0.022;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 200px 200px;
}

/* FLOATING GLASS PILL NAV */
.nav {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 10px 10px 24px;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(24px) saturate(1.8);
  -webkit-backdrop-filter: blur(24px) saturate(1.8);
  border-radius: var(--radius-pill);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    0 4px 24px rgba(10, 10, 15, 0.06),
    0 1px 3px rgba(10, 10, 15, 0.04),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
  transition: box-shadow 0.5s var(--spring), background 0.5s var(--spring);
}

.nav:hover {
  box-shadow:
    0 8px 32px rgba(10, 10, 15, 0.1),
    0 2px 6px rgba(10, 10, 15, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.nav-logo svg {
  display: block;
}

.nav-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--ink);
  color: var(--white);
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.01em;
  padding: 10px 20px;
  border-radius: var(--radius-pill);
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: transform 0.4s var(--spring), box-shadow 0.4s var(--spring), background 0.4s var(--spring);
}

.nav-btn:hover {
  background: var(--ink-soft);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(10, 10, 15, 0.2);
}

.nav-btn:active {
  transform: scale(0.97);
}

.nav-btn .arrow-circle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  transition: transform 0.4s var(--spring), background 0.4s var(--spring);
}

.nav-btn:hover .arrow-circle {
  transform: translateX(2px);
  background: rgba(255, 255, 255, 0.2);
}

.nav-btn .arrow-circle svg {
  width: 12px;
  height: 12px;
}

/* HERO */
.hero {
  min-height: 100dvh;
  display: flex;
  align-items: center;
  padding: 140px 0 120px;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 800px;
  height: 800px;
  background: radial-gradient(circle, rgba(250, 204, 21, 0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-container {
  max-width: 1320px;
  margin: 0 auto;
  padding: 0 40px;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 80px;
  align-items: center;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gray-warm);
  padding: 8px 16px;
  background: var(--gray-faint);
  border: 1px solid var(--gray-wash);
  border-radius: var(--radius-pill);
  margin-bottom: 32px;
  width: fit-content;
}

.hero-eyebrow::before {
  content: '';
  width: 6px;
  height: 6px;
  background: var(--yellow);
  border-radius: 50%;
  flex-shrink: 0;
}

.hero h1 {
  font-size: clamp(42px, 5.2vw, 72px);
  font-weight: 800;
  line-height: 1.02;
  letter-spacing: -0.035em;
  color: var(--ink);
  margin-bottom: 28px;
  text-wrap: balance;
}

.hero h1 em {
  font-style: normal;
  color: var(--yellow-dim);
  position: relative;
}

.hero-desc {
  font-size: 18px;
  font-weight: 400;
  line-height: 1.7;
  color: var(--gray-warm);
  max-width: 480px;
  margin-bottom: 40px;
}

/* Hero CTA */
.hero-cta-group {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: var(--yellow);
  color: var(--ink);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 16px;
  padding: 16px 16px 16px 28px;
  border-radius: var(--radius-pill);
  border: none;
  cursor: pointer;
  text-decoration: none;
  width: fit-content;
  transition: transform 0.5s var(--spring), box-shadow 0.5s var(--spring), background 0.4s var(--spring);
  box-shadow: 0 2px 12px rgba(250, 204, 21, 0.2);
  position: relative;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(250, 204, 21, 0.35);
  background: #f5c518;
}

.btn-primary:active {
  transform: translateY(1px) scale(0.98);
  box-shadow: 0 1px 6px rgba(250, 204, 21, 0.2);
}

.btn-primary:focus-visible {
  outline: 2px solid var(--ink);
  outline-offset: 3px;
}

.btn-primary .btn-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: rgba(10, 10, 15, 0.08);
  border-radius: 50%;
  transition: transform 0.5s var(--spring), background 0.4s var(--spring);
}

.btn-primary:hover .btn-icon {
  transform: translateX(2px) scale(1.05);
  background: rgba(10, 10, 15, 0.12);
}

.btn-primary .btn-icon svg {
  width: 16px;
  height: 16px;
}

.hero-meta {
  font-size: 13px;
  font-weight: 500;
  color: var(--gray-mid);
  display: flex;
  align-items: center;
  gap: 16px;
}

.hero-meta span {
  display: flex;
  align-items: center;
  gap: 5px;
}

.hero-meta .sep {
  width: 3px;
  height: 3px;
  background: var(--gray-light);
  border-radius: 50%;
}

/* EBOOK MOCKUP */
.ebook-stage {
  display: flex;
  justify-content: center;
  align-items: center;
  perspective: 1000px;
  position: relative;
}

.ebook-stage::before {
  content: '';
  position: absolute;
  width: 300px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(250, 204, 21, 0.08) 0%, transparent 70%);
  filter: blur(40px);
  pointer-events: none;
}

.ebook-3d {
  width: 340px;
  height: 460px;
  transform: rotateY(-16deg) rotateX(3deg);
  transform-style: preserve-3d;
  transition: transform 0.7s var(--spring);
  animation: float 5s var(--ease-out-expo) infinite;
  position: relative;
}

@keyframes float {
  0%, 100% { transform: rotateY(-16deg) rotateX(3deg) translateY(0); }
  50% { transform: rotateY(-16deg) rotateX(3deg) translateY(-12px); }
}

.ebook-3d:hover {
  transform: rotateY(-6deg) rotateX(1deg);
  animation-play-state: paused;
}

.ebook-shell {
  width: 100%;
  height: 100%;
  padding: 6px;
  background: rgba(10, 10, 15, 0.03);
  border: 1px solid rgba(10, 10, 15, 0.06);
  border-radius: 12px 20px 20px 12px;
}

.ebook-core {
  width: 100%;
  height: 100%;
  background: var(--ink);
  border-radius: 8px 16px 16px 8px;
  overflow: hidden;
  position: relative;
  box-shadow:
    -24px 24px 64px rgba(10, 10, 15, 0.25),
    -8px 8px 24px rgba(10, 10, 15, 0.15),
    inset 0 1px 1px rgba(255, 255, 255, 0.06);
}

.ebook-core::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 16px;
  background: linear-gradient(90deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.05) 60%, transparent 100%);
  z-index: 5;
}

.ebook-band {
  background: var(--yellow);
  padding: 16px 28px 12px;
}

.ebook-band span {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink);
}

.ebook-content {
  padding: 28px 28px 24px;
  display: flex;
  flex-direction: column;
  height: calc(100% - 48px);
}

.ebook-h {
  font-size: 21px;
  font-weight: 800;
  color: var(--white);
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin-bottom: 10px;
}

.ebook-p {
  font-size: 12px;
  color: var(--gray-mid);
  line-height: 1.6;
  margin-bottom: auto;
}

.ebook-chart {
  position: absolute;
  bottom: 72px;
  right: 20px;
  opacity: 0.07;
}

.ebook-footer {
  margin-top: auto;
  padding-top: 14px;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.ebook-footer svg {
  opacity: 0.5;
}

/* SECTION SHARED */
.wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 40px;
}

/* NUMBERS */
.numbers {
  padding: 100px 0 120px;
  background: var(--gray-faint);
  position: relative;
}

.numbers::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gray-wash), transparent);
}

.numbers-head {
  margin-bottom: 72px;
  max-width: 540px;
}

.numbers-head .eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gray-warm);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.numbers-head .eyebrow::before {
  content: '';
  width: 20px;
  height: 1px;
  background: var(--yellow);
}

.numbers-head h2 {
  font-size: clamp(32px, 3.6vw, 48px);
  font-weight: 800;
  line-height: 1.06;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin-bottom: 16px;
  text-wrap: balance;
}

.numbers-head p {
  font-size: 17px;
  color: var(--gray-warm);
  line-height: 1.65;
}

/* Bento Grid */
.bento {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  grid-auto-rows: minmax(160px, auto);
  gap: 16px;
}

.stat-shell {
  padding: 5px;
  background: rgba(10, 10, 15, 0.015);
  border: 1px solid rgba(10, 10, 15, 0.04);
  border-radius: var(--radius-xl);
  transition: transform 0.6s var(--spring), box-shadow 0.6s var(--spring);
  position: relative;
  overflow: hidden;
}

.stat-shell:hover {
  transform: translateY(-6px);
  box-shadow: 0 24px 64px rgba(10, 10, 15, 0.08), 0 4px 16px rgba(10, 10, 15, 0.04);
}

.stat-shell::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-xl);
  opacity: 0;
  transition: opacity 0.5s var(--spring);
  background: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(250, 204, 21, 0.1), transparent 60%);
  pointer-events: none;
}

.stat-shell:hover::after {
  opacity: 1;
}

.stat-core {
  background: var(--white);
  border-radius: calc(var(--radius-xl) - 5px);
  padding: 32px 28px;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.9);
}

.stat-value {
  font-size: 36px;
  font-weight: 800;
  color: var(--ink);
  line-height: 1;
  letter-spacing: -0.03em;
  font-variant-numeric: tabular-nums;
  margin-bottom: 8px;
}

.stat-label {
  font-size: 14px;
  font-weight: 500;
  color: var(--gray-warm);
  line-height: 1.5;
}

.stat-accent {
  position: absolute;
  top: 20px;
  right: 24px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yellow-glow);
  border-radius: 10px;
}

.stat-accent svg {
  width: 16px;
  height: 16px;
  color: var(--yellow-dim);
  stroke-width: 2;
}

.bento-wide  { grid-column: span 7; }
.bento-med   { grid-column: span 5; }
.bento-third { grid-column: span 4; }

.stat-shell.featured .stat-core {
  background: var(--ink);
}

.stat-shell.featured .stat-value {
  color: var(--yellow);
  font-size: 48px;
}

.stat-shell.featured .stat-label {
  color: var(--gray-mid);
}

.stat-shell.featured .stat-accent {
  background: rgba(250, 204, 21, 0.08);
}

/* CHAPTERS */
.chapters {
  padding: 100px 0;
}

.chapters-head {
  text-align: center;
  margin-bottom: 72px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.chapters-head .eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gray-warm);
  margin-bottom: 16px;
}

.chapters-head h2 {
  font-size: clamp(32px, 3.6vw, 48px);
  font-weight: 800;
  line-height: 1.06;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin-bottom: 16px;
}

.chapters-head p {
  font-size: 17px;
  color: var(--gray-warm);
  line-height: 1.65;
}

.chapter-block {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  margin-bottom: 80px;
}

.chapter-block:last-child {
  margin-bottom: 0;
}

.chapter-block:nth-child(even) {
  direction: rtl;
}

.chapter-block:nth-child(even) > * {
  direction: ltr;
}

.ch-img-shell {
  padding: 6px;
  background: rgba(10, 10, 15, 0.02);
  border: 1px solid rgba(10, 10, 15, 0.05);
  border-radius: var(--radius-2xl);
  transition: transform 0.7s var(--spring);
}

.ch-img-shell:hover {
  transform: scale(1.015);
}

.ch-img-core {
  border-radius: calc(var(--radius-2xl) - 6px);
  overflow: hidden;
}

.ch-img-core img {
  display: block;
  width: 100%;
  transition: transform 0.7s var(--spring);
}

.ch-img-shell:hover .ch-img-core img {
  transform: scale(1.03);
}

.ch-text {
  padding: 20px 0;
}

.ch-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: var(--yellow-glow);
  border: 1px solid rgba(250, 204, 21, 0.15);
  color: var(--yellow-dim);
  font-weight: 800;
  font-size: 14px;
  border-radius: 10px;
  margin-bottom: 20px;
  font-variant-numeric: tabular-nums;
}

.ch-text h3 {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin-bottom: 14px;
}

.ch-text p {
  font-size: 16px;
  color: var(--gray-warm);
  line-height: 1.75;
  max-width: 440px;
}

/* ACTIONS */
.actions {
  padding: 100px 0;
  background: var(--gray-faint);
  position: relative;
}

.actions::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gray-wash), transparent);
}

.actions-head {
  max-width: 480px;
  margin-bottom: 64px;
}

.actions-head .eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gray-warm);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.actions-head .eyebrow::before {
  content: '';
  width: 20px;
  height: 1px;
  background: var(--yellow);
}

.actions-head h2 {
  font-size: clamp(32px, 3.6vw, 48px);
  font-weight: 800;
  line-height: 1.06;
  letter-spacing: -0.03em;
  color: var(--ink);
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.action-card-shell {
  padding: 4px;
  background: rgba(10, 10, 15, 0.012);
  border: 1px solid rgba(10, 10, 15, 0.04);
  border-radius: 20px;
  transition: transform 0.5s var(--spring), box-shadow 0.5s var(--spring);
}

.action-card-shell:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(10, 10, 15, 0.06);
}

.action-card {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 24px;
  align-items: center;
  padding: 28px 32px;
  background: var(--white);
  border-radius: 16px;
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.9);
}

.action-num {
  font-size: 48px;
  font-weight: 900;
  color: var(--gray-wash);
  line-height: 1;
  letter-spacing: -0.04em;
  font-variant-numeric: tabular-nums;
  min-width: 56px;
  text-align: center;
  transition: color 0.5s var(--spring);
}

.action-card-shell:hover .action-num {
  color: var(--yellow);
}

.action-body h3 {
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}

.action-body p {
  font-size: 14px;
  color: var(--gray-warm);
  line-height: 1.6;
  max-width: 520px;
}

.action-arrow {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gray-faint);
  border-radius: 50%;
  transition: transform 0.5s var(--spring), background 0.4s var(--spring);
}

.action-card-shell:hover .action-arrow {
  transform: translateX(4px);
  background: var(--yellow-glow);
}

.action-arrow svg {
  width: 18px;
  height: 18px;
  color: var(--gray-warm);
  transition: color 0.4s var(--spring);
}

.action-card-shell:hover .action-arrow svg {
  color: var(--yellow-dim);
}

/* CTA */
.cta {
  padding: 120px 0;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}

.cta::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(250, 204, 21, 0.04) 0%, transparent 70%);
  pointer-events: none;
}

.cta-inner {
  text-align: center;
  max-width: 580px;
  margin: 0 auto;
  position: relative;
}

.cta-inner h2 {
  font-size: clamp(36px, 4vw, 56px);
  font-weight: 800;
  line-height: 1.06;
  letter-spacing: -0.03em;
  color: var(--white);
  margin-bottom: 20px;
}

.cta-sub {
  font-size: 17px;
  color: var(--gray-mid);
  line-height: 1.65;
  margin-bottom: 40px;
}

.cta .btn-primary {
  margin: 0 auto;
