}

.cta .btn-primary:hover {
  box-shadow: 0 8px 40px rgba(250, 204, 21, 0.4);
}

.cta-trust {
  margin-top: 24px;
  font-size: 13px;
  font-weight: 500;
  color: var(--gray-mid);
