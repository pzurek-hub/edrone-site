---
export const prerender = true;

import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Calculadora ROI | edrone — ¿cuánto ingreso estás perdiendo?"
  description="Descubre cuánto ingreso adicional puedes generar con la automatización de email marketing de edrone. Calculadora basada en datos reales de más de 1,000 tiendas."
  lang="es-MX"
  ogTitle="Calculadora ROI | edrone — ¿cuánto ingreso pierde tu tienda?"
  ogDescription="Calcula en 30 segundos cuánto ingreso adicional puedes generar con email marketing. Datos de más de 1,000 tiendas."
  ogUrl="https://roi.edrone.me/mx/"
  googleFont="Inter:wght@400;500;600;700;800"
  extraGoogleFonts={["Space+Grotesk:wght@500;600;700"]}
>

<style>
    /* ── Page-specific variables (navy theme) ── */
    :root {
      --navy: #0F172A;
      --navy-light: #1E293B;
      --yellow-dark: #e6e66e;
      --yellow-hover: #f5f570;
      --yellow-bg: rgba(255,255,140,0.10);
      --yellow-text: #1E293B;
      --warm-white: #FAFAF7;
      --gray-50: #F8FAFC;
      --gray-100: #F1F5F9;
      --gray-200: #E2E8F0;
      --gray-300: #CBD5E1;
      --gray-400: #94A3B8;
      --gray-500: #64748B;
      --gray-600: #475569;
      --gray-900: #1E293B;
    }

    /* ── HEADER ── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0 32px;
      background: rgba(15,23,42,0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .hdr {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo-svg { height: 20px; width: auto; }
    .hdr-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--yellow);
      color: var(--yellow-text);
      padding: 10px 22px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
      border-radius: 100px;
      transition: all 0.2s;
    }
    .hdr-cta:hover {
      background: var(--yellow-hover);
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(255,255,140,0.35);
    }
    .hdr-cta svg { width: 14px; height: 14px; }

    /* ── HERO (dark navy) ── */
    .hero-section {
      background: var(--navy);
      position: relative;
      overflow: hidden;
    }
    .hero-section::before {
      content: '';
      position: absolute;
      top: -200px;
      right: -100px;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(255,255,140,0.08) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-section::after {
      content: '';
      position: absolute;
      bottom: -200px;
      left: -100px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(255,255,140,0.04) 0%, transparent 60%);
      pointer-events: none;
    }

    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 72px 32px 80px;
      display: grid;
      grid-template-columns: 1fr 440px;
      gap: 64px;
      align-items: center;
      position: relative;
      z-index: 1;
    }
    @media (max-width: 960px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 40px;
        padding: 48px 20px 56px;
      }
    }

    .hero-copy { max-width: 520px; }
    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 600;
      color: var(--yellow);
      margin-bottom: 24px;
      letter-spacing: 0.02em;
    }
    .hero-label svg { width: 16px; height: 16px; flex-shrink: 0; }

    .hero h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: clamp(38px, 5vw, 58px);
      line-height: 1.08;
      letter-spacing: -2px;
      color: var(--white);
      margin-bottom: 20px;
    }
    .hero h1 .highlight {
      color: var(--yellow);
    }

    .hero-sub {
      font-size: 17px;
      color: var(--gray-400);
      line-height: 1.65;
      max-width: 440px;
      margin-bottom: 36px;
    }

    .hero-proof {
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .hero-proof-item {
      display: flex;
      flex-direction: column;
    }
    .hero-proof-num {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: var(--white);
      font-variant-numeric: tabular-nums;
    }
    .hero-proof-label {
      font-size: 12px;
      color: var(--gray-400);
      font-weight: 500;
    }

    /* ── CALC CARD (white, floating) ── */
    .calc-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 36px 32px 32px;
      box-shadow: var(--shadow-xl);
      position: relative;
    }
    .calc-card-accent {
      position: absolute;
      top: 0;
      left: 32px;
      right: 32px;
      height: 3px;
      background: linear-gradient(90deg, var(--yellow-dark) 0%, var(--yellow) 100%);
      border-radius: 0 0 2px 2px;
    }

    .calc-card-label {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--gray-600);
      margin-bottom: 28px;
    }

    .field { margin-bottom: 24px; }
    .field:last-of-type { margin-bottom: 0; }
    .field label {
      display: block;
      font-size: 14px;
      font-weight: 600;
      color: var(--gray-900);
      margin-bottom: 8px;
    }
    .field select,
    .field input[type="number"] {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid var(--gray-200);
      border-radius: 12px;
      font-size: 15px;
      font-family: 'Inter', sans-serif;
      background: var(--white);
      color: var(--navy);
      transition: all 0.2s;
      appearance: none;
      -webkit-appearance: none;
    }
    .field select {
      background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%2394a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
      background-repeat: no-repeat;
      background-position: right 16px center;
      padding-right: 40px;
      cursor: pointer;
    }
    .field select:focus,
    .field input:focus {
      outline: none;
      border-color: var(--yellow-dark);
      box-shadow: 0 0 0 3px var(--yellow-bg);
    }

    .slider-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 10px;
    }
    .slider-row input[type="range"] {
      flex: 1;
      -webkit-appearance: none;
      appearance: none;
      height: 6px;
      background: var(--gray-200);
      border-radius: 3px;
      outline: none;
    }
    .slider-row input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 24px;
      height: 24px;
      background: var(--yellow);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 2px 6px rgba(255,255,140,0.4);
    }
    .slider-row input[type="range"]::-moz-range-thumb {
      width: 24px;
      height: 24px;
      background: var(--yellow);
      border: none;
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 2px 6px rgba(255,255,140,0.4);
    }
    .slider-row input[type="range"]::-moz-range-progress {
      background: var(--yellow-dark);
      height: 6px;
      border-radius: 3px;
    }
    .slider-val {
      font-size: 14px;
      font-weight: 700;
      color: var(--navy);
      min-width: 56px;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .field-hint {
      font-size: 12px;
      color: var(--gray-400);
      margin-top: 6px;
    }
    .field-error {
      font-size: 12px;
      color: #EF4444;
      margin-top: 6px;
      display: none;
    }
    .field-error.show { display: block; }

    /* ── RESULTS ── */
    .results-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
      position: relative;
      z-index: 2;
      margin-top: -40px;
      opacity: 0;
      transform: translateY(24px);
      transition: all 0.6s cubic-bezier(0.22,1,0.36,1);
      pointer-events: none;
      max-height: 0;
      overflow: hidden;
    }
    .results-wrap.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      max-height: 700px;
      margin-bottom: 48px;
    }
    @media (max-width: 960px) {
      .results-wrap { padding: 0 20px; margin-top: 0; }
    }

    .results-card {
      background: var(--navy);
      border-radius: var(--radius);
      padding: 48px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: start;
      box-shadow: var(--shadow-xl);
    }
    @media (max-width: 800px) {
      .results-card {
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 32px 24px;
      }
    }

    .result-eyebrow {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--yellow);
      margin-bottom: 12px;
    }
    .result-amount-row {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 4px;
    }
    .result-plus {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 700;
      color: var(--yellow);
      letter-spacing: -2px;
    }
    .result-number {
      font-size: clamp(36px, 6vw, 56px);
      font-weight: 800;
      letter-spacing: -2px;
      line-height: 1;
      color: var(--white);
      font-variant-numeric: tabular-nums;
    }
    .result-currency {
      font-size: clamp(18px, 2.5vw, 24px);
      font-weight: 600;
      color: var(--gray-400);
    }
    .result-period {
      font-size: 14px;
      color: var(--gray-500);
      margin-bottom: 4px;
    }
    .result-yearly {
      font-size: 16px;
      color: var(--gray-400);
      margin-bottom: 28px;
    }
    .result-yearly strong {
      color: var(--white);
      font-weight: 700;
    }

    .result-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--yellow);
      color: var(--yellow-text);
      padding: 16px 32px;
      border-radius: 100px;
      text-decoration: none;
      font-size: 15px;
      font-weight: 700;
      transition: all 0.2s;
      border: none;
      cursor: pointer;
    }
    .result-cta:hover {
      background: var(--yellow-hover);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255,255,140,0.4);
    }
    .result-cta svg { width: 16px; height: 16px; }
    .result-sub {
      display: block;
      margin-top: 14px;
      font-size: 12px;
      color: var(--gray-500);
    }

    /* Scenarios */
    .scenarios { display: flex; flex-direction: column; gap: 20px; }
    .scenarios-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--gray-500);
      margin-bottom: 4px;
    }
    .scenario-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }
    .scenario-name {
      font-size: 13px;
      font-weight: 500;
      color: var(--gray-400);
    }
    .scenario-val {
      font-size: 15px;
      font-weight: 700;
      color: var(--white);
      font-variant-numeric: tabular-nums;
    }
    .scenario-bar {
      height: 8px;
      background: rgba(255,255,255,0.06);
      border-radius: 4px;
      overflow: hidden;
    }
    .scenario-fill {
      height: 100%;
      border-radius: 4px;
      width: 0%;
      transition: width 1s cubic-bezier(0.34,1.56,0.64,1);
    }
    .scenario:nth-child(2) .scenario-fill {
      background: linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255,255,255,0.16));
    }
    .scenario:nth-child(3) .scenario-fill {
      background: linear-gradient(90deg, rgba(255,255,140,0.2), rgba(255,255,140,0.35));
    }
    .scenario:nth-child(4) .scenario-fill {
      background: linear-gradient(90deg, var(--yellow-dark), var(--yellow));
    }

    .result-context {
      grid-column: 1 / -1;
      text-align: center;
      font-size: 12px;
      color: var(--gray-500);
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    /* ── SYSTEM PREVIEW ── */
    .preview {
      padding: 72px 32px;
      max-width: 1200px;
      margin: 0 auto;
      content-visibility: auto;
      contain-intrinsic-size: 0 800px;
    }
    .preview-label {
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--gray-500);
      margin-bottom: 12px;
    }
    .preview-title {
      text-align: center;
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(24px, 3.5vw, 36px);
      font-weight: 700;
      letter-spacing: -1px;
      color: var(--navy);
      margin-bottom: 12px;
    }
    .preview-sub {
      text-align: center;
      font-size: 16px;
      color: var(--gray-500);
      max-width: 520px;
      margin: 0 auto 48px;
    }

    /* Browser mockup */
    .browser-mockup {
      background: var(--white);
      border-radius: 16px;
      box-shadow: var(--shadow-xl);
      overflow: hidden;
      border: 1px solid var(--gray-200);
      max-width: 900px;
      margin: 0 auto 48px;
    }
    .browser-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 14px 18px;
      background: var(--gray-50);
      border-bottom: 1px solid var(--gray-200);
    }
    .browser-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--gray-300);
    }
    .browser-dot:nth-child(1) { background: #FF5F57; }
    .browser-dot:nth-child(2) { background: #FEBC2E; }
    .browser-dot:nth-child(3) { background: #28C840; }
    .browser-url {
      flex: 1;
      margin-left: 12px;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 8px;
      padding: 6px 14px;
      font-size: 12px;
      color: var(--gray-400);
      font-family: 'Inter', monospace;
    }
    .browser-mockup img {
      width: 100%;
      display: block;
      height: 420px;
      object-fit: cover;
      object-position: center 18%;
    }

    /* Feature highlights grid */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    @media (max-width: 768px) {
      .features-grid { grid-template-columns: 1fr; gap: 20px; }
    }
    .feature-item {
      padding: 28px 24px;
      border-radius: 16px;
      background: var(--white);
      border: 1px solid var(--gray-200);
      transition: all 0.25s;
    }
    .feature-item:hover {
      border-color: var(--gray-300);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .feature-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
      font-size: 20px;
    }
    .feature-icon--yellow { background: var(--yellow-bg); background-color: rgba(255,255,140,0.2); }
    .feature-icon--blue { background: rgba(59,130,246,0.08); }
    .feature-icon--green { background: rgba(16,185,129,0.08); }
    .feature-item h3 {
      font-size: 15px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 6px;
    }
    .feature-item p {
      font-size: 13px;
      color: var(--gray-500);
      line-height: 1.55;
    }

    /* ── SOCIAL PROOF ── */
    .proof {
      padding: 48px 0;
      background: var(--navy);
      overflow: hidden;
      content-visibility: auto;
      contain-intrinsic-size: 0 300px;
    }

    .marquee {
      mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
      margin-bottom: 36px;
    }
    .marquee-track {
      display: flex;
      gap: 64px;
      align-items: center;
      width: max-content;
      animation: marqueeScroll 40s linear infinite;
    }
    @keyframes marqueeScroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .marquee-track img {
      height: 22px;
      width: auto;
      filter: brightness(0) invert(1);
      opacity: 0.3;
      transition: opacity 0.3s;
    }
    .marquee-track img:hover { opacity: 0.6; }

    .proof-stats {
      display: flex;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
      max-width: 800px;
      margin: 0 auto;
      padding: 0 32px;
    }
    .proof-stat { text-align: center; }
    .proof-stat-num {
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -1px;
      display: block;
      font-variant-numeric: tabular-nums;
      color: var(--white);
    }
    .proof-stat:nth-child(1) .proof-stat-num { color: var(--yellow); }
    .proof-stat:nth-child(2) .proof-stat-num { color: var(--yellow-dark); }
    .proof-stat-label {
      font-size: 12px;
      color: var(--gray-400);
      font-weight: 500;
    }

    /* ── CLOSING CTA ── */
    .closing-cta {
      padding: 72px 32px;
      text-align: center;
      background: var(--warm-white);
    }
    .closing-cta h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(24px, 3.5vw, 36px);
      font-weight: 700;
      letter-spacing: -1px;
      color: var(--navy);
      margin-bottom: 12px;
    }
    .closing-cta p {
      font-size: 16px;
      color: var(--gray-500);
      margin-bottom: 32px;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }
    .closing-cta .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--yellow);
      color: var(--yellow-text);
      padding: 18px 40px;
      border-radius: 100px;
      text-decoration: none;
      font-size: 16px;
      font-weight: 700;
      transition: all 0.2s;
    }
    .closing-cta .cta-btn:hover {
      background: var(--yellow-hover);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255,255,140,0.4);
    }
    .closing-cta .cta-btn svg { width: 16px; height: 16px; }
    .closing-cta .cta-sub {
      display: block;
      margin-top: 16px;
      font-size: 13px;
      color: var(--gray-400);
    }

    /* ── FOOTER ── */
    footer {
      padding: 24px 32px;
      text-align: center;
      font-size: 12px;
      color: var(--gray-400);
      border-top: 1px solid var(--gray-200);
      background: var(--warm-white);
    }
    footer a {
      color: var(--gray-500);
      text-decoration: none;
    }
    footer a:hover { color: var(--navy); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-copy > * { opacity: 0; animation: fadeUp 0.6s forwards; }
    .hero-copy > *:nth-child(1) { animation-delay: 0.1s; }
    .hero-copy > *:nth-child(2) { animation-delay: 0.2s; }
    .hero-copy > *:nth-child(3) { animation-delay: 0.3s; }
    .hero-copy > *:nth-child(4) { animation-delay: 0.4s; }
    .calc-card { opacity: 0; animation: fadeUp 0.7s 0.25s forwards; }

    /* ── MOBILE ── */
    @media (max-width: 600px) {
      .hero { padding: 36px 16px 40px; }
      .hero-proof { gap: 20px; }
      .calc-card { padding: 28px 20px 24px; }
      .results-card { padding: 24px 16px; }
      .preview { padding: 48px 16px; }
      .proof-stats { gap: 24px; }
    }
</style>

  <!-- HEADER -->
  <header>
    <div class="hdr">
      <a href="https://www.edrone.me" class="logo" target="_blank" rel="noopener">
        <svg class="logo-svg" viewBox="0 0 1189.5 267.3" xmlns="http://www.w3.org/2000/svg">
          <g fill="#fafafa"><rect width="320.2" height="53.3"/><rect x=".1" y="214" width="320.2" height="53.3"/><rect x=".1" y="107" width="320.2" height="53.3"/></g>
