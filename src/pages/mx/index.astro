  <script is:inline>
    // Industry benchmark data (converted to MXN, ~5x PLN rate)
    const INDUSTRY_DATA = {
      ELECTRONICS:              { revPer1000: 117109.00, revUnknown1000: 87831.75, revNewsletter1000: 11710.90 },
      SPORT_EQUIPMENT:          { revPer1000: 99959.00,  revUnknown1000: 74969.25, revNewsletter1000: 9995.90  },
      EQUIPMENT:                { revPer1000: 63762.00,  revUnknown1000: 47821.50, revNewsletter1000: 6376.20  },
      VEHICLES_AND_PARTS:       { revPer1000: 127961.00, revUnknown1000: 95970.75, revNewsletter1000: 12796.10 },
      HEALTH_AND_BEAUTY:        { revPer1000: 33068.00,  revUnknown1000: 24801.00, revNewsletter1000: 3306.80  },
      ANIMALS_AND_PET_SUPPLIES: { revPer1000: 27860.00,  revUnknown1000: 20895.00, revNewsletter1000: 2786.00  },
      FOOD_DRINK_AND_TOBACCO:   { revPer1000: 85440.00,  revUnknown1000: 64080.00, revNewsletter1000: 8544.00  },
      KIDS_AND_BABIES:          { revPer1000: 33379.00,  revUnknown1000: 25034.25, revNewsletter1000: 3337.90  },
      HOME_AND_GARDEN:          { revPer1000: 57142.00,  revUnknown1000: 42856.50, revNewsletter1000: 5714.20  },
      GAMES_AND_TOYS:           { revPer1000: 32241.00,  revUnknown1000: 24180.75, revNewsletter1000: 3224.10  },
      TRAVEL_ACCESSORIES:       { revPer1000: 43044.00,  revUnknown1000: 32283.00, revNewsletter1000: 4304.40  },
      JEWELRY:                  { revPer1000: 60634.00,  revUnknown1000: 45475.50, revNewsletter1000: 6063.40  },
      CLOTHES_AND_ACCESSORIES:  { revPer1000: 32983.00,  revUnknown1000: 24737.25, revNewsletter1000: 3298.30  },
      FURNITURE:                { revPer1000: 48092.00,  revUnknown1000: 36069.00, revNewsletter1000: 4809.20  },
      HEALTH_AND_WELLNESS:      { revPer1000: 31304.00,  revUnknown1000: 23478.00, revNewsletter1000: 3130.40  },
      OTHER:                    { revPer1000: 48092.00,  revUnknown1000: 36069.00, revNewsletter1000: 4809.20  }
    };

    const fmt = n => '$' + Math.round(n).toLocaleString('es-MX');

    const industryEl = document.getElementById('industry');
    const subscribersEl = document.getElementById('subscribers');
    const rangeEl = document.getElementById('subscribersRange');
    const sliderValEl = document.getElementById('sliderVal');
    const resultsEl = document.getElementById('results');
    const fieldError = document.getElementById('fieldError');

    rangeEl.addEventListener('input', () => {
      const v = parseInt(rangeEl.value);
      subscribersEl.value = v;
      sliderValEl.textContent = fmt(v);
      fieldError.classList.remove('show');
      calculate();
    });

    subscribersEl.addEventListener('input', () => {
      const v = parseInt(subscribersEl.value) || 0;
      if (v >= 500 && v <= 100000) rangeEl.value = v;
      sliderValEl.textContent = fmt(v || 0);
      if (v > 0 && v < 100) { fieldError.classList.add('show'); }
      else { fieldError.classList.remove('show'); }
      calculate();
    });

    industryEl.addEventListener('change', calculate);

    function calculate() {
      const industry = industryEl.value;
      const subs = parseInt(subscribersEl.value) || parseInt(rangeEl.value) || 0;

      if (!industry || subs < 100) { resultsEl.classList.remove('visible'); return; }

      const data = INDUSTRY_DATA[industry];
      if (!data) return;

      const rev1 = data.revPer1000 * (subs / 1000);
      const rev2 = rev1 + (data.revUnknown1000 * (subs * 2.5 / 1000));
      const revNL = data.revNewsletter1000 * (subs / 1000) * 2;
      const rev3 = (rev2 + revNL) * 1.15;

      animateNumber('monthlyRevenue', rev1);
      document.getElementById('yearlyRevenue').textContent = fmt(rev1 * 12) + ' MXN';

      document.getElementById('s1val').textContent = fmt(rev1) + ' MXN';
      document.getElementById('s2val').textContent = fmt(rev2) + ' MXN';
      document.getElementById('s3val').textContent = fmt(rev3) + ' MXN';

      const maxRev = rev3;
      setTimeout(() => { document.getElementById('s1bar').style.width = Math.max(8, (rev1 / maxRev) * 100) + '%'; }, 100);
      setTimeout(() => { document.getElementById('s2bar').style.width = Math.max(8, (rev2 / maxRev) * 100) + '%'; }, 250);
      setTimeout(() => { document.getElementById('s3bar').style.width = '100%'; }, 400);

      resultsEl.classList.add('visible');

      if (typeof gtag === 'function') {
        gtag('event', 'calculator_result', { industry, subscribers: subs, monthly_revenue: Math.round(rev1), currency: 'MXN' });
      }

      setTimeout(() => { resultsEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 150);
    }

    document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', { link_url: btn.href, link_text: btn.textContent.trim(), page_location: window.location.pathname });
        }
      });
    });

    let animFrame;
    function animateNumber(elId, target) {
      const el = document.getElementById(elId);
      const start = parseInt(el.textContent.replace(/\s/g, '')) || 0;
      const duration = 700;
      const startTime = performance.now();

      if (animFrame) cancelAnimationFrame(animFrame);

      function tick(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = fmt(Math.round(start + (target - start) * eased));
        if (progress < 1) animFrame = requestAnimationFrame(tick);
      }
      animFrame = requestAnimationFrame(tick);
    }

    // ── UTM params forwarding ──
    (function() {
      const params = new URLSearchParams(window.location.search);
      const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
      const utmParams = new URLSearchParams();
      utmKeys.forEach(k => { if (params.get(k)) utmParams.set(k, params.get(k)); });
      if (utmParams.toString()) {
        document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(a => {
          const url = new URL(a.href);
          utmParams.forEach((v, k) => url.searchParams.set(k, v));
          a.href = url.toString();
        });
      }
    })();

    // ── Slider filled track ──
    function updateSliderTrack() {
      const min = parseInt(rangeEl.min);
      const max = parseInt(rangeEl.max);
      const val = parseInt(rangeEl.value);
      const pct = ((val - min) / (max - min)) * 100;
      rangeEl.style.background = `linear-gradient(to right, var(--yellow-dark) 0%, var(--yellow-dark) ${pct}%, var(--gray-200) ${pct}%, var(--gray-200) 100%)`;
    }
    rangeEl.addEventListener('input', updateSliderTrack);
    updateSliderTrack();

    if (subscribersEl.value) calculate();
  </script>

