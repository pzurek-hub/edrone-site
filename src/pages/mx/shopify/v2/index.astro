---
export const prerender = true;

import LandingLayout from '../../../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="edrone para Shopify México — Automatiza tu tienda y vende más"
  description="Conecta edrone con tu tienda Shopify en un clic. Recupera carritos abandonados, activa 20+ automatizaciones y genera 7x de ROI en 3 meses. Empieza gratis."
  lang="es-MX"
  ogTitle="edrone + Shopify — Marketing Automation para e-commerce en México"
  ogDescription="Recupera carritos, automatiza emails y aumenta ventas en tu tienda Shopify. 1,000+ tiendas confían en edrone. Plan gratuito disponible."
  ogUrl="https://roi.edrone.me/mx/shopify/v2/"
  googleFont="Roboto:wght@400;700"
>

<style>
    /* ── Design System Tokens ── */
    :root {
      --yellow: #FFFF8C;
      --yellow-hover: #f5f570;
      --dark: #2E2E29;
      --ghost: #F5F3F6;
      --turquoise: #00FFE9;
      --pink: #FECACC;
      --lavender: #A583D5;
      --orange: #F2AB7F;
      --white: #FFFFFF;
      --text-light: #6B6B65;
      --text-muted: #9B9B95;
      --font-display: 'Sans Pro', 'Helvetica Neue', Arial, sans-serif;
      --font-outline: 'Sans Pro Outline', 'Helvetica Neue', Arial, sans-serif;
      --font-body: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    /* ── HEADER ── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0 32px;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(46,46,41,0.08);
    }
    .hdr {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo-svg { height: 20px; width: auto; }
    .hdr-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--dark);
      color: var(--white);
      padding: 14px 28px;
      text-decoration: none;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 700;
      border-radius: 0;
      transition: all 0.2s;
    }
    .hdr-cta:hover {
      background: #1a1a16;
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(46,46,41,0.2);
    }
    .hdr-cta svg { width: 14px; height: 14px; }

    /* ── HERO ── */
    .hero-section {
      background: var(--ghost);
      position: relative;
      overflow: hidden;
    }
    .hero-section::before {
      content: '';
      position: absolute;
      top: -100px;
      left: 10%;
      width: 700px;
      height: 700px;
      background: radial-gradient(circle, rgba(255,255,140,0.5) 0%, transparent 65%);
      pointer-events: none;
      filter: blur(40px);
    }
    .hero-section::after {
      content: '';
      position: absolute;
      bottom: -100px;
      right: 10%;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(255,255,140,0.2) 0%, transparent 65%);
      pointer-events: none;
      filter: blur(40px);
    }
    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 32px 72px;
      text-align: center;
      position: relative;
      z-index: 1;
    }
    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      color: var(--text-light);
      margin-bottom: 28px;
      letter-spacing: 2px;
      text-transform: uppercase;
    }
    .hero-label svg { width: 16px; height: 16px; flex-shrink: 0; color: var(--dark); }
    .hero h1 {
      font-size: clamp(42px, 6vw, 76px);
      line-height: 1.05;
      color: var(--dark);
      margin-bottom: 24px;
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero h1 .outline { font-family: var(--font-outline); font-weight: 700; display: block; color: var(--dark); }
    .hero h1 .solid { font-family: var(--font-display); font-weight: 700; display: block; color: var(--dark); }
    .hero-sub {
      font-size: 18px;
      color: var(--text-light);
      line-height: 1.65;
      max-width: 580px;
      margin: 0 auto 36px;
    }
    .hero-cta-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-bottom: 48px;
      flex-wrap: wrap;
    }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--dark);
      color: var(--white);
      padding: 18px 40px;
      border-radius: 0;
      text-decoration: none;
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 700;
      transition: all 0.2s;
    }
    .cta-btn:hover {
      background: #1a1a16;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(46,46,41,0.25);
    }
    .cta-btn svg { width: 16px; height: 16px; }
    .cta-sub {
      font-size: 13px;
      color: var(--text-light);
    }

    /* ── Hero Proof Stats ── */
    .hero-proof {
      display: flex;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
      margin-bottom: 56px;
    }
    .hero-proof-item { display: flex; flex-direction: column; align-items: center; }
    .hero-proof-divider {
      width: 40px;
      height: 2px;
      background: var(--dark);
      margin-bottom: 10px;
    }
    .hero-proof-num {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--dark);
      font-variant-numeric: tabular-nums;
    }
    .hero-proof-label {
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 500;
      margin-top: 4px;
    }

    /* ── Integration Visual (below hero) ── */
    .integration-strip {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
    }
    .logo-connect {
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .logo-box {
      width: 80px;
      height: 80px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 12px 32px rgba(0,0,0,0.10);
    }
    .logo-box--shopify { background: #95BF47; }
    .logo-box--edrone { background: var(--yellow); }
    .logo-box svg { width: 40px; height: 40px; }
    .connect-line {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }
    .connect-dots {
      display: flex;
      gap: 6px;
    }
    .connect-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--dark);
      opacity: 0.3;
      animation: pulse 1.5s ease-in-out infinite;
    }
    .connect-dot:nth-child(2) { animation-delay: 0.3s; opacity: 0.5; }
    .connect-dot:nth-child(3) { animation-delay: 0.6s; opacity: 0.8; }
    @keyframes pulse {
      0%, 100% { opacity: 0.3; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.2); }
    }
    .connect-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }
    .integration-features {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .integration-feature {
      background: var(--white);
      border: 1px solid rgba(46,46,41,0.1);
      border-radius: 12px;
      padding: 10px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--text-light);
      transition: all 0.25s;
    }
    .integration-feature:hover {
      border-color: rgba(46,46,41,0.2);
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .integration-feature .check {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(46,46,41,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .integration-feature .check svg {
      width: 12px;
      height: 12px;
      color: var(--dark);
    }

    /* ── HERO SCREENSHOT ── */
    .hero-screenshot {
      max-width: 900px;
      margin: 0 auto;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(46,46,41,0.12), 0 4px 16px rgba(46,46,41,0.06);
    }
    .hero-screenshot img {
      width: 100%;
      height: auto;
      display: block;
    }

    /* ── TESTIMONIALS ── */
    .testimonials {
      padding: 60px 32px;
      background: var(--dark);
    }
    .testimonials-label {
      text-align: center;
      font-size: 13px;
      color: rgba(255,255,255,0.4);
      margin-bottom: 32px;
      font-weight: 500;
    }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .testimonial-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 28px 24px;
    }
    .testimonial-stars {
      color: #FFB800;
      font-size: 16px;
      margin-bottom: 12px;
      letter-spacing: 2px;
    }
    .testimonial-quote {
      font-size: 15px;
      color: rgba(255,255,255,0.8);
      line-height: 1.65;
      margin-bottom: 16px;
      font-style: italic;
    }
    .testimonial-author {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      color: var(--white);
    }
    .testimonial-role {
      font-size: 12px;
      color: rgba(255,255,255,0.4);
    }
    .testimonial-source {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 12px;
      font-size: 11px;
      color: rgba(255,255,255,0.3);
    }
    .testimonial-source svg { width: 14px; height: 14px; }

    /* ── FEATURE SHOWCASE (2-col with screenshot) ── */
    .feature-showcase {
      padding: 100px 32px;
      background: var(--white);
    }
    .feature-showcase-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    .feature-showcase-copy {}
    .feature-showcase-copy .section-label {
      text-align: left;
      color: var(--dark);
      opacity: 0.5;
    }
    .feature-showcase-copy h2 {
      font-size: clamp(28px, 3.5vw, 40px);
      line-height: 1.1;
      margin-bottom: 20px;
    }
    .feature-showcase-copy h2 .outline { font-family: var(--font-outline); font-weight: 700; color: var(--dark); }
    .feature-showcase-copy h2 .solid { font-family: var(--font-display); font-weight: 700; color: var(--dark); }
    .feature-showcase-copy p {
      font-size: 16px;
      color: var(--dark);
      opacity: 0.7;
      line-height: 1.65;
      margin-bottom: 28px;
    }
    .feature-list {
      list-style: none;
      padding: 0;
    }
    .feature-list li {
      padding: 16px 0;
      border-top: 1px solid rgba(46,46,41,0.15);
      font-size: 15px;
      color: var(--dark);
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .feature-list li:last-child { border-bottom: 1px solid rgba(46,46,41,0.15); }
    .feature-list li svg { width: 18px; height: 18px; flex-shrink: 0; color: var(--dark); opacity: 0.4; }
    .feature-showcase-img {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 16px 48px rgba(46,46,41,0.1);
    }
    .feature-showcase-img img {
      width: 100%;
      height: auto;
      display: block;
    }

    /* ── PAIN SECTION ── */
    .pain-section {
      padding: 100px 32px;
      background: var(--white);
    }
    .section-inner {
      max-width: 1200px;
      margin: 0 auto;
    }
    .section-label {
      text-align: center;
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--text-muted);
      margin-bottom: 12px;
    }
    .section-title {
      text-align: center;
      font-size: clamp(28px, 3.5vw, 40px);
      line-height: 1.1;
      margin-bottom: 12px;
    }
    .section-title .outline { font-family: var(--font-outline); font-weight: 700; }
    .section-title .solid { font-family: var(--font-display); font-weight: 700; }
    .section-sub {
      text-align: center;
      font-size: 16px;
      color: var(--text-light);
      max-width: 560px;
      margin: 0 auto 48px;
    }

    .pain-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .pain-card {
      background: var(--white);
      border: 1px solid #E8E8E8;
      border-radius: 12px;
      padding: 32px 28px;
      transition: all 0.25s;
    }
    .pain-card:hover {
      border-color: #D0D0D0;
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .pain-icon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .pain-icon svg { width: 22px; height: 22px; }
    .pain-icon--red { background: rgba(254,202,204,0.25); }
    .pain-icon--red svg { color: #e87c7c; }
    .pain-icon--orange { background: rgba(255,255,140,0.18); }
    .pain-icon--orange svg { color: #c9c940; }
    .pain-icon--gray { background: rgba(165,131,213,0.15); }
    .pain-icon--gray svg { color: #A583D5; }
    .pain-icon--blue { background: rgba(0,255,233,0.1); }
    .pain-icon--blue svg { color: #00FFE9; }
    .pain-card h3 {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 8px;
    }
    .pain-card p {
      font-size: 14px;
      color: var(--text-light);
      line-height: 1.6;
    }

    /* ── FEATURES SECTION ── */
    .features-section {
      padding: 100px 32px;
      background: var(--yellow);
      position: relative;
      overflow: hidden;
    }
    .features-section .section-label { color: var(--dark); opacity: 0.5; }
    .features-section .section-title { color: var(--dark); }
    .features-section .section-title .outline { color: var(--dark); font-family: var(--font-outline); }
    .features-section .section-sub { color: var(--dark); opacity: 0.6; }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .feature-card {
      background: var(--white);
      border: 1px solid rgba(46,46,41,0.06);
      border-radius: 12px;
      padding: 32px 24px;
      transition: all 0.25s;
    }
    .feature-card:hover {
      box-shadow: 0 8px 24px rgba(46,46,41,0.08);
      transform: translateY(-2px);
    }
    .feature-card--wide {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: center;
    }
    .feature-icon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    .feature-icon svg { width: 24px; height: 24px; }
    .feature-icon--yellow { background: rgba(46,46,41,0.08); }
    .feature-icon--yellow svg { color: var(--dark); }
    .feature-icon--blue { background: rgba(0,255,233,0.12); }
    .feature-icon--blue svg { color: #00C4B4; }
    .feature-icon--green { background: rgba(84,183,103,0.12); }
    .feature-icon--green svg { color: #54B767; }
    .feature-icon--purple { background: rgba(165,131,213,0.12); }
    .feature-icon--purple svg { color: #A583D5; }
    .feature-icon--orange { background: rgba(254,202,204,0.2); }
    .feature-icon--orange svg { color: #d47a7a; }
    .feature-card h3 {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 8px;
    }
    .feature-card p {
      font-size: 14px;
      color: var(--text-light);
      line-height: 1.6;
    }
    .feature-metric {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 16px;
      padding: 6px 14px;
      background: rgba(46,46,41,0.06);
      border-radius: 0;
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      color: var(--dark);
    }

    /* ── STEPS SECTION ── */
    .steps-section {
      padding: 100px 32px;
      background: var(--ghost);
    }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      max-width: 1000px;
      margin: 0 auto 40px;
    }
    .step-card {
      text-align: center;
      position: relative;
    }
    .step-num {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--yellow);
      color: var(--dark);
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }
    .step-card h3 {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 8px;
    }
    .step-card p {
      font-size: 14px;
      color: var(--text-light);
      line-height: 1.6;
    }
    .step-connector {
      position: absolute;
      top: 28px;
      left: calc(50% + 40px);
      width: calc(100% - 80px);
      height: 1px;
      background: var(--dark);
      opacity: 0.15;
    }
    .step-card:last-child .step-connector { display: none; }

    .steps-reinforcement {
      text-align: center;
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 20px;
    }
    .steps-reinforcement span { color: var(--turquoise); }
    .steps-badges {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .steps-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--text-light);
      font-weight: 500;
    }
    .steps-badge svg { width: 16px; height: 16px; color: #54B767; }

    /* ── ROI SECTION ── */
    .roi-section {
      padding: 100px 32px;
      background: var(--dark);
      position: relative;
      overflow: hidden;
    }
    .roi-section::before {
      content: '';
      position: absolute;
      top: -100px;
      left: 20%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(255,255,140,0.08) 0%, transparent 65%);
      pointer-events: none;
    }
    .roi-section .section-label { color: var(--yellow); opacity: 0.7; }
    .roi-section .section-title { color: var(--white); }
    .roi-section .section-title .outline { color: var(--white); font-family: var(--font-outline); }
    .roi-section .section-sub { color: rgba(255,255,255,0.5); }
    .roi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      max-width: 1000px;
      margin: 0 auto 40px;
    }
    .roi-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 36px 28px;
      text-align: center;
      transition: all 0.25s;
    }
    .roi-card:hover {
      background: rgba(255,255,255,0.07);
      border-color: rgba(0,255,233,0.15);
    }
    .roi-divider {
      width: 48px;
      height: 2px;
      background: var(--yellow);
      margin: 0 auto 16px;
    }
    .roi-big {
      font-family: var(--font-display);
      font-size: clamp(44px, 5vw, 64px);
      font-weight: 700;
      color: var(--yellow);
      letter-spacing: -2px;
      line-height: 1;
      margin-bottom: 8px;
    }
    .roi-label {
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 8px;
    }
    .roi-desc {
      font-size: 13px;
      color: rgba(255,255,255,0.5);
      line-height: 1.55;
    }
    .roi-teaser {
      text-align: center;
    }
    .roi-teaser p {
      font-size: 16px;
      color: rgba(255,255,255,0.5);
      margin-bottom: 16px;
    }
    .roi-teaser a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--yellow);
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 15px;
      text-decoration: none;
      transition: all 0.2s;
    }
    .roi-teaser a:hover { gap: 12px; }
