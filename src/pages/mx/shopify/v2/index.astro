  <script is:inline>
    // ── FAQ Accordion ──
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.parentElement;
        const wasOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
        if (!wasOpen) item.classList.add('open');
      });
    });

    // ── Scroll Fade-Up ──
    (function() {
      const fadeEls = document.querySelectorAll('.fade-up');
      if (!('IntersectionObserver' in window)) {
        fadeEls.forEach(el => el.classList.add('visible'));
        return;
      }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05, rootMargin: '0px 0px 50px 0px' });
      fadeEls.forEach(el => observer.observe(el));
      setTimeout(() => fadeEls.forEach(el => el.classList.add('visible')), 2000);
    })();

    // ── CTA Click Tracking ──
    document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', { link_url: btn.href, link_text: btn.textContent.trim(), page_location: window.location.pathname });
        }
      });
    });

    // ── UTM Params Forwarding ──
    (function() {
      const params = new URLSearchParams(window.location.search);
      const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
      const utmParams = new URLSearchParams();
      utmKeys.forEach(k => { if (params.get(k)) utmParams.set(k, params.get(k)); });
      if (!utmParams.toString()) {
        utmParams.set('utm_source', 'roi-landing');
        utmParams.set('utm_medium', 'mx-shopify');
        utmParams.set('utm_campaign', 'mx-shopify-v2-2026');
      }
      document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(a => {
        const url = new URL(a.href);
        utmParams.forEach((v, k) => url.searchParams.set(k, v));
        a.href = url.toString();
      });
    })();

    // ── Revenue Recovery Calculator ──
    (function() {
      const CART_ABANDON_RATE = 0.70;
      const RECOVERY_RATE = 0.08;
      const REACTIVATION_RATE = 0.035;
      const AI_RECO_LIFT = 0.055;

      const INDUSTRY_MULT = {
        fashion: 0.85, beauty: 0.78, electronics: 1.4, home: 1.1,
        food: 0.95, kids: 0.82, sports: 1.15, pets: 0.75,
        jewelry: 1.35, other: 1.0
      };

      const ordersInput = document.getElementById('calc-orders');
      const ordersRange = document.getElementById('calc-orders-range');
      const aovInput = document.getElementById('calc-aov');
      const aovRange = document.getElementById('calc-aov-range');
      const industrySelect = document.getElementById('calc-industry');
      const resultsDiv = document.getElementById('calc-results');

      function fmt(n) { return '$' + Math.round(n).toLocaleString('es-MX'); }

      function calc() {
        const orders = parseInt(ordersInput.value) || parseInt(ordersRange.value) || 0;
        const aov = parseInt(aovInput.value) || parseInt(aovRange.value) || 0;
        const mult = INDUSTRY_MULT[industrySelect.value] || 1.0;

        if (orders < 10 || aov < 50) return;

        const monthlyRev = orders * aov;
        const potentialOrders = monthlyRev / aov;
        const abandonedRev = monthlyRev * CART_ABANDON_RATE / (1 - CART_ABANDON_RATE);
        const totalPotentialRev = monthlyRev + abandonedRev;

        const s1 = abandonedRev * RECOVERY_RATE * mult;
        const s2 = monthlyRev * REACTIVATION_RATE * mult;
        const s3 = monthlyRev * AI_RECO_LIFT * mult;
        const totalRecover = s1 + s2 + s3;

        document.getElementById('calc-lost').textContent = fmt(abandonedRev);
        animNum('calc-recover', totalRecover);
        document.getElementById('calc-s1').textContent = fmt(s1);
        document.getElementById('calc-s2').textContent = fmt(s2);
        document.getElementById('calc-s3').textContent = fmt(s3);
        document.getElementById('calc-yearly').textContent = fmt(totalRecover * 12) + ' MXN';

        resultsDiv.style.opacity = '1';
        resultsDiv.style.transform = 'translateY(0)';

        if (typeof gtag === 'function') {
          gtag('event', 'calculator_result', {
            calculator_type: 'shopify_recovery',
            industry: industrySelect.value,
            monthly_orders: orders,
            aov: aov,
            monthly_recovery: Math.round(totalRecover),
            currency: 'MXN'
          });
        }
      }

      let af;
      function animNum(id, target) {
        const el = document.getElementById(id);
        const start = parseInt(el.textContent.replace(/[^0-9]/g, '')) || 0;
        const dur = 600;
        const t0 = performance.now();
        if (af) cancelAnimationFrame(af);
        function tick(now) {
          const p = Math.min((now - t0) / dur, 1);
          const e = 1 - Math.pow(1 - p, 3);
          el.textContent = fmt(Math.round(start + (target - start) * e));
          if (p < 1) af = requestAnimationFrame(tick);
        }
        af = requestAnimationFrame(tick);
      }

      function syncRange(input, range) {
        const v = parseInt(input.value) || 0;
        const min = parseInt(range.min);
        const max = parseInt(range.max);
        if (v >= min && v <= max) range.value = v;
      }

      ordersRange.addEventListener('input', () => { ordersInput.value = ordersRange.value; calc(); });
      aovRange.addEventListener('input', () => { aovInput.value = aovRange.value; calc(); });
      ordersInput.addEventListener('input', () => { syncRange(ordersInput, ordersRange); calc(); });
      aovInput.addEventListener('input', () => { syncRange(aovInput, aovRange); calc(); });
      industrySelect.addEventListener('change', calc);

      ordersInput.value = 500;
      aovInput.value = 850;
      calc();
      resultsDiv.style.opacity = '1';
      resultsDiv.style.transform = 'translateY(0)';
    })();
  </script>

