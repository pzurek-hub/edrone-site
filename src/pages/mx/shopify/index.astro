---
export const prerender = true;

import LandingLayout from '../../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="edrone para Shopify México — Automatiza tu tienda y vende más"
  description="Conecta edrone con tu tienda Shopify en un clic. Recupera carritos abandonados, activa 20+ automatizaciones y genera 7x de ROI en 3 meses. Empieza gratis."
  lang="es-MX"
  ogTitle="edrone + Shopify — Marketing Automation para e-commerce en México"
  ogDescription="Recupera carritos, automatiza emails y aumenta ventas en tu tienda Shopify. 1,000+ tiendas confían en edrone. Plan gratuito disponible."
  ogUrl="https://roi.edrone.me/mx/shopify/"
  googleFont="Inter:wght@400;500;600;700;800"
  extraGoogleFonts={["Space+Grotesk:wght@500;600;700"]}
>

<style>
    /* ── Page-specific variables (navy theme) ── */
    :root {
      --navy: #0F172A;
      --navy-light: #1E293B;
      --yellow-dark: #e6e66e;
      --yellow-hover: #f5f570;
      --yellow-bg: rgba(255,255,140,0.10);
      --yellow-text: #1E293B;
      --warm-white: #FAFAF7;
      --gray-50: #F8FAFC;
      --gray-100: #F1F5F9;
      --gray-200: #E2E8F0;
      --gray-300: #CBD5E1;
      --gray-400: #94A3B8;
      --gray-500: #64748B;
      --gray-600: #475569;
      --gray-900: #1E293B;
    }

    /* ── HEADER ── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0 32px;
      background: rgba(15,23,42,0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .hdr {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo-svg { height: 20px; width: auto; }
    .hdr-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--yellow);
      color: var(--yellow-text);
      padding: 10px 22px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
      border-radius: 100px;
      transition: all 0.2s;
    }
    .hdr-cta:hover {
      background: var(--yellow-hover);
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(255,255,140,0.35);
    }
    .hdr-cta svg { width: 14px; height: 14px; }

    /* ── HERO ── */
    .hero-section {
      background: var(--navy);
      position: relative;
      overflow: hidden;
    }
    .hero-section::before {
      content: '';
      position: absolute;
      top: -200px;
      right: -100px;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(255,255,140,0.08) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-section::after {
      content: '';
      position: absolute;
      bottom: -200px;
      left: -100px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(255,255,140,0.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 72px 32px 80px;
      display: grid;
      grid-template-columns: 1fr 440px;
      gap: 64px;
      align-items: center;
      position: relative;
      z-index: 1;
    }
    .hero-copy { max-width: 540px; }
    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 600;
      color: var(--yellow);
      margin-bottom: 24px;
      letter-spacing: 0.02em;
    }
    .hero-label svg { width: 16px; height: 16px; flex-shrink: 0; }
    .hero h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: clamp(36px, 4.5vw, 54px);
      line-height: 1.08;
      letter-spacing: -2px;
      color: var(--white);
      margin-bottom: 20px;
    }
    .hero h1 .highlight { color: var(--yellow); }
    .hero-sub {
      font-size: 17px;
      color: var(--gray-400);
      line-height: 1.65;
      max-width: 460px;
      margin-bottom: 32px;
    }
    .hero-cta-row {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 36px;
      flex-wrap: wrap;
    }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--yellow);
      color: var(--yellow-text);
      padding: 18px 40px;
      border-radius: 100px;
      text-decoration: none;
      font-size: 16px;
      font-weight: 700;
      transition: all 0.2s;
    }
    .cta-btn:hover {
      background: var(--yellow-hover);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255,255,140,0.4);
    }
    .cta-btn svg { width: 16px; height: 16px; }
    .cta-sub {
      font-size: 13px;
      color: var(--gray-500);
    }
    .hero-proof {
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .hero-proof-item { display: flex; flex-direction: column; }
    .hero-proof-num {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: var(--white);
      font-variant-numeric: tabular-nums;
    }
    .hero-proof-label {
      font-size: 12px;
      color: var(--gray-400);
      font-weight: 500;
    }

    /* ── INTEGRATION VISUAL (right side of hero) ── */
    .integration-visual {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }
    .logo-connect {
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .logo-box {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-lg);
    }
    .logo-box--shopify { background: #95BF47; }
    .logo-box--edrone { background: var(--yellow); }
    .logo-box svg { width: 48px; height: 48px; }
    .connect-line {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }
    .connect-dots {
      display: flex;
      gap: 6px;
    }
    .connect-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--yellow);
      opacity: 0.3;
      animation: pulse 1.5s ease-in-out infinite;
    }
    .connect-dot:nth-child(2) { animation-delay: 0.3s; opacity: 0.5; }
    .connect-dot:nth-child(3) { animation-delay: 0.6s; opacity: 0.8; }
    @keyframes pulse {
      0%, 100% { opacity: 0.3; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.2); }
    }
    .connect-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--gray-400);
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    .integration-features {
      display: flex;
      flex-direction: column;
      gap: 12px;
      width: 100%;
      max-width: 380px;
    }
    .integration-feature {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      color: var(--gray-300);
      transition: all 0.25s;
    }
    .integration-feature:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,140,0.2);
    }
    .integration-feature .check {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(255,255,140,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .integration-feature .check svg {
      width: 12px;
      height: 12px;
      color: var(--yellow);
    }

    /* ── PAIN SECTION ── */
    .pain-section {
      padding: 80px 32px;
      background: var(--warm-white);
    }
    .section-inner {
      max-width: 1200px;
      margin: 0 auto;
    }
    .section-label {
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--gray-500);
      margin-bottom: 12px;
    }
    .section-title {
      text-align: center;
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(24px, 3.5vw, 36px);
      font-weight: 700;
      letter-spacing: -1px;
      color: var(--navy);
      margin-bottom: 12px;
    }
    .section-sub {
      text-align: center;
      font-size: 16px;
      color: var(--gray-500);
      max-width: 560px;
      margin: 0 auto 48px;
    }

    .pain-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .pain-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 16px;
      padding: 32px 28px;
      transition: all 0.25s;
    }
    .pain-card:hover {
      border-color: var(--gray-300);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .pain-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .pain-icon svg { width: 22px; height: 22px; }
    .pain-icon--red { background: rgba(254,202,204,0.2); }
    .pain-icon--red svg { color: #e87c7c; }
    .pain-icon--orange { background: rgba(255,255,140,0.15); }
    .pain-icon--orange svg { color: var(--yellow-dark); }
    .pain-icon--gray { background: rgba(165,131,213,0.12); }
    .pain-icon--gray svg { color: #A583D5; }
    .pain-icon--blue { background: rgba(0,255,233,0.08); }
    .pain-icon--blue svg { color: #00FFE9; }
    .pain-card h3 {
      font-size: 16px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 8px;
    }
    .pain-card p {
      font-size: 14px;
      color: var(--gray-500);
      line-height: 1.6;
    }

    /* ── FEATURES SECTION ── */
    .features-section {
      padding: 80px 32px;
      background: var(--navy);
      position: relative;
      overflow: hidden;
    }
    .features-section::before {
      content: '';
      position: absolute;
      top: 50%;
      left: -200px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(255,255,140,0.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .features-section .section-label { color: var(--yellow); opacity: 0.7; }
    .features-section .section-title { color: var(--white); }
    .features-section .section-sub { color: var(--gray-400); }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .feature-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 32px 24px;
      transition: all 0.25s;
    }
    .feature-card:hover {
      background: rgba(255,255,255,0.07);
      border-color: rgba(255,255,140,0.15);
      transform: translateY(-2px);
    }
    .feature-card--wide {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: center;
    }
    .feature-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    .feature-icon svg { width: 24px; height: 24px; }
    .feature-icon--yellow { background: rgba(255,255,140,0.15); }
    .feature-icon--yellow svg { color: var(--yellow); }
    .feature-icon--blue { background: rgba(0,255,233,0.08); }
    .feature-icon--blue svg { color: #00FFE9; }
    .feature-icon--green { background: rgba(84,183,103,0.12); }
    .feature-icon--green svg { color: #54B767; }
    .feature-icon--purple { background: rgba(165,131,213,0.12); }
    .feature-icon--purple svg { color: #A583D5; }
    .feature-icon--orange { background: rgba(254,202,204,0.15); }
    .feature-icon--orange svg { color: #FECACC; }
    .feature-card h3 {
      font-size: 17px;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 8px;
    }
    .feature-card p {
      font-size: 14px;
      color: var(--gray-400);
      line-height: 1.6;
    }
    .feature-metric {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 16px;
      padding: 6px 14px;
      background: rgba(255,255,140,0.1);
      border-radius: 100px;
      font-size: 13px;
      font-weight: 700;
      color: var(--yellow);
    }

    /* ── STEPS SECTION ── */
    .steps-section {
      padding: 80px 32px;
      background: var(--warm-white);
    }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      max-width: 1000px;
      margin: 0 auto 40px;
    }
    .step-card {
      text-align: center;
      position: relative;
    }
    .step-num {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--yellow);
      color: var(--yellow-text);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 24px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }
    .step-card h3 {
      font-size: 17px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 8px;
    }
    .step-card p {
      font-size: 14px;
      color: var(--gray-500);
      line-height: 1.6;
    }
    .step-connector {
      position: absolute;
      top: 28px;
      left: calc(50% + 40px);
      width: calc(100% - 80px);
      height: 2px;
      background: repeating-linear-gradient(90deg, var(--gray-300) 0px, var(--gray-300) 6px, transparent 6px, transparent 12px);
    }
    .step-card:last-child .step-connector { display: none; }

    .steps-reinforcement {
      text-align: center;
      font-size: 18px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 20px;
    }
    .steps-reinforcement span { color: var(--yellow-dark); }
    .steps-badges {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .steps-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--gray-500);
      font-weight: 500;
    }
    .steps-badge svg { width: 16px; height: 16px; color: #10b981; }

    /* ── ROI SECTION ── */
    .roi-section {
      padding: 80px 32px;
      background: var(--navy);
    }
    .roi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      max-width: 1000px;
      margin: 0 auto 40px;
    }
    .roi-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 36px 28px;
      text-align: center;
      transition: all 0.25s;
    }
    .roi-card:hover {
      background: rgba(255,255,255,0.07);
      border-color: rgba(255,255,140,0.15);
    }
    .roi-big {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(40px, 5vw, 56px);
      font-weight: 700;
      color: var(--yellow);
      letter-spacing: -2px;
      line-height: 1;
      margin-bottom: 8px;
    }
    .roi-label {
      font-size: 14px;
      font-weight: 600;
      color: var(--white);
      margin-bottom: 8px;
    }
    .roi-desc {
      font-size: 13px;
      color: var(--gray-400);
      line-height: 1.55;
    }
    .roi-teaser {
      text-align: center;
    }
    .roi-teaser p {
      font-size: 16px;
      color: var(--gray-400);
      margin-bottom: 16px;
    }
    .roi-teaser a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--yellow);
      font-weight: 700;
      font-size: 15px;
      text-decoration: none;
      transition: all 0.2s;
    }
    .roi-teaser a:hover { gap: 12px; }
    .roi-teaser a svg { width: 16px; height: 16px; }

    /* ── WHY SECTION ── */
    .why-section {
      padding: 80px 32px;
      background: var(--warm-white);
    }
    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      max-width: 1000px;
      margin: 0 auto 32px;
    }
    .why-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 16px;
      padding: 28px 24px;
      transition: all 0.25s;
    }
    .why-card:hover {
      border-color: var(--gray-300);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .why-card h3 {
      font-size: 16px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 8px;
    }
    .why-card p {
      font-size: 14px;
      color: var(--gray-500);
      line-height: 1.6;
    }
    .free-plan-callout {
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
      padding: 24px;
      background: var(--yellow-bg);
      border: 1px solid rgba(255,255,140,0.2);
      border-radius: 12px;
      font-size: 14px;
      color: var(--gray-600);
    }
    .free-plan-callout strong { color: var(--navy); }

    /* ── SOCIAL PROOF ── */
    .proof {
      padding: 56px 0;
      background: var(--navy);
      overflow: hidden;
    }
    .proof-stats {
      display: flex;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
      max-width: 900px;
      margin: 0 auto 40px;
      padding: 0 32px;
    }
    .proof-stat { text-align: center; }
    .proof-stat-num {
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -1px;
      display: block;
      font-variant-numeric: tabular-nums;
      color: var(--white);
    }
    .proof-stat:nth-child(1) .proof-stat-num { color: var(--yellow); }
    .proof-stat:nth-child(2) .proof-stat-num { color: var(--yellow-dark); }
    .proof-stat-label {
      font-size: 12px;
      color: var(--gray-400);
      font-weight: 500;
    }
    .g2-badges {
      display: flex;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
      padding: 0 32px;
    }
    .g2-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 100px;
      padding: 8px 16px;
      font-size: 12px;
      font-weight: 600;
      color: var(--gray-300);
    }
    .g2-badge svg { width: 14px; height: 14px; color: #FF492C; }

    /* ── CTA SECTION ── */
    .closing-cta {
      padding: 80px 32px;
      text-align: center;
      background: var(--warm-white);
      position: relative;
    }
    .closing-cta::before {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 300px;
      background: radial-gradient(ellipse, rgba(255,255,140,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .closing-cta h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(24px, 3.5vw, 40px);
      font-weight: 700;
      letter-spacing: -1px;
      color: var(--navy);
      margin-bottom: 12px;
      position: relative;
    }
    .closing-cta > p {
      font-size: 16px;
      color: var(--gray-500);
      margin-bottom: 32px;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
      position: relative;
    }
    .closing-cta .cta-btn { position: relative; }
    .closing-cta .cta-sub-line {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 20px;
      flex-wrap: wrap;
      font-size: 13px;
      color: var(--gray-400);
      position: relative;
    }

    /* ── FAQ SECTION ── */
    .faq-section {
      padding: 64px 32px 80px;
      background: var(--white);
      border-top: 1px solid var(--gray-200);
    }
    .faq-list {
      max-width: 720px;
      margin: 0 auto;
    }
    .faq-item {
      border-bottom: 1px solid var(--gray-200);
    }
    .faq-q {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 20px 0;
      background: none;
      border: none;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 600;
      color: var(--navy);
      text-align: left;
      gap: 16px;
    }
    .faq-q:hover { color: var(--gray-600); }
    .faq-q svg {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      transition: transform 0.3s;
      color: var(--gray-400);
    }
    .faq-item.open .faq-q svg { transform: rotate(45deg); }
    .faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease, padding 0.35s ease;
    }
