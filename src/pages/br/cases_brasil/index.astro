---
export const prerender = true;

import LandingLayout from '../../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Cases de Sucesso | edrone — resultados reais de lojas brasileiras"
  description="Descubra como lojas brasileiras geram receita extra com edrone. Cases reais com ROI de ate 51x no WhatsApp, R$ 338K+ em 90 dias e muito mais."
  lang="pt-BR"
  googleFont="Inter:wght@400;500;600;700;800"
  extraGoogleFonts={["Roboto:wght@300;400;500"]}
>

<style is:global>
    body {
      font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--tuatara);
      background: var(--white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    h1, h2, h3, h4, .stat-number, .filter-btn, .cta-btn {
      font-family: 'Inter', 'Helvetica Neue', Helvetica, sans-serif;
    }

    :root {
      --tuatara: #2D2D29;
      --gray-600: #6b7280;
      --gray-400: #9ca3af;
      --gray-200: #e5e7eb;
      --gray-100: #f3f4f6;
      --gray-50: #f9fafb;
      --pink: #FFD1DC;
      --turquoise: #40E0D0;
      --lavender: #E6E6FA;
      --emerald: #50C878;
      --radius: 16px;
      --radius-sm: 8px;
      --radius-pill: 100px;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.05);
      --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.08), 0 8px 10px -6px rgba(0,0,0,0.04);
      --max-w: 1120px;
    }

    /* ── HEADER ── */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--gray-200);
      padding: 0 24px;
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo-svg { height: 22px; width: auto; }
    .header-cta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--tuatara);
      color: var(--white);
      padding: 10px 20px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      border-radius: var(--radius-pill);
      transition: all 0.2s;
    }
    .header-cta:hover { opacity: 0.85; transform: translateY(-1px); }
    .header-cta svg { width: 14px; height: 14px; }

    /* ── HERO ── */
    .hero {
      background: var(--yellow);
      padding: 72px 24px 64px;
      text-align: center;
    }
    .hero-inner {
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .hero h1 {
      font-size: clamp(32px, 5vw, 52px);
      font-weight: 800;
      line-height: 1.1;
      color: var(--tuatara);
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    .hero-sub {
      font-size: 18px;
      color: var(--tuatara);
      opacity: 0.75;
      max-width: 560px;
      margin: 0 auto 48px;
      font-weight: 300;
    }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      max-width: 800px;
      margin: 0 auto;
    }
    .hero-stat {
      background: var(--tuatara);
      border-radius: var(--radius);
      padding: 24px 16px;
      text-align: center;
    }
    .hero-stat-number {
      display: block;
      font-size: 32px;
      font-weight: 800;
      color: var(--yellow);
      line-height: 1.1;
      margin-bottom: 4px;
    }
    .hero-stat-label {
      display: block;
      font-size: 13px;
      color: rgba(255,255,255,0.7);
      font-weight: 400;
    }

    /* ── FILTERS ── */
    .filters {
      padding: 40px 24px 0;
      text-align: center;
    }
    .filters-inner {
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .filter-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
    }
    .filter-btn {
      padding: 10px 20px;
      border-radius: var(--radius-pill);
      border: 2px solid var(--tuatara);
      background: transparent;
      color: var(--tuatara);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .filter-btn:hover {
      background: var(--tuatara);
      color: var(--white);
    }
    .filter-btn.active {
      background: var(--tuatara);
      color: var(--white);
    }

    /* ── FILTER ROWS ── */
    .filter-row {
      display: flex;
      align-items: center;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .filter-row + .filter-row {
      margin-top: 12px;
    }
    .filter-label {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--gray-400);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      flex-shrink: 0;
    }
    .filter-bar-seg {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      justify-content: center;
    }
    .seg-btn {
      padding: 7px 14px;
      border-radius: var(--radius-pill);
      border: 1.5px solid var(--gray-200);
      background: transparent;
      color: var(--gray-600);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }
    .seg-btn:hover {
      border-color: var(--tuatara);
      color: var(--tuatara);
    }
    .seg-btn.active {
      background: var(--tuatara);
      color: var(--white);
      border-color: var(--tuatara);
    }
    .filter-divider {
      width: 100%;
      height: 1px;
      background: var(--gray-200);
      margin: 8px 0 4px;
    }
    .active-filters {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 12px;
      min-height: 28px;
    }
    .active-filter-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 12px;
      border-radius: var(--radius-pill);
      background: var(--yellow);
      color: var(--tuatara);
      font-size: 12px;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
    }
    .clear-filters {
      padding: 4px 12px;
      border-radius: var(--radius-pill);
      border: none;
      background: transparent;
      color: var(--gray-400);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: color 0.2s;
    }
    .clear-filters:hover { color: var(--tuatara); }
    .results-count {
      text-align: center;
      font-size: 13px;
      color: var(--gray-400);
      margin-top: 12px;
      font-family: 'Inter', sans-serif;
    }

    /* ── CASES GRID ── */
    .cases {
      padding: 40px 24px 72px;
    }
    .cases-inner {
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .cases-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .case-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      padding: 28px 24px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .case-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-xl);
      border-color: transparent;
    }
    .case-card.hidden,
    .testimonial-break.hidden {
      display: none;
    }

    /* Badge */
    .case-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: var(--radius-pill);
      font-size: 12px;
      font-weight: 600;
      width: fit-content;
      color: var(--tuatara);
    }
    .case-badge[data-ch="whatsapp"] { background: var(--emerald); color: var(--white); }
    .case-badge[data-ch="email"] { background: var(--turquoise); color: var(--tuatara); }
    .case-badge[data-ch="sms"] { background: var(--lavender); color: var(--tuatara); }
    .case-badge[data-ch="multicanal"] { background: var(--tuatara); color: var(--yellow); }
    .case-badge[data-ch="popup"] { background: var(--pink); color: var(--tuatara); }
    .case-badge svg { width: 14px; height: 14px; flex-shrink: 0; }

    /* Card content */
    .case-header { display: flex; align-items: center; gap: 12px; }
    .case-logo {
      width: 48px; height: 48px; border-radius: 12px; flex-shrink: 0;
      overflow: hidden; background: var(--gray-100);
      display: flex; align-items: center; justify-content: center;
    }
    .case-logo img { width: 100%; height: 100%; object-fit: contain; padding: 6px; }
    .case-logo-initial {
      font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 800;
      color: var(--tuatara); line-height: 1;
    }
    .case-header-text { display: flex; flex-direction: column; gap: 1px; }
    .case-name { font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 700; color: var(--tuatara); }
    .case-segment { font-size: 13px; color: var(--gray-600); }
    .case-stat {
      font-family: 'Inter', sans-serif; font-size: 36px; font-weight: 800;
      color: var(--tuatara); line-height: 1.1; letter-spacing: -0.02em;
    }
    .case-stat-label { font-size: 14px; color: var(--gray-600); margin-top: -4px; }
    .case-desc { font-size: 15px; color: var(--gray-600); line-height: 1.5; font-weight: 300; }
    .case-quote {
      font-style: italic; font-size: 14px; color: var(--tuatara); line-height: 1.5;
      padding: 12px 16px; background: var(--gray-50); border-radius: var(--radius-sm);
      border-left: 3px solid var(--yellow);
    }
    .case-quote cite { display: block; font-style: normal; font-size: 12px; color: var(--gray-600); margin-top: 8px; font-weight: 500; }
    .case-link {
      display: inline-flex; align-items: center; gap: 4px;
      color: var(--tuatara); font-size: 14px; font-weight: 600;
      text-decoration: none; margin-top: auto; transition: gap 0.2s;
    }
    .case-link:hover { gap: 8px; }
    .case-link svg { width: 14px; height: 14px; }

    /* ── INLINE TESTIMONIAL BREAK ── */
    .testimonial-break {
      grid-column: 1 / -1; border-radius: var(--radius); padding: 48px 40px;
      display: flex; align-items: center; gap: 40px; position: relative; overflow: hidden;
    }
    .testimonial-break.theme-dark { background: var(--tuatara); color: var(--white); }
    .testimonial-break.theme-yellow { background: var(--yellow); color: var(--tuatara); }
    .testimonial-break.theme-light { background: var(--gray-50); border: 1px solid var(--gray-200); color: var(--tuatara); }
    .tb-visual { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0; width: 160px; }
    .tb-logo-main { width: 140px; height: 100px; object-fit: contain; }
    .theme-dark .tb-logo-main { filter: brightness(0) invert(1); background: transparent; }
    .theme-dark .tb-logo-main[data-has-bg="true"] { filter: none; border-radius: 12px; }
    .tb-logo-fallback {
      width: 120px; height: 80px; border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Inter', sans-serif; font-size: 36px; font-weight: 800; line-height: 1;
    }
    .theme-dark .tb-logo-fallback { background: var(--yellow); color: var(--tuatara); }
    .theme-yellow .tb-logo-fallback { background: var(--tuatara); color: var(--yellow); }
    .theme-light .tb-logo-fallback { background: var(--tuatara); color: var(--yellow); }
    .tb-content { flex: 1; min-width: 0; }
    .tb-quote-mark { font-family: Georgia, serif; font-size: 56px; line-height: 1; margin-bottom: -8px; display: block; }
    .theme-dark .tb-quote-mark { color: var(--yellow); }
    .theme-yellow .tb-quote-mark { color: var(--tuatara); opacity: 0.25; }
    .theme-light .tb-quote-mark { color: var(--yellow); }
    .tb-quote { font-size: 20px; font-weight: 400; line-height: 1.6; font-style: italic; margin-bottom: 16px; }
    .theme-dark .tb-quote { color: rgba(255,255,255,0.9); }
    .tb-author-row { display: flex; align-items: center; gap: 12px; }
    .tb-author-info { display: flex; flex-direction: column; }
    .tb-author-name { font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; }
    .tb-author-role { font-size: 13px; opacity: 0.7; }
    .tb-stat-badge {
      display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px;
      border-radius: var(--radius-pill); font-family: 'Inter', sans-serif;
      font-size: 13px; font-weight: 700; margin-top: 12px;
    }
    .theme-dark .tb-stat-badge { background: rgba(255,255,140,0.15); color: var(--yellow); }
    .theme-yellow .tb-stat-badge { background: rgba(45,45,41,0.1); color: var(--tuatara); }
    .theme-light .tb-stat-badge { background: rgba(45,45,41,0.08); color: var(--tuatara); }
    .tb-link {
      display: inline-flex; align-items: center; gap: 4px; font-size: 14px;
      font-weight: 600; text-decoration: none; margin-top: 8px; transition: gap 0.2s;
    }
    .theme-dark .tb-link { color: var(--yellow); }
    .theme-yellow .tb-link { color: var(--tuatara); }
    .theme-light .tb-link { color: var(--tuatara); }
    .tb-link:hover { gap: 8px; }
    .tb-link svg { width: 14px; height: 14px; }

    @media (max-width: 700px) {
      .testimonial-break { flex-direction: column; text-align: center; padding: 32px 24px; gap: 24px; }
      .tb-author-row { justify-content: center; }
      .tb-quote { font-size: 17px; }
    }

    /* ── PLATFORM STATS ── */
    .platform-stats { background: var(--white); padding: 72px 24px; border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); }
    .platform-stats-inner { max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
    .ps-item { text-align: center; }
    .ps-dot { width: 48px; height: 48px; border-radius: 50%; background: var(--yellow); margin: 0 auto 16px; filter: blur(16px); opacity: 0.7; }
    .ps-number { font-family: 'Inter', sans-serif; font-size: clamp(36px, 5vw, 52px); font-weight: 800; color: var(--tuatara); line-height: 1.1; letter-spacing: -0.02em; }
    .ps-label { font-size: 15px; color: var(--gray-600); margin-top: 8px; line-height: 1.4; max-width: 260px; margin-left: auto; margin-right: auto; }

    /* ── G2 BADGES ── */
    .g2-section { background: var(--gray-50); padding: 72px 24px; text-align: center; }
    .g2-inner { max-width: var(--max-w); margin: 0 auto; }
    .g2-stars { font-size: 36px; letter-spacing: 4px; margin-bottom: 12px; }
    .g2-headline { font-family: 'Inter', sans-serif; font-size: clamp(28px, 4vw, 48px); font-weight: 800; color: var(--tuatara); margin-bottom: 4px; letter-spacing: -0.02em; line-height: 1.15; }
    .g2-sub { font-size: 17px; color: var(--gray-600); margin-bottom: 48px; }
    .g2-badges { display: flex; flex-wrap: wrap; gap: 24px; justify-content: center; align-items: flex-end; }
    .g2-badge-img { height: 120px; width: auto; object-fit: contain; transition: transform 0.2s; }
    .g2-badge-img:hover { transform: translateY(-4px); }
    .g2-badge-img.abcomm { height: 140px; }

    /* ── LOGO GRID ── */
    .logo-strip { padding: 40px 24px; background: var(--white); overflow: hidden; }
    .logo-strip-inner { max-width: var(--max-w); margin: 0 auto; text-align: center; }
    .logo-strip-label { font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 24px; }
    .logo-row { display: flex; flex-wrap: wrap; gap: 24px; justify-content: center; align-items: center; }
    .logo-row img { height: 36px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.5; transition: all 0.3s; }
    .logo-row img:hover { filter: grayscale(0%); opacity: 1; }

    /* ── FLOATING CTA ── */
    .floating-cta {
      position: fixed; bottom: 24px; right: 24px; z-index: 90;
      display: flex; align-items: center; gap: 8px;
      background: var(--tuatara); color: var(--white); padding: 14px 24px;
      text-decoration: none; font-family: 'Inter', sans-serif; font-size: 14px;
      font-weight: 700; border-radius: var(--radius-pill);
      box-shadow: 0 8px 32px rgba(0,0,0,0.2);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      opacity: 0; transform: translateY(20px); pointer-events: none;
    }
    .floating-cta.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .floating-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); background: #1a1a18; }
    .floating-cta svg { width: 14px; height: 14px; }
    .floating-cta .pulse-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--yellow); animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.4); } }

    /* ── INLINE CTA STRIP ── */
    .inline-cta {
      grid-column: 1 / -1; text-align: center; padding: 32px 16px;
      background: var(--tuatara); border-radius: var(--radius);
      display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap;
    }
    .inline-cta p { color: rgba(255,255,255,0.7); font-size: 15px; font-weight: 400; }
    .inline-cta p strong { color: var(--white); font-weight: 700; }
    .inline-cta-btn {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--yellow); color: var(--tuatara); padding: 12px 24px;
      text-decoration: none; font-family: 'Inter', sans-serif; font-size: 14px;
      font-weight: 700; border-radius: var(--radius-pill); transition: all 0.2s; flex-shrink: 0;
    }
    .inline-cta-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .inline-cta-btn svg { width: 14px; height: 14px; }

    @media (max-width: 600px) {
      .platform-stats-inner { grid-template-columns: 1fr; gap: 32px; }
      .g2-badges { gap: 10px; }
      .g2-badge-img { height: 80px; }
      .logo-row img { height: 28px; }
      .floating-cta { bottom: 16px; right: 16px; padding: 12px 20px; font-size: 13px; }
      .inline-cta { flex-direction: column; gap: 12px; }
    }

    /* ── BOTTOM CTA ── */
    .bottom-cta { background: var(--tuatara); padding: 72px 24px; text-align: center; }
    .bottom-cta h2 { font-size: clamp(24px, 4vw, 40px); font-weight: 800; color: var(--white); margin-bottom: 12px; letter-spacing: -0.02em; }
    .bottom-cta p { color: rgba(255,255,255,0.65); font-size: 17px; margin-bottom: 32px; font-weight: 300; }
    .cta-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--yellow); color: var(--tuatara); padding: 16px 32px;
      text-decoration: none; font-family: 'Inter', sans-serif; font-size: 16px;
      font-weight: 700; border-radius: var(--radius-pill); transition: all 0.2s;
    }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
    .cta-btn svg { width: 16px; height: 16px; }
    .cta-sub { display: block; margin-top: 16px; font-size: 13px; color: rgba(255,255,255,0.45); }

    /* ── FOOTER ── */
    .footer { text-align: center; padding: 24px; font-size: 13px; color: var(--gray-400); }
    .footer a { color: var(--gray-600); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .cases-grid { grid-template-columns: repeat(2, 1fr); }
      .quotes-grid { grid-template-columns: repeat(2, 1fr); }
      .hero-stats { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
      .cases-grid { grid-template-columns: 1fr; }
      .quotes-grid { grid-template-columns: 1fr; }
      .hero-stats { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .hero { padding: 48px 16px 40px; }
      .hero-stat { padding: 20px 12px; }
      .hero-stat-number { font-size: 26px; }
      .case-stat { font-size: 28px; }
      .filter-bar { gap: 6px; }
      .filter-btn { padding: 8px 14px; font-size: 13px; }
    }
</style>

  <!-- HEADER -->
  <header class="header">
    <div class="header-inner">
      <a href="https://www.edrone.me/pt" class="logo" target="_blank" rel="noopener">
