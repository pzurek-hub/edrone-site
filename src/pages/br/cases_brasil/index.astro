      {n:"Loula / Banca do Ramon",seg:"Moda e alimentos",stat:"+139%",sl:"lucro Dia dos Namorados",ch:"email",desc:"Newsletters personalizadas geraram aumentos de 139% e 30% de receita.",q:"",qa:"Victor Esquisato, Co-fundador Loula",url:"dia-dos-namorados-ecommerce",logo:"https://wp.edrone.me/wp-content/uploads/2024/02/loula-logo.png"},
      {n:"Banca do Ramon",seg:"Alimentos premium",stat:"+102%",sl:"receita marco Pascoa",ch:"email",desc:"Receita dobrou com automacoes de email personalizadas para Pascoa.",q:"",qa:"Suelen Pereira, CS Analyst edrone",url:"ecommerce-pascoa",logo:"https://wp.edrone.me/wp-content/uploads/2024/06/banca-ramon.jpeg"},
      {n:"Belt Nutrition",seg:"Suplementos bariatricos",stat:"+80%",sl:"receita de email",ch:"multicanal",desc:"60% da receita de email vindo de automacoes.",q:"",qa:"Jose Felipe Mousquer, Head de Marketing",url:"belt-nutrition",logo:"https://wp.edrone.me/wp-content/uploads/2023/09/images.png"},
      {n:"Brasil em Gotas",seg:"Moda e acessorios",stat:"70%",sl:"impacto automacoes",ch:"multicanal",desc:"70% de impacto nas vendas com automacoes e recomendacoes de produto.",q:"",qa:"Juliana Braga, Vice-diretora",url:"brasil-em-gotas",logo:"https://wp.edrone.me/wp-content/uploads/2024/11/logo-brasil-gotas.png"},
      {n:"Pomander",seg:"Beleza e aromas",stat:"67,5%",sl:"abertura WhatsApp",ch:"whatsapp",desc:"30% de impacto na receita com 67,5% de taxa de abertura.",q:"",qa:"Francisco Monari, Gerente de E-commerce",url:"automacao-whatsapp",logo:"https://wp.edrone.me/wp-content/uploads/2024/04/image-31.png"},
      {n:"ZooArt",seg:"Pet shop online",stat:"66,6%",sl:"taxa de recompra",ch:"multicanal",desc:"66,6% de recompra entre clientes impactados pela edrone em 1 ano.",q:"",qa:"Eryk Jakubik, Performance Manager",url:"zooart",logo:"https://wp.edrone.me/wp-content/uploads/2022/11/logo_zoo_art.png"},
      {n:"ArtStones",seg:"Moda e semi-joias",stat:"+52%",sl:"vendas novembro",ch:"email",desc:"Cresceu 52% em novembro com campanhas segmentadas de Black Friday.",q:"",qa:"Alan Matheus Perez, Diretor de Marketing",url:"artstone-black-friday",logo:"https://wp.edrone.me/wp-content/uploads/2024/12/1.-Logo-Oficial-ArtStones_logo-vertical-postivo-artstones.png"},
      {n:"Kaue Plus Size",seg:"Moda plus size",stat:"44%",sl:"impacto mensal vendas",ch:"multicanal",desc:"Vendas mensais +44% com segmentacao de email e automacao on-site.",q:"",qa:"Marcia Chican, Co-proprietaria",url:"a-segmentacao-tem-poder",logo:"https://wp.edrone.me/wp-content/uploads/2024/02/kaue-plus-size-logo.png"},
      // ═══ TIER 6: Outras metricas ═══
      {n:"Embelleze",seg:"Beleza capilar",stat:"11,95x ROI",sl:"ROI geral plataforma",ch:"multicanal",desc:"R$ 11,95 de retorno para cada R$ 1 investido.",q:"",qa:"Carla Niza, Coordenadora de E-commerce",url:"embelleze",logo:"https://wp.edrone.me/wp-content/uploads/2023/02/logo_embelleze.png"},
      {n:"Vo Irene",seg:"Cosmeticos naturais",stat:"11.90x ROI",sl:"ROI automacoes",ch:"multicanal",desc:"Base de clientes cresceu 38% com automacao personalizada.",q:"",qa:"Karla, Socia-fundadora",url:"e-commerce-cosmeticos",logo:"https://wp.edrone.me/wp-content/uploads/2025/04/vo-logo.jpeg"},
      {n:"Banca do Ramon",seg:"Alimentos e bebidas",stat:"31,43%",sl:"taxa de clique SMS",ch:"sms",desc:"SMS impulsionou vendas de queijos artesanais com ofertas exclusivas.",q:"",qa:"Marisa Walsick, Analista CRM",url:"case-sms-newsletter",logo:"https://wp.edrone.me/wp-content/uploads/2024/06/banca-ramon.jpeg"},
      {n:"Banca do Ramon",seg:"Alimentos premium",stat:"+23%",sl:"receita Q1 2025",ch:"email",desc:"Newsletter automatica com bestsellers gerou 135 pedidos no Q1.",q:"",qa:"Marisa Walsick, Especialista CRM",url:"newsletter-recorrente-banca-do-ramon",logo:"https://wp.edrone.me/wp-content/uploads/2024/06/banca-ramon.jpeg"},
      {n:"Ou",seg:"Casa e organizacao",stat:"20%+",sl:"receita via CRM",ch:"multicanal",desc:"Mais de 20% da receita atribuida a automacoes edrone.",q:"",qa:"Ricardo Magero Angeli, Gerente de Canais",url:"ecommerce-casa-decoracao-ou",logo:"https://wp.edrone.me/wp-content/uploads/2024/11/logo-ou.png"},
      {n:"Zorba",seg:"Moda intima masculina",stat:"1.200",sl:"novos clientes agosto",ch:"multicanal",desc:"1.200 novos clientes com campanhas de Dia dos Pais.",q:"",qa:"Carolina Fleming, Analista de E-commerce",url:"dia-dos-pais",logo:"https://wp.edrone.me/wp-content/uploads/2024/09/logo-zorba.png"},
    ];

    const BADGE_LABELS = {whatsapp:"WhatsApp",email:"Email",sms:"SMS",multicanal:"Multicanal",popup:"Pop-up"};
    const ICONS = {
      whatsapp:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>',
      email:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
      sms:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
      multicanal:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
      popup:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>'
    };
    const ARROW = '<svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

    // ── Testimonials to insert after every 6 cards ──
    const TESTIMONIALS = [
      {quote:"Estrategia multicanal se tornou vantagem competitiva real. Cada canal tem sua forca, mas a sinergia combinada cria a experiencia completa.",name:"Douglas Dill",role:"CEO, OnMoveis",stat:"R$ 338K+ em 90 dias",logo:"https://wp.edrone.me/wp-content/uploads/2025/10/image-8.png",hasBg:true,url:"estrategia-multicanal",theme:"dark"},
      {quote:"SMS provou ser canal acessivel, direto e eficiente, com minima concorrencia. O crescimento de +241% foi possivel gracas a parceria com a edrone.",name:"Julia",role:"Head de E-commerce, Sapato Retro",stat:"ROI de 31x no SMS",logo:"https://wp.edrone.me/wp-content/uploads/2025/12/sapato-logo.png",url:"black-friday-antecipada-sapato-retro",theme:"yellow"},
      {quote:"CRM re-engajou clientes inativos, refletindo diretamente na receita — especialmente durante a Black Friday. WhatsApp cresceu 682%.",name:"Isabel Albach",role:"Co-fundadora, Muzazen",stat:"51x ROI no WhatsApp",logo:"https://wp.edrone.me/wp-content/uploads/2025/12/muzazen-logo.jpeg",hasBg:true,url:"muzazen-black-friday",theme:"dark"},
      {quote:"Retornos surpreendentes em apenas 30 dias. Comunicacao automatizada e personalizada fortaleceu relacionamentos e impactou a receita diretamente.",name:"Beatriz Ataide",role:"Gerente de E-commerce, Seralle",stat:"16.87x ROI WhatsApp",logo:"https://wp.edrone.me/wp-content/uploads/2025/10/logo-seralle.png",url:"roi-whatsapp-seralle",theme:"yellow"},
      {quote:"Agora vendemos mais para clientes fieis — os numeros de recompra provam. CLV cresceu 107% com segmentacao comportamental.",name:"Rafael Soares",role:"Fundador, Origgo",stat:"+107% receita em 3 meses",logo:"https://wp.edrone.me/wp-content/uploads/2026/02/origgo.webp",hasBg:false,url:"crm-ecommerce-moda-masculina-case-origgo",theme:"dark"},
      {quote:"Mais do que gerar resultados, a edrone nos ajuda a estar presentes na rotina dos nossos clientes, com uma comunicacao leve, assertiva e que realmente faz diferenca.",name:"Rodrigo Kozlowski",role:"Gerente de Marketing, La Luna Modas",stat:"R$ 8,8M em 12 meses",logo:"https://wp.edrone.me/wp-content/uploads/2025/07/logo-la-luna.png",url:"case-la-luna",theme:"light"}
    ];

    // ── Render cards + testimonials ──
    const grid = document.getElementById('casesGrid');
    let testimonialIdx = 0;

    CASES.forEach((c, i) => {
      if (i > 0 && i % 6 === 0 && testimonialIdx < TESTIMONIALS.length) {
        const t = TESTIMONIALS[testimonialIdx];
        const initials = t.name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
        const hasBgAttr = t.hasBg ? ' data-has-bg="true"' : '';
        const logoVisual = t.logo
          ? '<img class="tb-logo-main"' + hasBgAttr + ' src="' + t.logo + '" alt="' + t.name + '" onerror="this.outerHTML=\'<div class=tb-logo-fallback>' + initials + '</div>\'">'
          : '<div class="tb-logo-fallback">' + initials + '</div>';

        const tbEl = document.createElement('div');
        tbEl.className = 'testimonial-break theme-' + t.theme;
        tbEl.dataset.testimonial = 'true';
        tbEl.innerHTML = '<div class="tb-visual">' + logoVisual + '</div><div class="tb-content"><span class="tb-quote-mark">\u201C</span><p class="tb-quote">' + t.quote + '</p><div class="tb-author-row"><div class="tb-author-info"><span class="tb-author-name">' + t.name + '</span><span class="tb-author-role">' + t.role + '</span></div></div><span class="tb-stat-badge">' + t.stat + '</span><br><a href="https://edrone.me/br/cases-de-sucesso/' + t.url + '" class="tb-link" target="_blank" rel="noopener">Ver case completo ' + ARROW + '</a></div>';
        grid.appendChild(tbEl);
        testimonialIdx++;
      }

      const channels = c.ch.split(' ');
      const primaryCh = channels[0];
      const badgeLabel = channels.length > 1
        ? channels.map(k => BADGE_LABELS[k] || k).join(' + ')
        : BADGE_LABELS[primaryCh] || primaryCh;

      const initial = c.n.replace(/[^A-Za-z0-9\u00C0-\u00FA]/g,'').charAt(0).toUpperCase();
      const logoSrc = c.logo || '';
      const logoHTML = logoSrc
        ? '<div class="case-logo"><img src="' + logoSrc + '" alt="' + c.n + '" onerror="this.parentElement.innerHTML=\'<span class=case-logo-initial>' + initial + '</span>\'"></div>'
        : '<div class="case-logo"><span class="case-logo-initial">' + initial + '</span></div>';

      let html = '<span class="case-badge" data-ch="' + primaryCh + '">' + (ICONS[primaryCh] || '') + badgeLabel + '</span><div class="case-header">' + logoHTML + '<div class="case-header-text"><span class="case-name">' + c.n + '</span><span class="case-segment">' + c.seg + '</span></div></div><div><span class="case-stat">' + c.stat + '</span><p class="case-stat-label">' + c.sl + '</p></div><p class="case-desc">' + c.desc + '</p>';

      if (c.q) {
        html += '<div class="case-quote">' + c.q + '<cite>' + c.qa + '</cite></div>';
      }

      html += '<a href="https://edrone.me/br/cases-de-sucesso/' + c.url + '" class="case-link" target="_blank" rel="noopener">Ver case completo ' + ARROW + '</a>';

      const card = document.createElement('div');
      card.className = 'case-card';
      card.dataset.channel = c.ch;
      card.dataset.segment = c.seg;
      card.innerHTML = html;
      grid.appendChild(card);
    });

    // ── Build segment filter buttons ──
    const SEG_MAP = {};
    CASES.forEach(c => { const raw = c.seg.toLowerCase(); if (!SEG_MAP[raw]) SEG_MAP[raw] = c.seg; });
    const SEG_GROUPS = {
      "Moda": ["moda infantil","moda masculina","moda plus size","moda camisetas","moda intima masculina","calcados","calcados femininos","calcados moda","calcados (21 lojas)","lingerie","moda lingerie","moda e acessorios","moda e semi-joias"],
      "Casa & Deco": ["moveis (shopify)","decoracao e casa","cama mesa banho","casa e organizacao","utilidades domesticas","pijamas e moda casa"],
      "Alimentos": ["alimentos e bebidas","alimentos premium","vinhos e bebidas"],
      "Beleza": ["beleza e bem-estar","beleza e aromas","beleza capilar","cosmeticos naturais"],
      "Esportes": ["bicicletas","esportes e outdoor","materiais esportivos"],
      "Saude": ["saude e hospitalar","suplementos bariatricos"],
      "Joias": ["joias e acessorios"],
      "Infantil": ["brinquedos"],
      "Pet": ["pet shop online"],
      "Plantas": ["plantas e jardim"],
      "Livros": ["livraria online"],
      "Materiais": ["materiais construcao"],
    };
    const segToGroup = {};
    Object.entries(SEG_GROUPS).forEach(([group, segs]) => { segs.forEach(s => { segToGroup[s] = group; }); });
    const groupCounts = {};
    CASES.forEach(c => { const group = segToGroup[c.seg.toLowerCase()] || "Outros"; groupCounts[group] = (groupCounts[group] || 0) + 1; });
    const segBar = document.getElementById('segFilter');
    const allSegBtn = document.createElement('button');
    allSegBtn.className = 'seg-btn active';
    allSegBtn.dataset.seg = 'all';
    allSegBtn.textContent = 'Todos';
    segBar.appendChild(allSegBtn);
    Object.entries(groupCounts).sort((a,b) => b[1] - a[1]).forEach(([group, count]) => {
      const btn = document.createElement('button');
      btn.className = 'seg-btn';
      btn.dataset.seg = group;
      btn.textContent = group + ' (' + count + ')';
      segBar.appendChild(btn);
    });

    // ── Combined filter state ──
    let activeChannel = 'all';
    let activeSegment = 'all';

    function applyFilters() {
      let visible = 0;
      document.querySelectorAll('.case-card').forEach(card => {
        const channels = card.dataset.channel.split(' ');
        const seg = card.dataset.segment || '';
        const segGroup = segToGroup[seg.toLowerCase()] || 'Outros';
        const chMatch = activeChannel === 'all' || channels.includes(activeChannel);
        const segMatch = activeSegment === 'all' || segGroup === activeSegment;
        const show = chMatch && segMatch;
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      const showTestimonials = activeChannel === 'all' && activeSegment === 'all';
      document.querySelectorAll('.testimonial-break').forEach(tb => { tb.classList.toggle('hidden', !showTestimonials); });
      const af = document.getElementById('activeFilters');
      const rc = document.getElementById('resultsCount');
      if (activeChannel === 'all' && activeSegment === 'all') {
        af.innerHTML = '';
        rc.textContent = '';
      } else {
        let tags = '';
        if (activeChannel !== 'all') { tags += '<span class="active-filter-tag">' + (BADGE_LABELS[activeChannel] || activeChannel) + '</span>'; }
        if (activeSegment !== 'all') { tags += '<span class="active-filter-tag">' + activeSegment + '</span>'; }
        tags += '<button class="clear-filters" id="clearAll">Limpar filtros</button>';
        af.innerHTML = tags;
        rc.textContent = visible + ' case' + (visible !== 1 ? 's' : '') + ' encontrado' + (visible !== 1 ? 's' : '');
        document.getElementById('clearAll').addEventListener('click', () => {
          activeChannel = 'all'; activeSegment = 'all';
          document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter === 'all'));
          document.querySelectorAll('.seg-btn').forEach(b => b.classList.toggle('active', b.dataset.seg === 'all'));
          applyFilters();
        });
      }
    }

    const filterBtns = document.querySelectorAll('.filter-btn');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeChannel = btn.dataset.filter;
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
        if (typeof gtag === 'function') { gtag('event', 'filter_click', { filter_channel: activeChannel, page_location: window.location.pathname }); }
      });
    });
    document.querySelectorAll('.seg-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeSegment = btn.dataset.seg;
        document.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
        if (typeof gtag === 'function') { gtag('event', 'filter_click', { filter_segment: activeSegment, page_location: window.location.pathname }); }
      });
    });

    // ── Floating CTA ──
    const floatingCta = document.getElementById('floatingCta');
    const heroSection = document.querySelector('.hero');
    let floatingVisible = false;
    function checkFloatingCta() {
      const heroBottom = heroSection.getBoundingClientRect().bottom;
      const bottomCta = document.querySelector('.bottom-cta');
      const bottomTop = bottomCta ? bottomCta.getBoundingClientRect().top : Infinity;
      const shouldShow = heroBottom < 0 && bottomTop > window.innerHeight;
      if (shouldShow !== floatingVisible) { floatingVisible = shouldShow; floatingCta.classList.toggle('visible', shouldShow); }
    }
    window.addEventListener('scroll', checkFloatingCta, { passive: true });
    checkFloatingCta();

    // ── Inline CTA strips ──
    const INLINE_CTAS = [
      { pos: 18, text: "Quer resultados como esses?", btnText: "Agende sua demo gratis" },
      { pos: 33, text: "Sua loja pode ser o <strong>proximo case</strong>", btnText: "Fale com um especialista" },
    ];
    const allCards = grid.querySelectorAll('.case-card');
    let inserted = 0;
    INLINE_CTAS.forEach(({ pos, text, btnText }) => {
      const targetIdx = pos + inserted;
      const cards = grid.children;
      if (targetIdx < cards.length) {
        const strip = document.createElement('div');
        strip.className = 'inline-cta';
        strip.dataset.inlineCta = 'true';
        strip.innerHTML = '<p>' + text + '</p><a href="https://edrone.me/br/demo" class="inline-cta-btn" target="_blank" rel="noopener">' + btnText + ' <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>';
        cards[targetIdx].parentNode.insertBefore(strip, cards[targetIdx]);
        inserted++;
      }
    });

    // Hide inline CTAs when filters are active
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        setTimeout(() => {
          const filtersActive = activeChannel !== 'all' || activeSegment !== 'all';
          document.querySelectorAll('[data-inline-cta]').forEach(el => { el.classList.toggle('hidden', filtersActive); });
        }, 10);
      });
    });
    document.querySelectorAll('.seg-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        setTimeout(() => {
          const filtersActive = activeChannel !== 'all' || activeSegment !== 'all';
          document.querySelectorAll('[data-inline-cta]').forEach(el => { el.classList.toggle('hidden', filtersActive); });
        }, 10);
      });
    });

    // ── GA4: track clicks ──
    document.addEventListener('click', e => {
      const link = e.target.closest('.case-link');
      if (link && typeof gtag === 'function') {
        const name = link.closest('.case-card')?.querySelector('.case-name')?.textContent || '';
        gtag('event', 'case_click', { case_name: name, link_url: link.href, page_location: window.location.pathname });
      }
      const cta = e.target.closest('.cta-btn, .header-cta, .floating-cta, .inline-cta-btn');
      if (cta && typeof gtag === 'function') {
        gtag('event', 'cta_click', { link_url: cta.href, link_text: cta.textContent.trim(), page_location: window.location.pathname });
      }
    });
  </script>

</LandingLayout>
