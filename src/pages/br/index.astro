---
export const prerender = true;

import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Calculadora de ROI | edrone — quanta receita você está perdendo?"
  description="Descubra quanta receita adicional você pode gerar com automação de e-mail marketing da edrone. Calculadora baseada em dados reais de mais de 1.000 lojas."
  lang="pt-BR"
  ogTitle="Calculadora de ROI | edrone — quanta receita sua loja está perdendo?"
  ogDescription="Calcule em 30 segundos quanta receita adicional você pode gerar com e-mail marketing. Dados de mais de 1.000 lojas."
  ogUrl="https://roi.edrone.me/br/"
  googleFont="Inter:wght@400;500;600;700;800"
>

<style>
    /* ── HEADER ── */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--gray-200);
      padding: 0 24px;
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo-svg { height: 22px; width: auto; }
    .header-cta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--black);
      color: var(--white);
      padding: 10px 20px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      border-radius: 100px;
      transition: all 0.2s;
    }
    .header-cta:hover { opacity: 0.85; transform: translateY(-1px); }
    .header-cta svg { width: 14px; height: 14px; }

    /* ── HERO ── */
    .hero {
      padding: 56px 24px 0;
      text-align: center;
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, var(--yellow-bg) 0%, var(--white) 100%);
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -100px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(250,204,21,0.15) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 100px;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 500;
      color: var(--gray-600);
      margin-bottom: 24px;
      position: relative;
    }
    .hero-badge .dot {
      width: 8px;
      height: 8px;
      background: #22c55e;
      border-radius: 50%;
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .hero h1 {
      font-weight: 800;
      font-size: clamp(36px, 5.5vw, 56px);
      line-height: 1.08;
      max-width: 750px;
      margin: 0 auto 20px;
      letter-spacing: -1.5px;
      color: var(--black);
      position: relative;
    }
    .hero h1 span {
      background: linear-gradient(135deg, var(--yellow) 0%, #f59e0b 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      color: var(--gray-600);
      font-size: 18px;
      max-width: 540px;
      margin: 0 auto 36px;
      line-height: 1.6;
      position: relative;
    }
    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
      position: relative;
      margin-bottom: 16px;
    }
    .hero-stat {
      text-align: center;
    }
    .hero-stat-number {
      display: block;
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -1px;
      color: var(--black);
    }
    .hero-stat-label {
      font-size: 13px;
      color: var(--gray-400);
      font-weight: 500;
    }
    .scroll-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--gray-400);
      font-size: 13px;
      text-decoration: none;
      margin-top: 32px;
      animation: bounce 2s infinite;
      font-weight: 500;
    }
    .scroll-cta svg { width: 16px; height: 16px; }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(5px); }
    }

    /* ── CALCULATOR ── */
    .calculator {
      padding: 24px 24px 48px;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .section-tag {
      display: block;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--teal-light);
      text-align: center;
      margin-bottom: 12px;
    }
    .section-title {
      text-align: center;
      font-size: clamp(24px, 3.5vw, 32px);
      font-weight: 700;
      margin-bottom: 8px;
      letter-spacing: -0.5px;
    }
    .section-subtitle {
      text-align: center;
      font-size: 16px;
      color: var(--gray-600);
      margin-bottom: 40px;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }

    .calc-form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 32px;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }
    @media (max-width: 600px) {
      .calc-form { grid-template-columns: 1fr; gap: 20px; }
    }

    .form-group label {
      display: block;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--gray-900);
    }
    .form-group select,
    .form-group input[type="number"] {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid var(--gray-200);
      border-radius: 12px;
      font-size: 16px;
      font-family: 'Inter', sans-serif;
      background: var(--white);
      color: var(--black);
      transition: border-color 0.2s, box-shadow 0.2s;
      appearance: none;
      -webkit-appearance: none;
    }
    .form-group select {
      background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%2394a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
      background-repeat: no-repeat;
      background-position: right 16px center;
      padding-right: 40px;
      cursor: pointer;
    }
    .form-group select:focus,
    .form-group input:focus {
      outline: none;
      border-color: var(--teal-light);
      box-shadow: 0 0 0 3px rgba(13,148,136,0.1);
    }

    .slider-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 10px;
    }
    .slider-row input[type="range"] {
      flex: 1;
      -webkit-appearance: none;
      appearance: none;
      height: 6px;
      background: var(--gray-200);
      border-radius: 3px;
      outline: none;
    }
    .slider-row input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 20px;
      height: 20px;
      background: var(--black);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: var(--shadow-sm);
    }
    .slider-val {
      font-size: 14px;
      font-weight: 600;
      color: var(--black);
      min-width: 60px;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .input-hint {
      font-size: 12px;
      color: var(--gray-400);
      margin-top: 6px;
    }
    .input-error {
      font-size: 12px;
      color: #ef4444;
      margin-top: 6px;
      display: none;
    }
    .input-error.show { display: block; }

    /* ── RESULTS ── */
    .results {
      max-width: 700px;
      margin: 0 auto;
      border-radius: 20px;
      text-align: center;
      opacity: 0;
      transform: translateY(24px);
      transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
      max-height: 0;
      overflow: hidden;
    }
    .results.visible {
      opacity: 1;
      transform: translateY(0);
      max-height: 900px;
    }
    .results-inner {
      background: var(--black);
      border-radius: 20px;
      padding: 48px 40px 40px;
      color: var(--white);
      box-shadow: var(--shadow-xl);
    }
    @media (max-width: 600px) {
      .results-inner { padding: 36px 20px 32px; }
    }

    .result-eyebrow {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--yellow);
      margin-bottom: 12px;
    }
    .result-number {
      font-size: clamp(44px, 10vw, 72px);
      font-weight: 800;
      letter-spacing: -3px;
      line-height: 1;
      color: var(--white);
    }
    .result-currency {
      font-size: clamp(24px, 5vw, 40px);
      font-weight: 700;
    }
    .result-period {
      font-size: 15px;
      color: var(--gray-400);
      margin-bottom: 6px;
      margin-top: 4px;
    }
    .result-yearly {
      font-size: 18px;
      font-weight: 600;
      color: var(--gray-400);
      margin-bottom: 36px;
    }
    .result-yearly strong {
      color: var(--white);
    }

    /* ── BAR CHART ── */
    .chart {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 16px;
      height: 180px;
      margin-bottom: 24px;
      padding: 0 20px;
    }
    @media (max-width: 600px) {
      .chart { gap: 10px; height: 150px; padding: 0; }
    }
    .chart-bar {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      flex: 1;
      max-width: 160px;
    }
    .bar-value {
      font-size: 14px;
      font-weight: 700;
      color: var(--white);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }
    @media (max-width: 600px) {
      .bar-value { font-size: 12px; }
    }
    .bar-fill {
      width: 100%;
      border-radius: 8px 8px 4px 4px;
      min-height: 16px;
      transition: height 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .bar-fill.c1 { background: linear-gradient(180deg, #475569 0%, #334155 100%); }
    .bar-fill.c2 { background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%); }
    .bar-fill.c3 { background: linear-gradient(180deg, var(--yellow) 0%, #f59e0b 100%); }
    .bar-label {
      font-size: 11px;
      color: var(--gray-400);
      text-align: center;
      line-height: 1.4;
      max-width: 130px;
    }
    @media (max-width: 600px) {
      .bar-label { font-size: 10px; }
    }
    .bar-label strong {
      color: var(--gray-200);
      font-weight: 600;
      display: block;
    }

    .result-divider {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.1);
      margin: 28px 0;
    }

    .result-context {
      font-size: 13px;
      color: var(--gray-400);
      max-width: 420px;
      margin: 0 auto 28px;
      line-height: 1.6;
    }
    .result-context strong {
      color: var(--gray-200);
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--yellow);
      color: var(--black);
      padding: 16px 32px;
      border-radius: 100px;
      text-decoration: none;
      font-size: 16px;
      font-weight: 700;
      transition: all 0.2s;
      border: none;
      cursor: pointer;
    }
    .cta-btn:hover {
      background: #eab308;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(250,204,21,0.4);
    }
    .cta-btn svg { width: 18px; height: 18px; }
    .cta-btn-sub {
      display: block;
      margin-top: 12px;
      font-size: 12px;
      color: var(--gray-400);
    }

    /* ── HOW IT WORKS ── */
    .how-it-works {
      padding: 72px 24px;
      background: var(--gray-50);
      border-top: 1px solid var(--gray-200);
      border-bottom: 1px solid var(--gray-200);
    }
    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      max-width: 900px;
      margin: 0 auto;
    }
    @media (max-width: 700px) {
      .steps { grid-template-columns: 1fr; gap: 24px; }
    }
    .step {
      text-align: center;
      padding: 32px 24px;
      background: var(--white);
      border-radius: var(--radius);
      border: 1px solid var(--gray-200);
      transition: box-shadow 0.2s;
    }
    .step:hover { box-shadow: var(--shadow-md); }
    .step-icon {
      width: 48px;
      height: 48px;
      background: var(--yellow-bg);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 24px;
    }
    .step-number {
      font-size: 12px;
      font-weight: 700;
      color: var(--teal-light);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }
    .step h3 {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .step p {
      font-size: 14px;
      color: var(--gray-600);
      line-height: 1.5;
    }

    /* ── SOCIAL PROOF ── */
    .social-proof {
      padding: 56px 24px;
      background: var(--black);
      color: var(--white);
      text-align: center;
    }
    .social-proof-label {
      font-size: 13px;
      color: rgba(255,255,255,0.4);
      margin-bottom: 32px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 600;
    }
    .logos {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 24px 48px;
      max-width: var(--max-w);
      margin: 0 auto 40px;
    }
    .logos img {
      height: 26px;
      width: auto;
      filter: brightness(0) invert(1);
      opacity: 0.35;
      transition: opacity 0.2s;
    }
    .logos img:hover { opacity: 0.7; }

    .testimonial {
      max-width: 560px;
      margin: 0 auto;
      padding-top: 32px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .testimonial blockquote {
      font-size: 16px;
      font-style: italic;
      color: rgba(255,255,255,0.7);
      line-height: 1.6;
      margin-bottom: 16px;
    }
    .testimonial cite {
      font-size: 14px;
      font-style: normal;
      color: rgba(255,255,255,0.4);
    }
    .testimonial cite strong {
      color: rgba(255,255,255,0.6);
      font-weight: 600;
    }

    /* ── FEATURES ── */
    .features {
      padding: 72px 24px;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 48px;
    }
    @media (max-width: 700px) {
      .features-grid { grid-template-columns: 1fr; }
    }
    .feature-card {
      padding: 28px 24px;
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      transition: all 0.2s;
    }
    .feature-card:hover {
      border-color: var(--gray-400);
      box-shadow: var(--shadow-md);
    }
    .feature-icon {
      font-size: 28px;
      margin-bottom: 16px;
    }
    .feature-card h3 {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .feature-card p {
      font-size: 14px;
      color: var(--gray-600);
      line-height: 1.5;
    }

    /* ── BOTTOM CTA ── */
    .bottom-cta {
      padding: 80px 24px;
      text-align: center;
      background: linear-gradient(180deg, var(--white) 0%, var(--yellow-bg) 100%);
      position: relative;
    }
    .bottom-cta h2 {
      font-weight: 800;
      font-size: clamp(28px, 4vw, 40px);
      margin-bottom: 12px;
      letter-spacing: -0.5px;
    }
    .bottom-cta > p {
      color: var(--gray-600);
      font-size: 16px;
      margin-bottom: 32px;
      max-width: 440px;
      margin-left: auto;
      margin-right: auto;
    }
    .bottom-cta .cta-btn {
      background: var(--black);
      color: var(--white);
    }
    .bottom-cta .cta-btn:hover {
      background: var(--dark);
      box-shadow: var(--shadow-lg);
    }
    .sub-note {
      margin-top: 16px;
      font-size: 13px;
      color: var(--gray-400);
    }

    /* ── FOOTER ── */
    .footer {
      padding: 28px 24px;
      text-align: center;
      font-size: 13px;
      color: var(--gray-400);
      border-top: 1px solid var(--gray-200);
    }
    .footer a {
      color: var(--gray-600);
      text-decoration: none;
    }
    .footer a:hover { text-decoration: underline; }

    /* ── BR-specific variables ── */
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--black);
      background: var(--white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    /* Local variable overrides for this page's color scheme */
    :root {
      --yellow-bg: #FFFBEB;
      --yellow-soft: #FEF9C3;
      --black: #0f172a;
      --dark: #1e293b;
      --gray-900: #334155;
      --gray-600: #64748b;
      --gray-400: #94a3b8;
      --gray-200: #e2e8f0;
      --gray-100: #f1f5f9;
      --gray-50: #f8fafc;
      --teal: #134e4a;
      --teal-light: #0d9488;
      --bar-1: #0f172a;
      --bar-2: #1e40af;
      --bar-3: #d97706;
      --max-w: 1120px;
      --radius: 16px;
    }
</style>

  <!-- HEADER -->
  <header class="header">
    <div class="header-inner">
      <a href="https://www.edrone.me/pt" class="logo" target="_blank" rel="noopener">
