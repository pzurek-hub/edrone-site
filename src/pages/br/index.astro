  <script is:inline>
    // ── Industry benchmark data (from edrone internal data, 1000+ stores) ──
    // Values converted from PLN to BRL at approximate rate (1 PLN ≈ 1.30 BRL)
    const PLN_TO_BRL = 1.30;
    const INDUSTRY_DATA = {
      ELECTRONICS:              { revPer1000: 23421.80 * PLN_TO_BRL, revUnknown1000: 17566.35 * PLN_TO_BRL, revNewsletter1000: 2342.18 * PLN_TO_BRL, aov: 928.39 * PLN_TO_BRL, aovEdrone: 1171.09 * PLN_TO_BRL },
