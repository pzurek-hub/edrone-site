      VEHICLES_AND_PARTS:       { revPer1000: 25592.20 * PLN_TO_BRL, revUnknown1000: 19194.15 * PLN_TO_BRL, revNewsletter1000: 2559.22 * PLN_TO_BRL, aov: 1080.39 * PLN_TO_BRL, aovEdrone: 1279.81 * PLN_TO_BRL },
      HEALTH_AND_BEAUTY:        { revPer1000: 6613.60 * PLN_TO_BRL,  revUnknown1000: 4960.20 * PLN_TO_BRL,  revNewsletter1000: 661.36 * PLN_TO_BRL,  aov: 260.36 * PLN_TO_BRL, aovEdrone: 330.66 * PLN_TO_BRL },
      ANIMALS_AND_PET_SUPPLIES: { revPer1000: 5572.00 * PLN_TO_BRL,  revUnknown1000: 4179.00 * PLN_TO_BRL,  revNewsletter1000: 557.20 * PLN_TO_BRL,  aov: 238.85 * PLN_TO_BRL, aovEdrone: 278.60 * PLN_TO_BRL },
      FOOD_DRINK_AND_TOBACCO:   { revPer1000: 17088.00 * PLN_TO_BRL, revUnknown1000: 12816.00 * PLN_TO_BRL, revNewsletter1000: 1708.80 * PLN_TO_BRL, aov: 738.09 * PLN_TO_BRL, aovEdrone: 854.40 * PLN_TO_BRL },
      KIDS_AND_BABIES:          { revPer1000: 6675.80 * PLN_TO_BRL,  revUnknown1000: 5006.85 * PLN_TO_BRL,  revNewsletter1000: 667.58 * PLN_TO_BRL,  aov: 260.37 * PLN_TO_BRL, aovEdrone: 331.79 * PLN_TO_BRL },
      HOME_AND_GARDEN:          { revPer1000: 11428.40 * PLN_TO_BRL, revUnknown1000: 8571.30 * PLN_TO_BRL,  revNewsletter1000: 1142.84 * PLN_TO_BRL, aov: 508.74 * PLN_TO_BRL, aovEdrone: 571.42 * PLN_TO_BRL },
      GAMES_AND_TOYS:           { revPer1000: 6448.20 * PLN_TO_BRL,  revUnknown1000: 4836.15 * PLN_TO_BRL,  revNewsletter1000: 644.82 * PLN_TO_BRL,  aov: 289.13 * PLN_TO_BRL, aovEdrone: 322.41 * PLN_TO_BRL },
      TRAVEL_ACCESSORIES:       { revPer1000: 8608.80 * PLN_TO_BRL,  revUnknown1000: 6456.60 * PLN_TO_BRL,  revNewsletter1000: 860.88 * PLN_TO_BRL,  aov: 410.86 * PLN_TO_BRL, aovEdrone: 430.44 * PLN_TO_BRL },
      JEWELRY:                  { revPer1000: 12126.80 * PLN_TO_BRL, revUnknown1000: 9095.10 * PLN_TO_BRL,  revNewsletter1000: 1212.68 * PLN_TO_BRL, aov: 579.18 * PLN_TO_BRL, aovEdrone: 606.34 * PLN_TO_BRL },
      CLOTHES_AND_ACCESSORIES:  { revPer1000: 6596.60 * PLN_TO_BRL,  revUnknown1000: 4947.45 * PLN_TO_BRL,  revNewsletter1000: 659.66 * PLN_TO_BRL,  aov: 327.44 * PLN_TO_BRL, aovEdrone: 329.83 * PLN_TO_BRL },
      FURNITURE:                { revPer1000: 9618.40 * PLN_TO_BRL,  revUnknown1000: 7213.80 * PLN_TO_BRL,  revNewsletter1000: 961.84 * PLN_TO_BRL,  aov: 478.59 * PLN_TO_BRL, aovEdrone: 480.92 * PLN_TO_BRL },
      HEALTH_AND_WELLNESS:      { revPer1000: 6260.80 * PLN_TO_BRL,  revUnknown1000: 4695.60 * PLN_TO_BRL,  revNewsletter1000: 626.08 * PLN_TO_BRL,  aov: 348.78 * PLN_TO_BRL, aovEdrone: 313.04 * PLN_TO_BRL },
      OTHER:                    { revPer1000: 9618.40 * PLN_TO_BRL,  revUnknown1000: 7213.80 * PLN_TO_BRL,  revNewsletter1000: 961.84 * PLN_TO_BRL,  aov: 478.59 * PLN_TO_BRL, aovEdrone: 480.92 * PLN_TO_BRL }
    };

    const fmt = n => Math.round(n).toLocaleString('pt-BR');

    const industryEl = document.getElementById('industry');
    const subscribersEl = document.getElementById('subscribers');
    const rangeEl = document.getElementById('subscribersRange');
    const sliderVal = document.getElementById('sliderVal');
    const resultsEl = document.getElementById('results');
    const inputHint = document.getElementById('inputHint');
    const inputError = document.getElementById('inputError');

    // Sync slider <-> input
    rangeEl.addEventListener('input', () => {
      const v = parseInt(rangeEl.value);
      subscribersEl.value = v;
      sliderVal.textContent = fmt(v);
      inputError.classList.remove('show');
      calculate();
    });
    subscribersEl.addEventListener('input', () => {
      const v = parseInt(subscribersEl.value) || 0;
      if (v >= 500 && v <= 100000) rangeEl.value = v;
      sliderVal.textContent = fmt(v || 0);
      if (v > 0 && v < 100) {
        inputError.classList.add('show');
      } else {
        inputError.classList.remove('show');
      }
      calculate();
    });
    industryEl.addEventListener('change', calculate);

    function calculate() {
      const industry = industryEl.value;
      const subs = parseInt(subscribersEl.value) || parseInt(rangeEl.value) || 0;

      if (!industry || subs < 100) {
        resultsEl.classList.remove('visible');
        return;
      }

      const data = INDUSTRY_DATA[industry];
      if (!data) return;

      // Scenario 1: Revenue from subscriber automations only
      const revSubscribers = data.revPer1000 * (subs / 1000);

      // Scenario 2: + Revenue from unknown contacts automation (assume unknowns ~2.5x subscribers)
      const unknowns = subs * 2.5;
      const revFullBase = revSubscribers + (data.revUnknown1000 * (unknowns / 1000));

      // Scenario 3: + Newsletters (2/month) + SMS uplift (15%)
      const revNewsletters = data.revNewsletter1000 * (subs / 1000) * 2;
      const revFullSMS = (revFullBase + revNewsletters) * 1.15;

      // Display primary result (scenario 1 = conservative)
      animateNumber('monthlyRevenue', revSubscribers);
      document.getElementById('yearlyRevenue').textContent = 'R$ ' + fmt(revSubscribers * 12);

      // Bar chart
      const maxRev = revFullSMS;
      const maxH = 160;
      const h1 = Math.max(24, (revSubscribers / maxRev) * maxH);
      const h2 = Math.max(24, (revFullBase / maxRev) * maxH);
      const h3 = maxH;

      document.getElementById('bar1').style.height = h1 + 'px';
      document.getElementById('bar2').style.height = h2 + 'px';
      document.getElementById('bar3').style.height = h3 + 'px';
      document.getElementById('bar1val').textContent = 'R$ ' + fmt(revSubscribers);
      document.getElementById('bar2val').textContent = 'R$ ' + fmt(revFullBase);
      document.getElementById('bar3val').textContent = 'R$ ' + fmt(revFullSMS);

      resultsEl.classList.add('visible');

      // GA4: track calculator result
      if (typeof gtag === 'function') {
        gtag('event', 'calculator_result', {
          industry: industry,
          subscribers: subs,
          monthly_revenue: Math.round(revSubscribers),
          currency: 'BRL'
        });
      }

      // Auto-scroll to results
      setTimeout(() => {
        resultsEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }

    // GA4: track CTA clicks
    document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', {
            link_url: btn.href,
            link_text: btn.textContent.trim(),
            page_location: window.location.pathname
          });
        }
      });
    });

    // Count-up animation
    let animFrame;
    function animateNumber(elId, target) {
      const el = document.getElementById(elId);
      const start = parseInt(el.textContent.replace(/\./g, '')) || 0;
      const duration = 700;
      const startTime = performance.now();

      if (animFrame) cancelAnimationFrame(animFrame);

      function tick(now) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(start + (target - start) * eased);
        el.textContent = fmt(current);
        if (progress < 1) animFrame = requestAnimationFrame(tick);
      }
      animFrame = requestAnimationFrame(tick);
    }

    // Auto-calculate on load if values exist
    if (subscribersEl.value) calculate();
  </script>

</LandingLayout>
