<script is:inline>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  const wheel = document.getElementById('roletaWheel');
  let spinning = false;
  let currentDeg = 0;
  if (wheel) {
    wheel.addEventListener('click', () => {
      if (spinning) return;
      spinning = true;
      const extraDeg = 720 + Math.floor(Math.random() * 360);
      currentDeg += extraDeg;
      wheel.style.transition = 'transform 2.2s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      wheel.style.transform = 'rotate(' + currentDeg + 'deg)';
      setTimeout(() => { spinning = false; }, 2400);
    });
  }
</script>

