---
export const prerender = true;

import LandingLayout from '../../../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Use Hitzz: R$ 53.104 em 15 dias com a Roleta da Sorte · edrone"
  description="Como a Use Hitzz capturou 2.700 leads e gerou R$ 53.104 em receita em 15 dias com a Roleta da Sorte gamificada da edrone — sem aumentar o orçamento de mídia."
  lang="pt-BR"
  ogTitle="Use Hitzz: R$ 53.104 em 15 dias com a Roleta da Sorte edrone"
  ogDescription="2.700 novos leads. R$ 53k em receita. 15 dias. Veja como a estratégia funcionou."
  googleFont="Plus+Jakarta+Sans:wght@700;800"
  extraGoogleFonts={["Roboto:wght@300;400;500"]}
>

<style>
    :root {
      --dark: #2D2D29;
      --turquoise: #40E0D0;
      --green: #50C878;
      --pink: #FFD1DC;
      --off-white: #FAFAF5;
      --font-head: 'Plus Jakarta Sans', 'Arial Black', sans-serif;
      --font-body: 'Roboto', sans-serif;
    }
    body { font-family: var(--font-body); color: var(--dark); background: var(--yellow); overflow-x: hidden; }
    h1, h2, h3 { font-family: var(--font-head); font-weight: 800; line-height: 1.1; }
    h1 { font-size: clamp(2.2rem, 5vw, 3.8rem); }
    h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); }
    h3 { font-size: clamp(1.1rem, 1.8vw, 1.5rem); }
    p { font-family: var(--font-body); font-weight: 400; line-height: 1.7; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 28px; }
    .section { padding: 96px 0; }
    .badge { display: inline-block; font-family: var(--font-body); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 14px; border-radius: 100px; border: 1.5px solid currentColor; margin-bottom: 24px; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-head); font-size: 1rem; font-weight: 700; padding: 16px 36px; border-radius: 8px; text-decoration: none; transition: transform 0.15s ease, box-shadow 0.15s ease; cursor: pointer; border: none; }
    .btn:hover { transform: translateY(-2px); }
    .btn-dark { background: var(--dark); color: var(--yellow); }
    .btn-dark:hover { box-shadow: 0 8px 24px rgba(45,45,41,0.28); }
    .btn-yellow { background: var(--yellow); color: var(--dark); }
    .btn-yellow:hover { box-shadow: 0 8px 24px rgba(255,255,140,0.5); }
    header { position: sticky; top: 0; z-index: 100; background: rgba(255,255,140,0.95); border-bottom: 1.5px solid rgba(45,45,41,0.1); backdrop-filter: blur(8px); }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 28px; max-width: 1100px; margin: 0 auto; }
    .logo { font-family: var(--font-head); font-size: 1.4rem; font-weight: 800; color: var(--dark); text-decoration: none; letter-spacing: -0.03em; }
    .nav-cta { padding: 10px 24px; font-size: 0.9rem; }
    #hero { background: var(--yellow); padding: 72px 0 88px; overflow: hidden; }
    .hero-inner { display: grid; grid-template-columns: 1fr 400px; gap: 64px; align-items: center; }
    .hero-badge { color: var(--dark); opacity: 0.7; }
    .hero-text h1 { color: var(--dark); margin-bottom: 20px; }
    .hero-text p { font-size: 1.15rem; color: rgba(45,45,41,0.72); max-width: 520px; margin-bottom: 36px; line-height: 1.65; }
    .hero-kpis { display: flex; gap: 36px; margin-top: 28px; padding-top: 28px; border-top: 1.5px solid rgba(45,45,41,0.14); flex-wrap: wrap; }
    .kpi-item strong { display: block; font-family: var(--font-head); font-size: 1.6rem; font-weight: 800; color: var(--dark); line-height: 1; margin-bottom: 4px; }
    .kpi-item span { font-size: 0.8rem; color: rgba(45,45,41,0.55); text-transform: uppercase; letter-spacing: 0.06em; }
    .roleta-wrapper { display: flex; flex-direction: column; align-items: center; position: relative; }
    .roleta-pointer { width: 0; height: 0; border-left: 13px solid transparent; border-right: 13px solid transparent; border-bottom: 26px solid var(--dark); position: absolute; top: -4px; z-index: 10; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15)); }
    .roleta-wheel { width: 300px; height: 300px; border-radius: 50%; border: 5px solid var(--dark); box-shadow: 0 16px 48px rgba(45,45,41,0.18), 0 4px 12px rgba(45,45,41,0.1); background: conic-gradient(var(--dark) 0deg 90deg, var(--turquoise) 90deg 180deg, var(--green) 180deg 270deg, var(--pink) 270deg 360deg); position: relative; cursor: pointer; animation: spin-in 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) both; user-select: none; }
    @keyframes spin-in { from { transform: rotate(-90deg); opacity: 0; } to { transform: rotate(0deg); opacity: 1; } }
    .roleta-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 76px; height: 76px; border-radius: 50%; background: var(--yellow); border: 4px solid var(--dark); display: flex; align-items: center; justify-content: center; font-family: var(--font-head); font-size: 0.72rem; font-weight: 800; color: var(--dark); text-transform: uppercase; letter-spacing: 0.05em; z-index: 5; pointer-events: none; }
    .roleta-label { position: absolute; font-family: var(--font-head); font-size: 0.63rem; font-weight: 800; text-transform: uppercase; text-align: center; line-height: 1.3; width: 72px; pointer-events: none; }
    .roleta-hint { margin-top: 14px; font-size: 0.78rem; color: rgba(45,45,41,0.45); text-align: center; }
    #problem { background: var(--off-white); }
    .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: start; }
    .problem-text h2 { margin-bottom: 20px; }
    .problem-text p { font-size: 1.05rem; color: rgba(45,45,41,0.72); margin-bottom: 32px; line-height: 1.7; }
    .stat-pill { display: inline-flex; flex-direction: column; background: var(--yellow); padding: 20px 28px; border-radius: 12px; border: 1.5px solid rgba(45,45,41,0.12); }
    .stat-pill strong { font-family: var(--font-head); font-size: 2.8rem; font-weight: 800; line-height: 1; margin-bottom: 4px; }
    .stat-pill span { font-size: 0.82rem; color: rgba(45,45,41,0.6); max-width: 160px; line-height: 1.4; }
    .problem-list { list-style: none; display: flex; flex-direction: column; gap: 20px; padding-top: 8px; }
    .problem-list li { display: flex; gap: 14px; font-size: 0.97rem; color: rgba(45,45,41,0.78); line-height: 1.6; }
    .picon { flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%; background: var(--dark); color: var(--yellow); display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 700; margin-top: 2px; }
    .problem-list li strong { color: var(--dark); }
    #solution { background: var(--yellow); }
    #solution h2 { margin-bottom: 14px; }
    .section-sub { font-size: 1.05rem; color: rgba(45,45,41,0.68); max-width: 580px; margin-bottom: 56px; line-height: 1.7; }
    .flow { display: flex; align-items: center; justify-content: center; gap: 4px; margin-bottom: 56px; flex-wrap: wrap; }
    .flow-step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px; min-width: 90px; padding: 4px; }
    .flow-icon { width: 56px; height: 56px; border-radius: 50%; background: var(--dark); color: var(--yellow); display: flex; align-items: center; justify-content: center; font-size: 1.35rem; }
    .flow-step span { font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; color: var(--dark); max-width: 80px; line-height: 1.3; }
    .flow-arrow { font-size: 1.2rem; color: rgba(45,45,41,0.3); flex-shrink: 0; }
    .prizes-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px; }
    .prize-card { background: var(--white); border: 1.5px solid rgba(45,45,41,0.1); border-radius: 14px; padding: 24px 18px; text-align: center; transition: transform 0.18s, box-shadow 0.18s; }
    .prize-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(45,45,41,0.1); }
    .prize-emoji { font-size: 2rem; display: block; margin-bottom: 12px; }
    .prize-label { font-family: var(--font-head); font-size: 1rem; font-weight: 800; color: var(--dark); margin-bottom: 6px; }
    .prize-desc { font-size: 0.78rem; color: rgba(45,45,41,0.55); line-height: 1.5; }
    .setup-note { text-align: center; padding: 20px 0 0; border-top: 1.5px solid rgba(45,45,41,0.12); font-size: 0.88rem; color: rgba(45,45,41,0.6); }
    .setup-note strong { color: var(--dark); }
    #results { background: var(--dark); color: var(--yellow); }
    #results .badge { border-color: rgba(255,255,140,0.25); color: rgba(255,255,140,0.55); }
    .results-hero { text-align: center; margin-bottom: 64px; }
    .big-number { font-family: var(--font-head); font-size: clamp(4.5rem, 13vw, 9.5rem); font-weight: 800; color: var(--yellow); line-height: 0.9; letter-spacing: -0.04em; display: block; margin: 8px 0 16px; }
    .big-sub { font-size: 0.78rem; color: rgba(255,255,140,0.4); text-transform: uppercase; letter-spacing: 0.1em; }
    .results-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 52px; }
    .result-card { border: 1px solid rgba(255,255,140,0.12); border-radius: 14px; padding: 32px 24px; text-align: center; }
    .result-card .rnum { font-family: var(--font-head); font-size: 2.6rem; font-weight: 800; color: var(--yellow); display: block; line-height: 1; margin-bottom: 10px; }
    .result-card .rlbl { font-size: 0.82rem; color: rgba(255,255,140,0.45); line-height: 1.4; }
    .breakdown { margin-top: 8px; }
    .breakdown-title { font-family: var(--font-head); font-size: 0.72rem; font-weight: 700; color: rgba(255,255,140,0.4); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 24px; }
    .bar-row { display: grid; grid-template-columns: 110px 1fr 130px; gap: 16px; align-items: center; margin-bottom: 14px; }
    .bar-name { font-family: var(--font-head); font-size: 0.88rem; font-weight: 700; color: var(--yellow); }
    .bar-track { height: 8px; background: rgba(255,255,140,0.08); border-radius: 100px; overflow: hidden; }
    .bar-fill { height: 100%; background: var(--turquoise); border-radius: 100px; }
    .bar-val { font-size: 0.8rem; color: rgba(255,255,140,0.5); text-align: right; }
    .results-note { text-align: center; margin-top: 36px; font-size: 0.8rem; color: rgba(255,255,140,0.28); letter-spacing: 0.04em; }
    #why { background: var(--off-white); }
    #why h2 { margin-bottom: 14px; }
    .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .why-card { background: var(--white); border: 1.5px solid rgba(45,45,41,0.07); border-radius: 18px; padding: 36px 32px; transition: transform 0.2s, box-shadow 0.2s; }
    .why-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(45,45,41,0.07); }
    .why-num { font-family: var(--font-head); font-size: 3.2rem; font-weight: 800; color: var(--yellow); display: block; line-height: 1; margin-bottom: 18px; }
    .why-card h3 { margin-bottom: 12px; }
    .why-card p { font-size: 0.95rem; color: rgba(45,45,41,0.68); line-height: 1.7; }
    #testimonial { background: var(--yellow); }
    .testimonial-inner { max-width: 680px; margin: 0 auto; text-align: center; }
    .quote-glyph { font-family: var(--font-head); font-size: 7rem; line-height: 0.6; color: rgba(45,45,41,0.12); display: block; margin-bottom: 20px; }
    blockquote { font-family: var(--font-head); font-size: clamp(1.2rem, 2.4vw, 1.75rem); font-weight: 700; color: var(--dark); line-height: 1.45; margin-bottom: 36px; }
    .author { display: inline-flex; align-items: center; gap: 14px; }
    .author-avatar { width: 48px; height: 48px; border-radius: 50%; background: var(--dark); color: var(--yellow); display: flex; align-items: center; justify-content: center; font-family: var(--font-head); font-weight: 800; font-size: 1rem; flex-shrink: 0; }
    .author-info strong { display: block; font-family: var(--font-head); font-size: 0.93rem; font-weight: 700; color: var(--dark); }
    .author-info span { font-size: 0.8rem; color: rgba(45,45,41,0.5); }
    .brand-row { display: flex; align-items: center; justify-content: center; gap: 28px; margin-top: 48px; padding-top: 36px; border-top: 1.5px solid rgba(45,45,41,0.12); flex-wrap: wrap; }
    .brand-chip { font-family: var(--font-head); font-size: 0.85rem; font-weight: 800; color: rgba(45,45,41,0.38); text-transform: uppercase; letter-spacing: 0.1em; }
    .brand-sep { width: 1px; height: 20px; background: rgba(45,45,41,0.18); }
    #cta-final { background: var(--dark); text-align: center; }
    #cta-final .badge { border-color: rgba(255,255,140,0.25); color: rgba(255,255,140,0.45); }
    #cta-final h2 { color: var(--yellow); margin-bottom: 14px; }
    #cta-final p { font-size: 1.1rem; color: rgba(255,255,140,0.55); max-width: 480px; margin: 0 auto 40px; line-height: 1.7; }
    .proof-row { display: flex; align-items: center; justify-content: center; gap: 28px; margin-top: 28px; flex-wrap: wrap; }
    .proof-item { font-size: 0.82rem; color: rgba(255,255,140,0.35); }
    .proof-dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,140,0.18); }
    .cta-micro { display: block; margin-top: 14px; font-size: 0.78rem; color: rgba(255,255,140,0.28); }
    footer { background: var(--yellow); padding: 36px 28px; border-top: 1.5px solid rgba(45,45,41,0.1); }
    .footer-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
    .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
    .footer-links a { font-size: 0.82rem; color: rgba(45,45,41,0.5); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--dark); }
    .fade-up { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    @media (max-width: 920px) { .hero-inner { grid-template-columns: 1fr; } .roleta-wrapper { display: none; } .problem-grid { grid-template-columns: 1fr; gap: 40px; } .prizes-grid { grid-template-columns: repeat(2, 1fr); } .results-cards { grid-template-columns: 1fr 1fr; } .why-grid { grid-template-columns: 1fr; } .bar-row { grid-template-columns: 90px 1fr 100px; gap: 10px; } }
    @media (max-width: 600px) { .section { padding: 64px 0; } .prizes-grid { grid-template-columns: 1fr 1fr; gap: 12px; } .results-cards { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr; } .flow-arrow { display: none; } .big-number { font-size: 4rem; } .bar-row { grid-template-columns: 80px 1fr; } .bar-val { display: none; } .hero-kpis { gap: 20px; } }
</style>

<header>
  <nav class="nav">
    <a href="https://edrone.me/br" class="logo">edrone</a>
    <a href="#cta-final" class="btn btn-dark nav-cta">Agendar demo →</a>
  </nav>
</header>

<section id="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-text fade-up">
        <span class="badge hero-badge">Case de Sucesso Real · Brasil · 2024</span>
        <h1>R$&nbsp;53.104 em 15&nbsp;dias.<br>Sem aumentar o orçamento de mídia.</h1>
        <p>Como a Use Hitzz usou a Roleta da Sorte gamificada da edrone para capturar 2.700 leads e transformar visitantes em compradores — tudo no automático.</p>
        <a href="#cta-final" class="btn btn-dark">Quero isso na minha loja →</a>
        <div class="hero-kpis">
          <div class="kpi-item"><strong>2.700</strong><span>Novos leads</span></div>
          <div class="kpi-item"><strong>15 dias</strong><span>Duração</span></div>
          <div class="kpi-item"><strong>R$ 53k</strong><span>Receita aprovada</span></div>
          <div class="kpi-item"><strong>Zero</strong><span>Mídia paga extra</span></div>
        </div>
      </div>
      <div class="roleta-wrapper">
        <div class="roleta-pointer"></div>
        <div class="roleta-wheel" id="roletaWheel" title="Clique para girar">
          <span class="roleta-label" style="top:20%; left:6%; transform:rotate(-45deg); color:#FFFF8C;">80%<br>OFF</span>
          <span class="roleta-label" style="top:8%; right:6%; transform:rotate(45deg); color:#2D2D29;">Frete<br>Grátis</span>
          <span class="roleta-label" style="bottom:8%; right:6%; transform:rotate(135deg); color:#2D2D29;">26%<br>OFF</span>
          <span class="roleta-label" style="bottom:20%; left:6%; transform:rotate(-135deg); color:#2D2D29;">Brinde<br>Especial</span>
          <div class="roleta-center">GIRE</div>
        </div>
        <p class="roleta-hint">↑ Clique para girar</p>
      </div>
    </div>
  </div>
</section>

<section id="problem" class="section">
  <div class="container">
    <div class="problem-grid fade-up">
      <div class="problem-text">
        <span class="badge">O Problema</span>
        <h2>Sua loja recebe visitas. A maioria vai embora sem comprar.</h2>
        <p>Pop-ups tradicionais são ignorados. O visitante fecha antes de ler, sai sem converter — e a receita que você pagou para trazer ele some junto com ele.</p>
        <div class="stat-pill"><strong>98%</strong><span>dos visitantes saem sem converter na primeira visita</span></div>
      </div>
      <ul class="problem-list">
        <li><div class="picon">✗</div><div><strong>Pop-ups estáticos não engajam.</strong> O visitante fecha antes de ler. Sem interação, sem lead, sem receita.</div></li>
        <li><div class="picon">✗</div><div><strong>Saída sem conversão = investimento desperdiçado.</strong> Cada visitante que vai embora custou mídia — e não voltou.</div></li>
        <li><div class="picon">✗</div><div><strong>Base de e-mail não cresce.</strong> Sem novos leads, as campanhas atingem sempre os mesmos contatos e perdem força.</div></li>
        <li><div class="picon">✗</div><div><strong>Desconto único não segmenta.</strong> Oferecer a mesma oferta para todo mundo desvaloriza a marca e comprime margem.</div></li>
      </ul>
    </div>
  </div>
</section>

<section id="solution" class="section">
  <div class="container fade-up">
    <span class="badge">A Solução</span>
    <h2>A Roleta da Sorte da edrone.</h2>
    <p class="section-sub">Um pop-up que vira um jogo. O visitante gira, ganha um incentivo real, e entra na sua lista — em segundos. A automação faz o resto.</p>
    <div class="flow">
      <div class="flow-step"><div class="flow-icon">👤</div><span>Visitante chega</span></div>
      <div class="flow-arrow">→</div>
      <div class="flow-step"><div class="flow-icon">🎯</div><span>Roleta aparece</span></div>
      <div class="flow-arrow">→</div>
      <div class="flow-step"><div class="flow-icon">🎰</div><span>Visitante gira</span></div>
      <div class="flow-arrow">→</div>
      <div class="flow-step"><div class="flow-icon">✉️</div><span>Lead capturado</span></div>
      <div class="flow-arrow">→</div>
      <div class="flow-step"><div class="flow-icon">⚡</div><span>Automação dispara</span></div>
      <div class="flow-arrow">→</div>
      <div class="flow-step"><div class="flow-icon">💰</div><span>Venda gerada</span></div>
    </div>
    <div class="prizes-grid">
      <div class="prize-card"><span class="prize-emoji">🏷️</span><div class="prize-label">80% OFF</div><div class="prize-desc">Desconto alto para converter quem estava hesitando</div></div>
      <div class="prize-card"><span class="prize-emoji">💳</span><div class="prize-label">26% OFF</div><div class="prize-desc">Desconto moderado que preserva a margem da loja</div></div>
      <div class="prize-card"><span class="prize-emoji">🚚</span><div class="prize-label">Frete Grátis</div><div class="prize-desc">Remove a principal objeção de compra no e-commerce</div></div>
      <div class="prize-card"><span class="prize-emoji">🎁</span><div class="prize-label">Brinde Especial</div><div class="prize-desc">Para clientes movidos por exclusividade e experiência</div></div>
    </div>
    <p class="setup-note"><strong>Configurado em minutos.</strong> Zero código. Integração nativa com WooCommerce, Shopify, PrestaShop, Shoper e IdoSell.</p>
  </div>
</section>

<section id="results" class="section">
  <div class="container fade-up">
    <div class="results-hero">
      <span class="badge">Os Resultados</span>
      <span class="big-number">R$&nbsp;53.104</span>
      <p class="big-sub">Receita aprovada · Use Hitzz · Calçados femininos · 15 dias</p>
    </div>
    <div class="results-cards">
      <div class="result-card"><span class="rnum">2.700</span><span class="rlbl">Novos leads capturados</span></div>
      <div class="result-card"><span class="rnum">15</span><span class="rlbl">Dias de campanha</span></div>
      <div class="result-card"><span class="rnum">4</span><span class="rlbl">Variações de incentivo</span></div>
    </div>
    <div class="breakdown">
      <p class="breakdown-title">Receita por cupom</p>
      <div class="bar-row"><span class="bar-name">80OFF</span><div class="bar-track"><div class="bar-fill" style="width:58.6%"></div></div><span class="bar-val">R$ 31.101 · 73 pedidos</span></div>
      <div class="bar-row"><span class="bar-name">26OFF</span><div class="bar-track"><div class="bar-fill" style="width:34.1%"></div></div><span class="bar-val">R$ 18.090 · 45 pedidos</span></div>
      <div class="bar-row"><span class="bar-name">PRESENTE</span><div class="bar-track"><div class="bar-fill" style="width:5.1%"></div></div><span class="bar-val">R$ 2.685 · brinde</span></div>
    </div>
    <p class="results-note">Receita gerada sem nenhum real extra de mídia paga.</p>
  </div>
</section>

<section id="why" class="section">
  <div class="container fade-up">
    <span class="badge">Por que funcionou</span>
    <h2>A estratégia por trás dos números.</h2>
    <p class="section-sub">Não foi sorte. Foi a combinação certa de psicologia, automação e segmentação inteligente.</p>
    <div class="why-grid">
