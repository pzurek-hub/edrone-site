---
export const prerender = true;

import LandingLayout from '../../../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Sapato Retrô: +241% de faturamento com Black Friday antecipada · edrone"
  description="Como a Sapato Retrô gerou R$ 390.655 em 30 dias com Black Friday antecipada — SMS com ROI de 31x, R$ 40k recuperados em automações e 7 fluxos ativos."
  lang="pt-BR"
  ogTitle="Sapato Retrô: +241% em 30 dias com edrone"
  ogDescription="R$ 390k em 30 dias. SMS com 31x ROI. R$ 40k recuperados. Black Friday antecipada com CRM edrone."
  googleFont="Plus+Jakarta+Sans:wght@700;800"
  extraGoogleFonts={["Roboto:wght@300;400;500"]}
>

<style>
    :root { --dark: #2D2D29; --turquoise: #40E0D0; --green: #50C878; --pink: #FFD1DC; --orange: #FF6B35; --off-white: #FAFAF5; --font-head: 'Plus Jakarta Sans', 'Arial Black', sans-serif; --font-body: 'Roboto', sans-serif; }
    body { font-family: var(--font-body); color: var(--dark); background: var(--yellow); overflow-x: hidden; }
    h1, h2, h3 { font-family: var(--font-head); font-weight: 800; line-height: 1.1; }
    h1 { font-size: clamp(2.2rem, 5vw, 3.8rem); } h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); } h3 { font-size: clamp(1.1rem, 1.8vw, 1.5rem); }
    p { font-family: var(--font-body); font-weight: 400; line-height: 1.7; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 28px; } .section { padding: 96px 0; }
    .badge { display: inline-block; font-family: var(--font-body); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 14px; border-radius: 100px; border: 1.5px solid currentColor; margin-bottom: 24px; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-head); font-size: 1rem; font-weight: 700; padding: 16px 36px; border-radius: 8px; text-decoration: none; transition: transform 0.15s ease, box-shadow 0.15s ease; cursor: pointer; border: none; }
    .btn:hover { transform: translateY(-2px); }
    .btn-dark { background: var(--dark); color: var(--yellow); } .btn-dark:hover { box-shadow: 0 8px 24px rgba(45,45,41,0.28); }
    .btn-yellow { background: var(--yellow); color: var(--dark); } .btn-yellow:hover { box-shadow: 0 8px 24px rgba(255,255,140,0.5); }
    header { position: sticky; top: 0; z-index: 100; background: rgba(255,255,140,0.95); border-bottom: 1.5px solid rgba(45,45,41,0.1); backdrop-filter: blur(8px); }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 28px; max-width: 1100px; margin: 0 auto; }
    .logo { font-family: var(--font-head); font-size: 1.4rem; font-weight: 800; color: var(--dark); text-decoration: none; letter-spacing: -0.03em; }
    .nav-cta { padding: 10px 24px; font-size: 0.9rem; }
    #hero { background: var(--yellow); padding: 72px 0 88px; overflow: hidden; }
    .hero-inner { display: grid; grid-template-columns: 1fr 420px; gap: 64px; align-items: center; }
    .hero-badge { color: var(--dark); opacity: 0.7; }
    .hero-text h1 { color: var(--dark); margin-bottom: 20px; }
    .hero-text p { font-size: 1.15rem; color: rgba(45,45,41,0.72); max-width: 520px; margin-bottom: 36px; line-height: 1.65; }
    .hero-kpis { display: flex; gap: 36px; margin-top: 28px; padding-top: 28px; border-top: 1.5px solid rgba(45,45,41,0.14); flex-wrap: wrap; }
    .kpi-item strong { display: block; font-family: var(--font-head); font-size: 1.6rem; font-weight: 800; color: var(--dark); line-height: 1; margin-bottom: 4px; }
    .kpi-item span { font-size: 0.8rem; color: rgba(45,45,41,0.55); text-transform: uppercase; letter-spacing: 0.06em; }
    .bf-card { background: var(--dark); border-radius: 20px; padding: 28px; box-shadow: 0 24px 64px rgba(45,45,41,0.25), 0 6px 16px rgba(45,45,41,0.12); position: relative; overflow: hidden; }
    .bf-card::before { content: ''; position: absolute; top: -80px; right: -80px; width: 240px; height: 240px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,140,0.08) 0%, transparent 70%); pointer-events: none; }
    .bf-tag { display: inline-block; background: var(--yellow); color: var(--dark); font-family: var(--font-head); font-size: 0.65rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; padding: 5px 12px; border-radius: 6px; margin-bottom: 20px; }
    .bf-revenue { text-align: center; padding: 20px 0 18px; border-bottom: 1px solid rgba(255,255,140,0.08); margin-bottom: 18px; }
    .bf-revenue .rev-lbl { font-size: 0.65rem; color: rgba(255,255,140,0.3); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 6px; display: block; }
    .bf-revenue .rev-num { font-family: var(--font-head); font-size: 2.4rem; font-weight: 800; color: var(--yellow); line-height: 1; display: block; }
    .bf-revenue .rev-period { font-size: 0.7rem; color: rgba(255,255,140,0.28); margin-top: 4px; display: block; }
    .bf-growth { display: flex; align-items: center; justify-content: center; gap: 10px; background: rgba(255,255,140,0.05); border: 1px solid rgba(255,255,140,0.1); border-radius: 10px; padding: 14px; margin-bottom: 18px; }
    .bf-growth .gr-num { font-family: var(--font-head); font-size: 2.2rem; font-weight: 800; color: var(--green); line-height: 1; }
    .bf-growth .gr-lbl { font-size: 0.72rem; color: rgba(255,255,140,0.4); line-height: 1.4; max-width: 120px; }
    .bf-channels { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 18px; }
    .bf-ch { background: rgba(255,255,140,0.04); border: 1px solid rgba(255,255,140,0.08); border-radius: 10px; padding: 12px 14px; }
    .bf-ch .ch-icon { font-size: 1.1rem; display: block; margin-bottom: 6px; }
    .bf-ch .ch-val { font-family: var(--font-head); font-size: 1.1rem; font-weight: 800; color: var(--turquoise); display: block; line-height: 1; margin-bottom: 3px; }
    .bf-ch .ch-name { font-size: 0.65rem; color: rgba(255,255,140,0.3); text-transform: uppercase; letter-spacing: 0.08em; }
    .bf-recovered { display: flex; align-items: center; gap: 12px; padding: 12px 14px; background: rgba(80,200,120,0.08); border: 1px solid rgba(80,200,120,0.18); border-radius: 10px; }
    .bf-recovered .rec-icon { font-size: 1.4rem; flex-shrink: 0; }
    .bf-recovered .rec-text { font-family: var(--font-head); font-size: 0.78rem; font-weight: 700; color: var(--green); line-height: 1.35; }
    #problem { background: var(--off-white); }
    .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: start; }
    .problem-text h2 { margin-bottom: 20px; }
    .problem-text p { font-size: 1.05rem; color: rgba(45,45,41,0.72); margin-bottom: 32px; line-height: 1.7; }
    .stat-pill { display: inline-flex; flex-direction: column; background: var(--yellow); padding: 20px 28px; border-radius: 12px; border: 1.5px solid rgba(45,45,41,0.12); }
    .stat-pill strong { font-family: var(--font-head); font-size: 2.8rem; font-weight: 800; line-height: 1; margin-bottom: 4px; }
    .stat-pill span { font-size: 0.82rem; color: rgba(45,45,41,0.6); max-width: 180px; line-height: 1.4; }
    .problem-list { list-style: none; display: flex; flex-direction: column; gap: 20px; padding-top: 8px; }
    .problem-list li { display: flex; gap: 14px; font-size: 0.97rem; color: rgba(45,45,41,0.78); line-height: 1.6; }
    .picon { flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%; background: var(--dark); color: var(--yellow); display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 700; margin-top: 2px; }
    .problem-list li strong { color: var(--dark); }
    #solution { background: var(--yellow); } #solution h2 { margin-bottom: 14px; }
    .section-sub { font-size: 1.05rem; color: rgba(45,45,41,0.68); max-width: 580px; margin-bottom: 56px; line-height: 1.7; }
    .flow { display: flex; align-items: center; justify-content: center; gap: 4px; margin-bottom: 56px; flex-wrap: wrap; }
    .flow-step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px; min-width: 90px; padding: 4px; }
    .flow-icon { width: 56px; height: 56px; border-radius: 50%; background: var(--dark); color: var(--yellow); display: flex; align-items: center; justify-content: center; font-size: 1.35rem; }
    .flow-step span { font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; color: var(--dark); max-width: 80px; line-height: 1.3; }
    .flow-arrow { font-size: 1.2rem; color: rgba(45,45,41,0.3); flex-shrink: 0; }
    .channels-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
    .channel-card { background: var(--white); border: 1.5px solid rgba(45,45,41,0.1); border-radius: 14px; padding: 28px 22px; transition: transform 0.18s, box-shadow 0.18s; }
    .channel-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(45,45,41,0.1); }
    .ch-emoji { font-size: 2rem; display: block; margin-bottom: 14px; }
    .ch-label { font-family: var(--font-head); font-size: 1rem; font-weight: 800; color: var(--dark); margin-bottom: 6px; }
    .ch-desc { font-size: 0.82rem; color: rgba(45,45,41,0.6); line-height: 1.6; margin-bottom: 14px; }
    .ch-result { font-family: var(--font-head); font-size: 1.2rem; font-weight: 800; color: var(--dark); border-top: 1.5px solid rgba(45,45,41,0.07); padding-top: 12px; margin-top: auto; }
    .ch-result-lbl { font-size: 0.7rem; color: rgba(45,45,41,0.4); font-family: var(--font-body); font-weight: 400; display: block; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.06em; }
    .setup-note { text-align: center; padding: 20px 0 0; border-top: 1.5px solid rgba(45,45,41,0.12); font-size: 0.88rem; color: rgba(45,45,41,0.6); }
    .setup-note strong { color: var(--dark); }
    #results { background: var(--dark); color: var(--yellow); }
    #results .badge { border-color: rgba(255,255,140,0.25); color: rgba(255,255,140,0.55); }
    .results-hero { text-align: center; margin-bottom: 64px; }
    .big-number { font-family: var(--font-head); font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 800; color: var(--yellow); line-height: 0.9; letter-spacing: -0.04em; display: block; margin: 8px 0 16px; }
    .big-sub { font-size: 0.78rem; color: rgba(255,255,140,0.4); text-transform: uppercase; letter-spacing: 0.1em; }
    .results-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 48px; }
    .result-card { border: 1px solid rgba(255,255,140,0.12); border-radius: 14px; padding: 24px 18px; text-align: center; }
    .result-card .rnum { font-family: var(--font-head); font-size: 2rem; font-weight: 800; color: var(--yellow); display: block; line-height: 1; margin-bottom: 8px; }
    .result-card .rlbl { font-size: 0.78rem; color: rgba(255,255,140,0.4); line-height: 1.4; }
    .results-breakdown { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
    .breakdown-title { font-family: var(--font-head); font-size: 0.72rem; font-weight: 700; color: rgba(255,255,140,0.35); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 18px; }
    .bar-row { display: grid; grid-template-columns: 120px 1fr 90px; gap: 12px; align-items: center; margin-bottom: 12px; }
    .bar-name { font-family: var(--font-head); font-size: 0.82rem; font-weight: 700; color: var(--yellow); }
    .bar-track { height: 8px; background: rgba(255,255,140,0.08); border-radius: 100px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 100px; }
    .fill-yellow { background: var(--yellow); } .fill-turquoise { background: var(--turquoise); }
    .bar-val { font-size: 0.75rem; color: rgba(255,255,140,0.45); text-align: right; }
    .sms-roi-box { margin-top: 20px; padding: 16px 20px; background: rgba(80,200,120,0.08); border: 1px solid rgba(80,200,120,0.2); border-radius: 12px; display: flex; align-items: center; gap: 14px; }
    .sms-roi-num { font-family: var(--font-head); font-size: 2.4rem; font-weight: 800; color: var(--green); line-height: 1; flex-shrink: 0; }
    .sms-roi-lbl { font-size: 0.78rem; color: rgba(255,255,140,0.4); line-height: 1.5; }
    .results-note { text-align: center; margin-top: 36px; font-size: 0.8rem; color: rgba(255,255,140,0.28); letter-spacing: 0.04em; }
    #why { background: var(--off-white); } #why h2 { margin-bottom: 14px; }
    .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .why-card { background: var(--white); border: 1.5px solid rgba(45,45,41,0.07); border-radius: 18px; padding: 36px 32px; transition: transform 0.2s, box-shadow 0.2s; }
    .why-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(45,45,41,0.07); }
    .why-num { font-family: var(--font-head); font-size: 3.2rem; font-weight: 800; color: var(--yellow); display: block; line-height: 1; margin-bottom: 18px; }
    .why-card h3 { margin-bottom: 12px; } .why-card p { font-size: 0.95rem; color: rgba(45,45,41,0.68); line-height: 1.7; }
    #testimonial { background: var(--yellow); }
    .testimonial-card { background: var(--dark); border-radius: 20px; padding: 44px 48px; max-width: 780px; margin: 0 auto; }
    .quote-glyph { font-family: var(--font-head); font-size: 5rem; line-height: 0.6; color: rgba(255,255,140,0.12); display: block; margin-bottom: 20px; }
    blockquote { font-family: var(--font-head); font-size: clamp(1.1rem, 2vw, 1.45rem); font-weight: 700; color: var(--yellow); line-height: 1.5; margin-bottom: 32px; }
    .author { display: inline-flex; align-items: center; gap: 14px; }
    .author-avatar { width: 48px; height: 48px; border-radius: 50%; background: var(--yellow); color: var(--dark); display: flex; align-items: center; justify-content: center; font-family: var(--font-head); font-weight: 800; font-size: 0.95rem; flex-shrink: 0; }
    .author-info strong { display: block; font-family: var(--font-head); font-size: 0.93rem; font-weight: 700; color: var(--yellow); }
    .author-info span { font-size: 0.78rem; color: rgba(255,255,140,0.45); }
    .brand-row { display: flex; align-items: center; justify-content: center; gap: 28px; margin-top: 48px; padding-top: 36px; border-top: 1.5px solid rgba(45,45,41,0.12); flex-wrap: wrap; }
    .brand-chip { font-family: var(--font-head); font-size: 0.85rem; font-weight: 800; color: rgba(45,45,41,0.38); text-transform: uppercase; letter-spacing: 0.1em; }
    .brand-sep { width: 1px; height: 20px; background: rgba(45,45,41,0.18); }
    #cta-final { background: var(--dark); text-align: center; }
    #cta-final .badge { border-color: rgba(255,255,140,0.25); color: rgba(255,255,140,0.45); }
    #cta-final h2 { color: var(--yellow); margin-bottom: 14px; }
    #cta-final p { font-size: 1.1rem; color: rgba(255,255,140,0.55); max-width: 500px; margin: 0 auto 40px; line-height: 1.7; }
    .proof-row { display: flex; align-items: center; justify-content: center; gap: 28px; margin-top: 28px; flex-wrap: wrap; }
    .proof-item { font-size: 0.82rem; color: rgba(255,255,140,0.35); } .proof-dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,140,0.18); }
    .cta-micro { display: block; margin-top: 14px; font-size: 0.78rem; color: rgba(255,255,140,0.28); }
    footer { background: var(--yellow); padding: 36px 28px; border-top: 1.5px solid rgba(45,45,41,0.1); }
    .footer-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
    .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
    .footer-links a { font-size: 0.82rem; color: rgba(45,45,41,0.5); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--dark); }
    .fade-up { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    @media (max-width: 980px) { .hero-inner { grid-template-columns: 1fr; } .bf-card { display: none; } .problem-grid { grid-template-columns: 1fr; gap: 40px; } .channels-grid { grid-template-columns: 1fr; } .results-cards { grid-template-columns: 1fr 1fr; } .results-breakdown { grid-template-columns: 1fr; gap: 24px; } .why-grid { grid-template-columns: 1fr; } }
    @media (max-width: 600px) { .section { padding: 64px 0; } .results-cards { grid-template-columns: 1fr 1fr; } .why-grid { grid-template-columns: 1fr; } .flow-arrow { display: none; } .big-number { font-size: 3rem; } .bar-row { grid-template-columns: 90px 1fr; } .bar-val { display: none; } .hero-kpis { gap: 20px; } .testimonial-card { padding: 28px 24px; } }
</style>

<header><nav class="nav"><a href="https://edrone.me/br" class="logo">edrone</a><a href="#cta-final" class="btn btn-dark nav-cta">Agendar demo →</a></nav></header>

<section id="hero"><div class="container"><div class="hero-inner">
  <div class="hero-text fade-up">
    <span class="badge hero-badge">Case de Sucesso Real · Calçados · Outubro 2025</span>
    <h1>+241% de faturamento em&nbsp;30&nbsp;dias.<br>Com Black Friday antecipada.</h1>
    <p>Como a Sapato Retrô usou SMS, automações comportamentais e e-mail segmentado para gerar R$&nbsp;390.655 em outubro — antes da Black Friday oficial.</p>
    <a href="#cta-final" class="btn btn-dark">Quero isso na minha loja →</a>
    <div class="hero-kpis">
      <div class="kpi-item"><strong>+241%</strong><span>Faturamento vs. mês anterior</span></div>
      <div class="kpi-item"><strong>R$&nbsp;390k</strong><span>Receita em 30 dias</span></div>
      <div class="kpi-item"><strong>31x</strong><span>ROI do canal SMS</span></div>
      <div class="kpi-item"><strong>R$&nbsp;40k</strong><span>Recuperados em automações</span></div>
    </div>
  </div>
  <div class="bf-card">
    <div class="bf-tag">⚡ Black Friday Antecipada · Out/2025</div>
    <div class="bf-revenue"><span class="rev-lbl">Receita total no mês</span><span class="rev-num">R$&nbsp;390.655</span><span class="rev-period">1–31 de outubro de 2025</span></div>
    <div class="bf-growth"><span class="gr-num">+241%</span><span class="gr-lbl">vs. mês anterior — em apenas 30 dias</span></div>
    <div class="bf-channels"><div class="bf-ch"><span class="ch-icon">📧</span><span class="ch-val">R$&nbsp;45,7k</span><span class="ch-name">E-mail</span></div><div class="bf-ch"><span class="ch-icon">📱</span><span class="ch-val">R$&nbsp;70,4k</span><span class="ch-name">SMS</span></div></div>
    <div class="bf-recovered"><span class="rec-icon">🔁</span><span class="rec-text">~R$ 40.000 recuperados por automações de carrinho + produto visualizado</span></div>
  </div>
</div></div></section>

<section id="problem" class="section"><div class="container"><div class="problem-grid fade-up">
  <div class="problem-text"><span class="badge">O Problema</span><h2>Black Friday chega. Sua base não está preparada.</h2><p>A maioria das lojas espera novembro para agir — e aí compete com todos pelo mesmo cliente, ao mesmo custo de mídia. Quem chega antes, converte mais barato.</p><div class="stat-pill"><strong>1 mês</strong><span>de antecipação que triplicou o faturamento da Sapato Retrô</span></div></div>
  <ul class="problem-list">
    <li><div class="picon">✗</div><div><strong>SMS subaproveitado.</strong> Muitos e-commerces têm o canal disponível mas nunca estruturam os momentos certos para usar — e deixam dinheiro na mesa.</div></li>
    <li><div class="picon">✗</div><div><strong>Automações inativas.</strong> Carrinhos abandonados e produtos visualizados gerando receita zero enquanto o cliente vai comprar no concorrente.</div></li>
    <li><div class="picon">✗</div><div><strong>Black Friday reativa, não estratégica.</strong> Sem planejamento de jornada, os disparos de novembro viram promoção genérica — sem segmentação, sem urgência real.</div></li>
    <li><div class="picon">✗</div><div><strong>Base sem visibilidade de impacto.</strong> Sem atribuição clara, fica impossível saber quais canais realmente geram venda — e onde dobrar a aposta.</div></li>
  </ul>
</div></div></section>

<section id="solution" class="section"><div class="container fade-up">
  <span class="badge">A Solução</span><h2>Multicanal estratégico com SMS como protagonista.</h2>
  <p class="section-sub">A Sapato Retrô ativou uma estratégia integrada de e-mail, SMS e automações comportamentais — com segmentação de base e momentos de envio definidos por comportamento real de compra.</p>
  <div class="flow">
    <div class="flow-step"><div class="flow-icon">📊</div><span>Base segmentada</span></div><div class="flow-arrow">→</div>
    <div class="flow-step"><div class="flow-icon">📱</div><span>SMS no momento certo</span></div><div class="flow-arrow">→</div>
    <div class="flow-step"><div class="flow-icon">📧</div><span>E-mail personalizado</span></div><div class="flow-arrow">→</div>
    <div class="flow-step"><div class="flow-icon">⚡</div><span>7 fluxos ativos</span></div><div class="flow-arrow">→</div>
    <div class="flow-step"><div class="flow-icon">🔁</div><span>Recuperação automática</span></div><div class="flow-arrow">→</div>
    <div class="flow-step"><div class="flow-icon">💰</div><span>+241% receita</span></div>
  </div>
