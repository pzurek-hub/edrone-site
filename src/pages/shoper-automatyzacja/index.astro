---
export const prerender = true;

import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Automatyzacja na Shoper — 10 sklepów, 4,9 mln zł przychodu | edrone"
  description="Pobierz darmowy ebook: jak 10 sklepów na Shoper wygenerowało 4,9 mln zł z automatyzacji marketingowej w edrone. Dane, screeny, wnioski."
  lang="pl"
  ogTitle="Automatyzacja na Shoper — 10 sklepów, 4,9 mln zł | edrone"
  ogDescription="Darmowy ebook z danymi z marca 2026. Przychody, ROI i screeny 10 sklepów Shoper."
  ogUrl="https://roi.edrone.me/shoper-automatyzacja/"
  googleFont="Roboto:wght@300;400;500;700;900"
>

<style>
:root {
  --yellow: #FFFF8C;
  --yellow-deep: #FFE600;
  --dark: #2E2E29;
  --ghost: #F5F3F6;
  --warm-gray: #E8E5E0;
  --pink: #FECACC;
  --lavender: #A583D5;
  --turquoise: #00FFE9;
  --white: #FFFFFF;
  --text: #2E2E29;
  --text-light: #6B6B65;
  --text-muted: #9B9B95;
  --font-display: 'Sans Pro', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  --font-outline: 'Sans Pro Outline', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  --font-body: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
}

html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body); color: var(--text);
  background: var(--warm-gray); line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}
.container { max-width: 1100px; margin: 0 auto; padding: 0 28px; }

/* HEADER */
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(232,229,224,0.88);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(46,46,41,0.08);
}
.header-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 28px;
  display: flex; align-items: center; justify-content: space-between; height: 64px;
}
.header-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.header-logo .bars { display: flex; flex-direction: column; gap: 4px; }
.header-logo .bars span { display: block; width: 22px; height: 3px; background: var(--dark); border-radius: 1px; }
.header-logo .wordmark { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--dark); font-style: italic; }

.btn-dark {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--dark); color: var(--white);
  font-family: var(--font-display); font-weight: 700;
  font-size: 14px; padding: 12px 28px; border-radius: 100px;
  border: none; cursor: pointer; text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.btn-dark:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(46,46,41,0.2); }

.btn-yellow-pill {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--yellow); color: var(--dark);
  font-family: var(--font-display); font-weight: 700;
  font-size: 15px; padding: 16px 36px; border-radius: 100px;
  border: none; cursor: pointer; text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.btn-yellow-pill:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(255,255,140,0.4); }

/* HERO */
.hero {
  padding: 110px 0 60px; position: relative; overflow: hidden;
  min-height: 90vh; display: flex; align-items: center;
}
.hero-grid {
  display: grid; grid-template-columns: 1fr 420px; gap: 60px; align-items: center;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-weight: 500; font-size: 13px; color: var(--text-light);
  letter-spacing: 0.04em; margin-bottom: 24px;
}
.hero-badge .dot { width: 6px; height: 6px; background: var(--lavender); border-radius: 50%; }

.hero h1 { font-size: 52px; line-height: 1.05; margin-bottom: 20px; }
.hero h1 .outline { font-family: var(--font-outline); font-weight: 700; display: block; }
.hero h1 .solid { font-family: var(--font-display); font-weight: 700; display: block; }
.hero h1 .highlight {
  font-family: var(--font-display); font-weight: 700;
  background: var(--yellow); padding: 2px 8px; display: inline;
}

.hero-sub { font-size: 17px; color: var(--text-light); line-height: 1.65; margin-bottom: 28px; max-width: 480px; }

.hero-stats { display: flex; gap: 32px; margin-bottom: 36px; }
.hero-stat .num { font-family: var(--font-display); font-size: 28px; font-weight: 700; color: var(--dark); line-height: 1.1; }
.hero-stat .label { font-size: 13px; color: var(--text-muted); margin-top: 2px; }

.hero-form { display: flex; gap: 10px; max-width: 440px; }
.hero-form input {
  flex: 1; padding: 16px 20px;
  border: 2px solid rgba(46,46,41,0.12); border-radius: 100px;
  font-size: 15px; font-family: var(--font-body); background: var(--white);
  transition: border-color 0.2s;
}
.hero-form input:focus { outline: none; border-color: var(--lavender); }
.hero-form input::placeholder { color: var(--text-muted); }

.hero-micro { font-size: 12px; color: var(--text-muted); margin-top: 12px; display: flex; gap: 16px; }

/* EBOOK MOCKUP */
.ebook-visual { position: relative; display: flex; justify-content: center; align-items: center; }

.ebook-cover-card {
  width: 340px; height: 460px; background: var(--warm-gray);
  border: 1px solid rgba(46,46,41,0.08);
  border-radius: 4px 12px 12px 4px; padding: 40px 32px;
  position: relative; overflow: hidden;
  box-shadow: -16px 16px 48px rgba(46,46,41,0.12), 0 2px 8px rgba(46,46,41,0.06);
  transition: transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94);
}
.ebook-cover-card:hover { transform: translateY(-4px); }
.ebook-cover-card .spine { position: absolute; left: 0; top: 0; bottom: 0; width: 6px; background: linear-gradient(to right, rgba(46,46,41,0.15), transparent); }
.ebook-cover-card .edrone-tag { font-family: var(--font-display); font-size: 14px; font-weight: 700; color: var(--dark); font-style: italic; position: absolute; top: 24px; right: 28px; }
.ebook-cover-card .title-block { margin-top: 40px; }
.ebook-cover-card .title-highlight { font-family: var(--font-display); font-weight: 700; font-size: 28px; background: var(--yellow); padding: 4px 10px; display: inline; line-height: 1.6; }
.ebook-cover-card .title-outline { font-family: var(--font-outline); font-weight: 700; font-size: 30px; line-height: 1.15; margin-top: 8px; color: var(--dark); }
.ebook-cover-card .title-solid { font-family: var(--font-display); font-weight: 700; font-size: 30px; line-height: 1.15; color: var(--dark); }

.ebook-decorations { position: absolute; bottom: 0; left: 0; right: 0; height: 200px; overflow: hidden; }
.deco-bars { position: absolute; bottom: 20px; left: 24px; display: flex; align-items: flex-end; gap: 5px; }
.deco-bars span { display: block; width: 12px; background: var(--yellow-deep); border-radius: 2px 2px 0 0; }
.deco-bubble-1 { position: absolute; right: 20px; bottom: 60px; width: 120px; height: 85px; background: var(--pink); border-radius: 16px; transform: rotate(-8deg); }
.deco-bubble-2 { position: absolute; right: 60px; bottom: 30px; width: 80px; height: 55px; background: var(--lavender); border-radius: 12px; transform: rotate(5deg); opacity: 0.7; }
.deco-circle { position: absolute; right: 30px; bottom: 10px; width: 60px; height: 60px; border: 6px solid var(--lavender); border-radius: 50%; opacity: 0.5; }

/* STATS STRIP */
.stats-strip { padding: 48px 0; background: var(--white); border-top: 3px solid var(--yellow); }
.stats-strip-inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; text-align: center; }
.stat-block .num { font-family: var(--font-display); font-size: 36px; font-weight: 700; color: var(--dark); line-height: 1.1; }
.stat-block .label { font-size: 14px; color: var(--text-light); margin-top: 4px; }

/* STORES */
.stores-section { padding: 80px 0; }
.section-header { text-align: center; margin-bottom: 48px; }
.section-header h2 { font-size: 38px; line-height: 1.1; margin-bottom: 12px; }
.section-header h2 .outline { font-family: var(--font-outline); font-weight: 700; }
.section-header h2 .solid { font-family: var(--font-display); font-weight: 700; }
.section-header p { font-size: 17px; color: var(--text-light); max-width: 500px; margin: 0 auto; }

.stores-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.store-card {
  background: var(--white); border-radius: 16px; padding: 24px;
  display: flex; align-items: center; gap: 18px;
  border: 1px solid rgba(46,46,41,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}
.store-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(46,46,41,0.08); }
.store-num {
  width: 40px; height: 40px; border-radius: 50%; background: var(--yellow);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--dark); flex-shrink: 0;
}
.store-info { flex: 1; }
.store-info .name { font-family: var(--font-display); font-weight: 700; font-size: 15px; }
.store-info .branch { font-size: 13px; color: var(--text-muted); }
.store-metrics { display: flex; gap: 16px; text-align: right; }
.store-metric .val { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--dark); }
.store-metric .lbl { font-size: 11px; color: var(--text-muted); }

/* WHAT'S INSIDE */
.inside-section { padding: 80px 0; background: var(--dark); color: var(--white); position: relative; overflow: hidden; }
.inside-section::before { content: ''; position: absolute; top: -60px; right: -60px; width: 300px; height: 300px; background: var(--lavender); border-radius: 50%; opacity: 0.08; }
.inside-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.inside-card {
  background: rgba(255,255,255,0.06); border-radius: 16px; padding: 32px 28px;
  border-top: 3px solid var(--yellow); transition: background 0.2s;
}
.inside-card:hover { background: rgba(255,255,255,0.1); }
.inside-card .icon { font-size: 28px; margin-bottom: 16px; display: flex; align-items: center; justify-content: center; width: 52px; height: 52px; background: rgba(255,255,140,0.12); border-radius: 12px; }
.inside-card h3 { font-family: var(--font-display); font-weight: 700; font-size: 18px; margin-bottom: 8px; color: var(--white); }
.inside-card p { font-size: 14px; color: rgba(255,255,255,0.55); line-height: 1.6; }

/* PRO TIP */
.protip-section { padding: 60px 0; }
.protip-box {
  background: var(--yellow); border-radius: 16px; padding: 40px 48px;
  display: flex; align-items: flex-start; gap: 20px; max-width: 800px; margin: 0 auto;
}
.protip-box .star { font-family: var(--font-display); font-size: 28px; font-weight: 700; flex-shrink: 0; }
.protip-box .label { font-family: var(--font-display); font-weight: 700; font-size: 15px; margin-bottom: 6px; }
.protip-box p { font-size: 15px; color: var(--dark); line-height: 1.6; }

/* SOCIAL PROOF */
.proof-section { padding: 48px 0; text-align: center; }
.proof-label { font-size: 12px; color: var(--text-muted); letter-spacing: 0.08em; font-weight: 500; margin-bottom: 20px; }
.proof-logos { display: flex; justify-content: center; align-items: center; gap: 40px; flex-wrap: wrap; opacity: 0.4; }
.proof-logos span { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--dark); }

/* CTA */
.cta-section { padding: 100px 0; background: var(--white); text-align: center; position: relative; }
.cta-section::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 600px; height: 300px; background: radial-gradient(ellipse, rgba(255,255,140,0.3) 0%, transparent 70%); pointer-events: none; }
.cta-section h2 { font-size: 42px; line-height: 1.1; margin-bottom: 16px; position: relative; }
.cta-section h2 .outline { font-family: var(--font-outline); font-weight: 700; }
.cta-section h2 .solid { font-family: var(--font-display); font-weight: 700; }
.cta-section .sub { font-size: 18px; color: var(--text-light); max-width: 500px; margin: 0 auto 36px; }
.cta-form-bottom { display: flex; gap: 10px; justify-content: center; max-width: 460px; margin: 0 auto; }
.cta-form-bottom input { flex: 1; padding: 16px 24px; border: 2px solid rgba(46,46,41,0.1); border-radius: 100px; font-size: 15px; font-family: var(--font-body); background: var(--ghost); }
.cta-form-bottom input:focus { outline: none; border-color: var(--dark); }
.cta-trust { display: flex; justify-content: center; gap: 24px; margin-top: 16px; font-size: 13px; color: var(--text-muted); }

/* FOOTER */
.footer { padding: 28px 0; text-align: center; font-size: 13px; color: var(--text-muted); border-top: 1px solid rgba(46,46,41,0.08); }
.footer a { color: var(--text-muted); text-decoration: none; }
.footer a:hover { color: var(--dark); }

/* ANIMATIONS */
@keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
.fade-up { opacity: 0; animation: fadeUp 0.6s cubic-bezier(0.25,0.46,0.45,0.94) forwards; }
.delay-1 { animation-delay: 0.1s; } .delay-2 { animation-delay: 0.2s; } .delay-3 { animation-delay: 0.3s; } .delay-4 { animation-delay: 0.4s; }

/* RESPONSIVE */
@media (max-width: 900px) {
  .hero-grid { grid-template-columns: 1fr; gap: 40px; }
  .ebook-visual { order: -1; }
  .hero h1 { font-size: 38px; }
  .stats-strip-inner { grid-template-columns: repeat(2, 1fr); }
  .stores-grid { grid-template-columns: 1fr; }
  .inside-grid { grid-template-columns: 1fr; }
  .cta-form-bottom { flex-direction: column; }
  .cta-form-bottom input, .cta-form-bottom button { width: 100%; }
  .protip-box { flex-direction: column; padding: 28px; }
  .section-header h2 { font-size: 30px; }
  .cta-section h2 { font-size: 32px; }
}
@media (max-width: 600px) {
  .hero h1 { font-size: 32px; }
  .hero-form { flex-direction: column; }
  .hero-stats { flex-wrap: wrap; gap: 16px; }
  .stats-strip-inner { grid-template-columns: 1fr 1fr; gap: 16px; }
  .store-metrics { flex-direction: column; gap: 4px; }
  .hero-micro { flex-direction: column; gap: 4px; }
}
</style>

