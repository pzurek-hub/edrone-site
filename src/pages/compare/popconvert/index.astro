      </svg>
    </a>
    <a href="https://control.edrone.me/register" class="hdr-cta">
      Try edrone Free
      <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</header>

<!-- ═══════ HERO ═══════ -->
<section class="hero-section">
  <div class="hero">
    <div class="hero-badge">Comparison Guide</div>

    <div class="vs-row">
      <div class="vs-brand">
        <div class="vs-icon vs-icon--edrone">e</div>
        <span class="vs-brand-name">edrone</span>
      </div>
      <span class="vs-divider">vs</span>
      <div class="vs-brand">
        <div class="vs-icon vs-icon--pop">P</div>
        <span class="vs-brand-name">Popconvert</span>
      </div>
    </div>

