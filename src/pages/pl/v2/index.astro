---
export const prerender = true;

import LandingLayout from '../../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Kalkulator ROI | edrone — ile przychodu tracisz?"
  description="Sprawdź ile dodatkowego przychodu możesz generować z automatyzacji email marketingu z edrone. Kalkulator oparty na realnych danych z 1000+ sklepów."
  lang="pl"
  ogTitle="Kalkulator ROI | edrone — ile przychodu traci Twój sklep?"
  ogDescription="Oblicz w 30 sekund ile dodatkowego przychodu możesz generować z email marketingu. Dane z 1000+ sklepów."
  ogUrl="https://roi.edrone.me/pl/v2/"
  googleFont="Roboto:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400;1,700;1,900"
>

<style>
    /* ── HEADER ── */
    .header {
      position: sticky;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(46, 46, 41, 0.08);
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .header-logo svg { display: block; }
    .btn-nav {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--yellow);
      color: var(--dark);
      font-weight: 700;
      font-size: 14px;
      padding: 10px 24px;
      border-radius: 100px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
    }
    .btn-nav:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(255, 255, 140, 0.5);
    }
    .btn-nav svg { width: 14px; height: 14px; }

    /* ── CTA BUTTON (black) ── */
    .btn-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--dark);
      color: var(--white);
      font-weight: 700;
      font-size: 17px;
      padding: 16px 36px;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
    }
    .btn-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(46, 46, 41, 0.2);
    }
    .btn-cta .arrow { font-size: 20px; transition: transform 0.2s; }
    .btn-cta:hover .arrow { transform: translateX(3px); }

    /* ── HERO (white bg with yellow gradient cloud) ── */
    .hero-section {
      background: var(--white);
      position: relative;
      overflow: hidden;
    }
    .hero-section::after {
      content: '';
      position: absolute;
      bottom: -15%;
      left: -10%;
      width: 70%;
      height: 70%;
      background: radial-gradient(ellipse at 25% 95%, #FFFF8C 0%, #FFFF8C66 30%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 24px 88px;
      display: grid;
      grid-template-columns: 1fr 440px;
      gap: 64px;
      align-items: center;
      position: relative;
      z-index: 1;
    }
    @media (max-width: 960px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 40px;
        padding: 48px 20px 56px;
      }
    }

    .hero-copy { max-width: 560px; }
    .hero-copy .outline-text {
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.1;
      display: block;
      margin-bottom: 4px;
    }
    .hero h1 {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
      font-weight: 900;
      font-size: clamp(36px, 5vw, 56px);
      line-height: 1.08;
      color: var(--dark);
      margin-bottom: 20px;
    }
    .hero-sub {
      font-size: 18px;
      color: #555550;
      line-height: 1.65;
      max-width: 480px;
      margin-bottom: 36px;
      font-weight: 300;
    }
    .hero-proof {
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .hero-proof-item { display: flex; flex-direction: column; }
    .hero-proof-num {
      font-size: 22px;
      font-weight: 900;
      letter-spacing: -0.5px;
      color: var(--dark);
      font-variant-numeric: tabular-nums;
    }
    .hero-proof-label {
      font-size: 12px;
      color: #888;
      font-weight: 400;
    }

    /* ── CALC CARD ── */
    .calc-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 36px 32px 32px;
      box-shadow: var(--shadow-xl);
      position: relative;
    }
    .calc-card-accent {
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 4px;
      background: var(--yellow);
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .calc-card-label {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #888;
      margin-bottom: 28px;
    }

    .field { margin-bottom: 24px; }
    .field:last-of-type { margin-bottom: 0; }
    .field label {
      display: block;
      font-size: 14px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 8px;
    }
    .field select,
    .field input[type="number"] {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid rgba(46, 46, 41, 0.12);
      border-radius: 12px;
      font-size: 15px;
      font-family: 'Roboto', sans-serif;
      background: var(--white);
      color: var(--dark);
      transition: all 0.2s;
      appearance: none;
      -webkit-appearance: none;
    }
    .field select {
      background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%232E2E29' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
      background-repeat: no-repeat;
      background-position: right 16px center;
      padding-right: 40px;
      cursor: pointer;
    }
    .field select:focus,
    .field input:focus {
      outline: none;
      border-color: var(--dark);
      box-shadow: 0 0 0 3px rgba(255, 255, 140, 0.3);
    }

    .slider-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 10px;
    }
    .slider-row input[type="range"] {
      flex: 1;
      -webkit-appearance: none;
      appearance: none;
      height: 6px;
      background: rgba(46, 46, 41, 0.12);
      border-radius: 3px;
      outline: none;
    }
    .slider-row input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 24px; height: 24px;
      background: var(--yellow);
      border: 3px solid var(--dark);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 2px 6px rgba(46, 46, 41, 0.15);
    }
    .slider-row input[type="range"]::-moz-range-thumb {
      width: 24px; height: 24px;
      background: var(--yellow);
      border: 3px solid var(--dark);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 2px 6px rgba(46, 46, 41, 0.15);
    }
    .slider-row input[type="range"]::-moz-range-progress {
      background: var(--dark);
      height: 6px;
      border-radius: 3px;
    }
    .slider-val {
      font-size: 14px;
      font-weight: 700;
      color: var(--dark);
      min-width: 56px;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .field-hint {
      font-size: 12px;
      color: #999;
      margin-top: 6px;
    }
    .field-error {
      font-size: 12px;
      color: #EF4444;
      margin-top: 6px;
      display: none;
    }
    .field-error.show { display: block; }

    /* ── RESULTS ── */
    .results-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
      z-index: 2;
      margin-top: -40px;
      opacity: 0;
      transform: translateY(24px);
      transition: all 0.6s cubic-bezier(0.22,1,0.36,1);
      pointer-events: none;
      max-height: 0;
      overflow: hidden;
    }
    .results-wrap.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      max-height: 700px;
      margin-bottom: 48px;
    }
    @media (max-width: 960px) {
      .results-wrap { padding: 0 20px; margin-top: 0; }
    }

    .results-card {
      background: var(--dark);
      border-radius: var(--radius);
      padding: 48px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: start;
      box-shadow: var(--shadow-xl);
    }
    @media (max-width: 800px) {
      .results-card {
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 32px 24px;
      }
    }

    .result-eyebrow {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--yellow);
      margin-bottom: 12px;
    }
    .result-amount-row {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 4px;
    }
    .result-plus {
      font-family: 'Sans Pro', 'Roboto', sans-serif;
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 700;
      color: var(--yellow);
      letter-spacing: -2px;
    }
    .result-number {
      font-size: clamp(36px, 6vw, 56px);
      font-weight: 900;
      letter-spacing: -2px;
      line-height: 1;
      color: var(--white);
      font-variant-numeric: tabular-nums;
    }
    .result-currency {
      font-size: clamp(18px, 2.5vw, 24px);
      font-weight: 700;
      color: rgba(255, 255, 255, 0.5);
    }
    .result-period {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 4px;
    }
    .result-yearly {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 28px;
    }
    .result-yearly strong {
      color: var(--white);
      font-weight: 700;
    }

    .result-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--yellow);
      color: var(--dark);
      padding: 16px 32px;
      border-radius: 100px;
      text-decoration: none;
      font-size: 15px;
      font-weight: 700;
      transition: all 0.2s;
      border: none;
      cursor: pointer;
      font-family: inherit;
    }
    .result-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255,255,140,0.4);
    }
    .result-cta svg { width: 16px; height: 16px; }
    .result-sub {
      display: block;
      margin-top: 14px;
      font-size: 12px;
      color: rgba(255, 255, 255, 0.4);
    }

    /* Scenarios */
    .scenarios { display: flex; flex-direction: column; gap: 20px; }
    .scenarios-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 4px;
    }
    .scenario-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }
    .scenario-name {
      font-size: 13px;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.5);
    }
    .scenario-val {
      font-size: 15px;
      font-weight: 700;
      color: var(--white);
      font-variant-numeric: tabular-nums;
    }
    .scenario-bar {
      height: 8px;
      background: rgba(255,255,255,0.06);
      border-radius: 4px;
      overflow: hidden;
    }
    .scenario-fill {
      height: 100%;
      border-radius: 4px;
      width: 0%;
      transition: width 1s cubic-bezier(0.34,1.56,0.64,1);
    }
    .scenario:nth-child(2) .scenario-fill {
      background: linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255,255,255,0.16));
    }
    .scenario:nth-child(3) .scenario-fill {
      background: linear-gradient(90deg, rgba(255,255,140,0.2), rgba(255,255,140,0.35));
    }
    .scenario:nth-child(4) .scenario-fill {
      background: linear-gradient(90deg, #e6e66e, var(--yellow));
    }

    .result-context {
      grid-column: 1 / -1;
      text-align: center;
      font-size: 12px;
      color: rgba(255,255,255,0.35);
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    /* ── SYSTEM PREVIEW ── */
    .preview {
      padding: 80px 24px;
      max-width: 1200px;
      margin: 0 auto;
      content-visibility: auto;
      contain-intrinsic-size: 0 800px;
    }
    .preview-header {
      text-align: center;
      margin-bottom: 48px;
    }
    .preview-header .outline-text {
      font-size: clamp(24px, 3vw, 36px);
      display: block;
      margin-bottom: 4px;
    }
    .preview-header .bold-text {
      font-size: clamp(32px, 4vw, 48px);
      font-weight: 900;
      color: var(--dark);
      line-height: 1.1;
    }
    .preview-sub {
      text-align: center;
      font-size: 16px;
      color: #888;
      max-width: 520px;
      margin: 16px auto 48px;
      font-weight: 300;
    }

    .browser-mockup {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow-xl);
      overflow: hidden;
      border: 1px solid rgba(46, 46, 41, 0.08);
      max-width: 900px;
      margin: 0 auto 48px;
    }
    .browser-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 14px 18px;
      background: var(--ghost);
      border-bottom: 1px solid rgba(46, 46, 41, 0.08);
    }
    .browser-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: rgba(46, 46, 41, 0.15);
    }
    .browser-dot:nth-child(1) { background: #FF5F57; }
    .browser-dot:nth-child(2) { background: #FEBC2E; }
    .browser-dot:nth-child(3) { background: #28C840; }
    .browser-url {
      flex: 1;
      margin-left: 12px;
      background: var(--white);
      border: 1px solid rgba(46, 46, 41, 0.08);
      border-radius: 8px;
      padding: 6px 14px;
      font-size: 12px;
      color: #999;
      font-family: 'Roboto', monospace;
    }
    .browser-mockup img {
      width: 100%;
      display: block;
      height: 420px;
      object-fit: cover;
      object-position: center 18%;
    }

    /* ── FEATURES SECTION (yellow bg) ── */
    .features-section {
      background: var(--yellow);
      padding: 80px 0;
    }
    .features-header {
      text-align: center;
      margin-bottom: 48px;
    }
    .features-header .outline-text {
      font-size: clamp(24px, 3vw, 36px);
      display: block;
      margin-bottom: 4px;
    }
    .features-header .bold-text {
      font-size: clamp(32px, 4vw, 48px);
      font-weight: 900;
      color: var(--dark);
      line-height: 1.1;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    @media (max-width: 768px) {
      .features-grid { grid-template-columns: 1fr; gap: 20px; }
    }
    .feature-item {
      padding: 32px;
      border-radius: var(--radius);
      background: var(--white);
      transition: transform 0.2s;
    }
    .feature-item:hover { transform: translateY(-3px); }
    .feature-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
      font-size: 22px;
      background: var(--yellow);
    }
    .feature-item h3 {
      font-size: 18px;
      font-weight: 900;
      color: var(--dark);
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .feature-item p {
      font-size: 15px;
      color: #666;
      line-height: 1.65;
      font-weight: 300;
    }

    /* ── SOCIAL PROOF (dark bg) ── */
    .proof {
      padding: 64px 0;
      background: var(--dark);
      overflow: hidden;
      content-visibility: auto;
      contain-intrinsic-size: 0 300px;
    }
    .marquee {
      mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
      margin-bottom: 36px;
    }
    .marquee-track {
      display: flex;
      gap: 64px;
      align-items: center;
      width: max-content;
      animation: marqueeScroll 40s linear infinite;
    }
    @keyframes marqueeScroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .marquee-track img {
      height: 22px;
      width: auto;
      filter: brightness(0) invert(1);
      opacity: 0.3;
      transition: opacity 0.3s;
    }
    .marquee-track img:hover { opacity: 0.6; }

    .proof-stats {
      display: flex;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
      max-width: 800px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .proof-stat { text-align: center; }
    .proof-stat-num {
      font-size: 28px;
      font-weight: 900;
      letter-spacing: -1px;
      display: block;
      font-variant-numeric: tabular-nums;
      color: var(--white);
    }
    .proof-stat:nth-child(1) .proof-stat-num { color: var(--yellow); }
    .proof-stat:nth-child(2) .proof-stat-num { color: var(--yellow); }
    .proof-stat-label {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.4);
      font-weight: 400;
    }

    /* ── CLOSING CTA ── */
    .closing-cta {
      padding: 96px 24px;
      text-align: center;
      background: var(--white);
    }
    .closing-cta .outline-text {
      font-size: clamp(24px, 3vw, 36px);
      display: block;
      margin-bottom: 4px;
    }
    .closing-cta .bold-text {
      font-size: clamp(32px, 4vw, 48px);
      font-weight: 900;
      color: var(--dark);
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .closing-cta p {
      font-size: 18px;
      color: #888;
      margin-bottom: 36px;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
      font-weight: 300;
    }
    .closing-cta .btn-cta {
      font-size: 17px;
      padding: 18px 40px;
    }
    .closing-cta .cta-sub {
      display: block;
      margin-top: 16px;
      font-size: 13px;
      color: #999;
    }

    /* ── FOOTER ── */
    .footer {
      padding: 32px 0;
      text-align: center;
      font-size: 13px;
      color: #999;
      border-top: 1px solid rgba(46, 46, 41, 0.08);
      font-weight: 300;
    }
    .footer a {
      color: #999;
      text-decoration: none;
    }
    .footer a:hover { color: var(--dark); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-copy > * { opacity: 0; animation: fadeUp 0.6s forwards; }
    .hero-copy > *:nth-child(1) { animation-delay: 0.1s; }
    .hero-copy > *:nth-child(2) { animation-delay: 0.2s; }
    .hero-copy > *:nth-child(3) { animation-delay: 0.3s; }
    .hero-copy > *:nth-child(4) { animation-delay: 0.4s; }
    .calc-card { opacity: 0; animation: fadeUp 0.7s 0.25s forwards; }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .hero { padding: 36px 16px 40px; }
      .hero-proof { gap: 20px; }
      .calc-card { padding: 28px 20px 24px; }
      .results-card { padding: 24px 16px; }
      .preview { padding: 48px 16px; }
      .proof-stats { gap: 24px; }
      .features-section { padding: 48px 0; }
      .closing-cta { padding: 64px 16px; }
      .testimonials-grid { grid-template-columns: 1fr; }
    }

    /* ── TESTIMONIALS ── */
    .testimonials-section {
      padding: 64px 24px;
      background: var(--dark);
    }
    .testimonials-section .container { max-width: 1000px; margin: 0 auto; }
    .testimonials-label {
      text-align: center;
      font-size: 12px;
      color: rgba(255,255,255,0.4);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 32px;
    }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .testimonial-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 28px 24px;
    }
    .testimonial-stars {
      color: #F59E0B;
      font-size: 16px;
      margin-bottom: 12px;
      letter-spacing: 2px;
    }
    .testimonial-quote {
      font-size: 15px;
      color: rgba(255,255,255,0.8);
      line-height: 1.6;
      font-style: italic;
      margin-bottom: 16px;
    }
    .testimonial-author {
      font-size: 13px;
      font-weight: 700;
      color: var(--white);
    }
    .testimonial-role {
      font-size: 12px;
      color: rgba(255,255,255,0.4);
      margin-top: 2px;
    }
</style>

  <!-- HEADER -->
  <header class="header">
    <div class="header-inner">
